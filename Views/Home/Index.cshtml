@model Bachelor_s_Point.Application.DTOs.PagedResult<Room>
@{
    ViewData["Title"] = "Home";

    string GetCoverImage(Room r)
    {
        if (r.Images == null || !r.Images.Any()) return "";
        var primary = r.Images.FirstOrDefault(i => i.IsPrimary);
        return (primary?.ImagePath ?? r.Images.OrderBy(i => i.DisplayOrder).First().ImagePath) ?? "";
    }
}

<style>
    .room-card-image {
        height: 180px;
        background: #e3e8ef;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .room-card-image img { width: 100%; height: 100%; object-fit: cover; }
    .room-card-image .no-img { color: #9ca3af; font-size: 3rem; }
</style>

<div class="hero-welcome">
    <div class="container">
        <h1 class="display-5">Welcome to Bachelor's Point</h1>
        <p class="lead mt-2 mb-3">Find a bachelor room, or list one for others.</p>
        <a asp-controller="Room" asp-action="Index" class="btn btn-light">
            <i class="bi bi-search me-1"></i> Browse all rooms
        </a>
    </div>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
        <h3 class="mb-0"><i class="bi bi-houses-fill me-2 text-secondary"></i>Latest Available Rooms</h3>
        @if (Model.TotalCount > 0)
        {
            <span class="text-muted small">
                Showing @((Model.Page - 1) * Model.PageSize + 1)
                – @((Model.Page - 1) * Model.PageSize + Model.Items.Count)
                of @Model.TotalCount
            </span>
        }
    </div>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i> No rooms have been posted yet.
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var room in Model.Items)
            {
                string cover = GetCoverImage(room);
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="room-card-image">
                            @if (!string.IsNullOrEmpty(cover))
                            {
                                <img src="@cover" alt="@room.Title" />
                            }
                            else
                            {
                                <i class="bi bi-image no-img"></i>
                            }
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@room.Title</h5>
                            <h6 class="card-subtitle text-muted mb-2">
                                <i class="bi bi-geo-alt"></i> @room.Location
                            </h6>
                            <p class="card-text">
                                @(room.Description?.Length > 100 ? room.Description.Substring(0, 100) + "..." : room.Description)
                            </p>
                            <p class="mb-0"><strong class="text-success">BDT @room.Price</strong></p>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <a asp-controller="Room" asp-action="Details" asp-route-id="@room.Id" class="btn btn-sm btn-outline-primary">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)">
                            <i class="bi bi-chevron-left"></i> Previous
                        </a>
                    </li>
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.HasNext ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

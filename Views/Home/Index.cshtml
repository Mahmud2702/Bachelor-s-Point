    }

    @@media (max-width: 575.98px) {
        .admin-stat-grid {
            grid-template-columns: 1fr;
        }

        .admin-status-mini {
            grid-template-columns: 1fr;
        }

        .public-room-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@if (isAdminUser)
{
    <section class="admin-home-page">
        <div class="admin-home-shell">

            <div class="admin-hero">
                <div class="admin-hero-content">
                    <div>
                        <div class="admin-kicker">
                            <i class="fa-solid fa-shield-halved"></i>
                            <span>Admin Control Center</span>
                        </div>

                        <h1>Welcome back, Admin</h1>

                        <p>
                            Monitor room approvals, user verification, payments, roles, and platform activity from one clean dashboard.
                        </p>

                        <div class="admin-hero-actions">
                            <a asp-controller="Room" asp-action="Pending" class="admin-btn admin-btn-primary">
                                <i class="fa-solid fa-clock-rotate-left"></i>
                                Review Pending Rooms
                            </a>

                            <a asp-controller="Payment" asp-action="AdminPayments" class="admin-btn admin-btn-soft">
                                <i class="fa-solid fa-credit-card"></i>
                                Check Payments
                            </a>

                            <a asp-controller="Kyc" asp-action="Pending" class="admin-btn admin-btn-soft">
                                <i class="fa-solid fa-id-card-clip"></i>
                                Verify Users
                            </a>
                        </div>
                    </div>

                    <div class="admin-status-panel">
                        <div class="admin-status-number">@totalAttentionCount</div>
                        <span>items need admin attention</span>

                        <div class="admin-status-mini">
                            <div>
                                <strong>@pendingRoomCount</strong>
                                <small>Rooms</small>
                            </div>
                            <div>
                                <strong>@pendingKycCount</strong>
                                <small>KYC</small>
                            </div>
                            <div>
                                <strong>@pendingPaymentCount</strong>
                                <small>Payments</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-section">
                <div class="admin-section-head">
                    <div>
                        <h2 class="admin-section-title">
                            <i class="fa-solid fa-chart-simple"></i>
                            Platform Overview
                        </h2>
                        <p class="admin-section-subtitle">Quick numbers for system health and pending workload.</p>
                    </div>
                </div>

                <div class="admin-stat-grid">
                    <div class="admin-stat-card">
                        <div class="admin-stat-icon">
                            <i class="fa-solid fa-hourglass-half"></i>
                        </div>
                        <h3 class="admin-stat-value">@pendingRoomCount</h3>
                        <p class="admin-stat-label">Pending Rooms</p>
                        <p class="admin-stat-hint">Room posts waiting for approval.</p>
                    </div>

                    <div class="admin-stat-card">
                        <div class="admin-stat-icon">
                            <i class="fa-solid fa-id-card"></i>
                        </div>
                        <h3 class="admin-stat-value">@pendingKycCount</h3>
                        <p class="admin-stat-label">KYC Requests</p>
                        <p class="admin-stat-hint">Identity submissions awaiting review.</p>
                    </div>

                    <div class="admin-stat-card">
                        <div class="admin-stat-icon">
                            <i class="fa-solid fa-money-check-dollar"></i>
                        </div>
                        <h3 class="admin-stat-value">@pendingPaymentCount</h3>
                        <p class="admin-stat-label">Payments</p>
                        <p class="admin-stat-hint">Transactions needing verification.</p>
                    </div>

                    <div class="admin-stat-card">
                        <div class="admin-stat-icon">
                            <i class="fa-solid fa-house-circle-check"></i>
                        </div>
                        <h3 class="admin-stat-value">@activeRoomCount</h3>
                        <p class="admin-stat-label">Active Rooms</p>
                        <p class="admin-stat-hint">Approved and available listings.</p>
                    </div>

                    <div class="admin-stat-card">
                        <div class="admin-stat-icon">
                            <i class="fa-solid fa-users"></i>
                        </div>
                        <h3 class="admin-stat-value">@totalUserCount</h3>
                        <p class="admin-stat-label">Total Users</p>
                        <p class="admin-stat-hint">Registered accounts on platform.</p>
                    </div>
                </div>
            </div>

            <div class="admin-section">
                <div class="admin-content-grid">

                    <div class="admin-panel">
                        <div class="admin-section-head">
                            <div>
                                <h2 class="admin-section-title">
                                    <i class="fa-solid fa-bolt"></i>
                                    Quick Management
                                </h2>
                                <p class="admin-section-subtitle">Jump directly to important admin tasks.</p>
                            </div>
                        </div>

                        <div class="admin-actions-grid">
                            <a asp-controller="Room" asp-action="Pending" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="fa-solid fa-list-check"></i>
                                </div>
                                <h3>Room Approval</h3>
                                <p>Review new room posts and approve clean listings.</p>
                            </a>

                            <a asp-controller="Payment" asp-action="AdminPayments" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="fa-solid fa-receipt"></i>
                                </div>
                                <h3>Payment Review</h3>
                                <p>Verify registration and room posting payments.</p>
                            </a>

                            <a asp-controller="User" asp-action="Index" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="fa-solid fa-user-gear"></i>
                                </div>
                                <h3>User Management</h3>
                                <p>View, edit, and manage registered users.</p>
                            </a>

                            <a asp-controller="Role" asp-action="Index" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="fa-solid fa-user-shield"></i>
                                </div>
                                <h3>Role Management</h3>
                                <p>Control admin and user role records.</p>
                            </a>

                            <a asp-controller="Kyc" asp-action="Pending" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="fa-solid fa-fingerprint"></i>
                                </div>
                                <h3>KYC Verification</h3>
                                <p>Approve or reject submitted identity documents.</p>
                            </a>

                            <a asp-controller="Kyc" asp-action="LoginActivity" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="fa-solid fa-chart-line"></i>
                                </div>
                                <h3>Login Activity</h3>
                                <p>Monitor recent account access and activity.</p>
                            </a>
                        </div>
                    </div>

                    <div class="admin-panel">
                        <div class="admin-section-head">
                            <div>
                                <h2 class="admin-section-title">
                                    <i class="fa-solid fa-bell"></i>
                                    Admin Activity
                                </h2>
                                <p class="admin-section-subtitle">Current workload and system reminders.</p>
                            </div>
                        </div>

                        <div class="admin-activity-list">
                            <div class="admin-activity-item">
                                <div class="admin-activity-icon">
                                    <i class="fa-solid fa-house-circle-exclamation"></i>
                                </div>
                                <div>
                                    <h4>@pendingRoomCount room post(s) waiting</h4>
                                    <p>Check submitted listings before they become visible to users.</p>
                                </div>
                            </div>

                            <div class="admin-activity-item">
                                <div class="admin-activity-icon">
                                    <i class="fa-solid fa-id-card-clip"></i>
                                </div>
                                <div>
                                    <h4>@pendingKycCount KYC request(s) pending</h4>
                                    <p>Review identity documents to keep the platform trusted.</p>
                                </div>
                            </div>

                            <div class="admin-activity-item">
                                <div class="admin-activity-icon">
                                    <i class="fa-solid fa-credit-card"></i>
                                </div>
                                <div>
                                    <h4>@pendingPaymentCount payment(s) need review</h4>
                                    <p>Verify payment records so users can continue smoothly.</p>
                                </div>
                            </div>

                            <div class="admin-activity-item">
                                <div class="admin-activity-icon">
                                    <i class="fa-solid fa-shield-heart"></i>
                                </div>
                                <div>
                                    <h4>System status looks stable</h4>
                                    <p>Use the sidebar to inspect users, roles, messages, and listings.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="admin-section">
                <div class="admin-panel">
                    <div class="admin-section-head">
                        <div>
                            <h2 class="admin-section-title">
                                <i class="fa-solid fa-house-user"></i>
                                Latest Approved Rooms
                            </h2>
                            <p class="admin-section-subtitle">Recently visible rooms currently shown to platform users.</p>
                        </div>

                        @if (Model.TotalCount > 0)
                        {
                            <a asp-controller="Room" asp-action="Index" class="admin-btn admin-btn-soft" style="background: rgba(17, 24, 68, .08); color: var(--ah-navy); border-color: rgba(17, 24, 68, .12);">
                                <i class="fa-solid fa-arrow-up-right-from-square"></i>
                                Browse All
                            </a>
                        }
                    </div>

                    @if (!Model.Items.Any())
                    {
                        <div class="admin-empty">
                            <i class="fa-solid fa-circle-info"></i>
                            <span>No approved rooms are available yet.</span>
                        </div>
                    }
                    else
                    {
                        <div class="admin-table-list">
                            @foreach (var room in Model.Items.Take(5))
                            {
                                string cover = GetCoverImage(room);

                                <div class="admin-room-row">
                                    <div class="admin-room-cover">
                                        @if (!string.IsNullOrEmpty(cover))
                                        {
                                            <img src="@cover" alt="@room.Title" />
                                        }
                                        else
                                        {
                                            <i class="fa-regular fa-image"></i>
                                        }
                                    </div>

                                    <div>
                                        <h3 class="admin-room-title">@room.Title</h3>
                                        <p class="admin-room-meta">
                                            <i class="fa-solid fa-location-dot me-1"></i>
                                            @room.Location
                                            <span class="mx-1">•</span>
                                            @GetRoomAge(room.CreatedAt)
                                        </p>
                                    </div>

                                    <div class="admin-room-price">
                                        BDT @room.Price.ToString("N0")
                                        <small>per month</small>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

        </div>
    </section>
}
else
{
    <section class="public-home-page">
        <div class="public-home-shell">

            <div class="public-hero">
                <h1>Find Your Perfect Bachelor Room</h1>
                <p>
                    Discover verified bachelor rooms, mess seats, sublets, and flatmates in your preferred area.
                </p>

                <form asp-controller="Room" asp-action="Index" method="get" class="public-search">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text"
                           name="searchText"
                           placeholder="Enter city, area, flat name or keywords..." />
                    <button type="submit">
                        <i class="fa-solid fa-arrow-right me-1"></i>
                        Search Space
                    </button>
                </form>
            </div>

            <div class="admin-section">
                <div class="admin-section-head">
                    <div>
                        <h2 class="admin-section-title">
                            <i class="fa-solid fa-house-circle-check"></i>
                            Latest Available Rooms
                        </h2>
                        <p class="admin-section-subtitle">Recently approved rooms available for users.</p>
                    </div>
                </div>

                @if (!Model.Items.Any())
                {
                    <div class="admin-empty">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>No rooms have been posted yet. Check back soon.</span>
                    </div>
                }
                else
                {
                    <div class="public-room-grid">
                        @foreach (var room in Model.Items)
                        {
                            string cover = GetCoverImage(room);

                            <article class="public-room-card">
                                <div class="public-room-img">
                                    @if (!string.IsNullOrEmpty(cover))
                                    {
                                        <img src="@cover" alt="@room.Title" />
                                    }
                                    else
                                    {
                                        <i class="fa-regular fa-image fa-2x"></i>
                                    }
                                </div>

                                <div class="public-room-body">
                                    <h3 class="admin-room-title">@room.Title</h3>
                                    <p class="admin-room-meta">
                                        <i class="fa-solid fa-location-dot me-1"></i>
                                        @room.Location
                                    </p>

                                    <p class="admin-section-subtitle" style="margin:.5rem 0 .8rem;">
                                        @GetShortText(room.Description, 85)
                                    </p>

                                    <div class="d-flex align-items-center justify-content-between gap-2">
                                        <strong style="color:var(--ah-navy);">
                                            BDT @room.Price.ToString("N0")
                                        </strong>

                                        <a asp-controller="Room"
                                           asp-action="Details"
                                           asp-route-id="@room.Id"
                                           class="admin-btn admin-btn-soft"
                                           style="background: rgba(17, 24, 68, .08); color: var(--ah-navy); border: 1px solid rgba(17, 24, 68, .10); min-height: 38px;">
                                            View
                                            <i class="fa-solid fa-chevron-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)">
                                <i class="fa-solid fa-chevron-left"></i>
                            </a>
                        </li>

                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                            </li>
                        }

                        <li class="page-item @(Model.HasNext ? "" : "disabled")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)">
                                <i class="fa-solid fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }

        </div>
    </section>
}
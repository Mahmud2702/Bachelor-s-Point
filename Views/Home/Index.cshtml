@model Bachelor_s_Point.Application.DTOs.PagedResult<Room>
@{
    ViewData["Title"] = "Home";

    string GetCoverImage(Room r)
    {
        if (r.Images == null || !r.Images.Any()) return "";
        var primary = r.Images.FirstOrDefault(i => i.IsPrimary);
        return (primary?.ImagePath ?? r.Images.OrderBy(i => i.DisplayOrder).First().ImagePath) ?? "";
    }
}

<div class="container py-2">
    <!-- Interactive Search Hero Block -->
    <div class="nx-hero fade-up">
        <h1 class="display-4 fw-extrabold text-white mb-2" style="font-weight: 800;">Find Your Perfect Bachelor Room</h1>
        <p class="lead text-white-50 mb-4" style="opacity: 0.85; max-width: 600px; margin: 0 auto 2rem;">
            Discover verified bachelors, mess rooms, sublets, and flatmates in your preferred area in seconds.
        </p>
        
        <div class="mx-auto" style="max-width: 680px; position: relative; z-index: 5;">
            <form asp-controller="Room" asp-action="Index" method="get">
                <div class="p-2 bg-white rounded-pill shadow-lg d-flex align-items-center gap-2" style="border: 1px solid rgba(255,255,255,0.1);">
                    <div class="d-flex align-items-center gap-2 ps-3 flex-grow-1">
                        <i class="bi bi-search text-muted" style="font-size: 1.1rem;"></i>
                        <input type="text" name="searchText" placeholder="Enter city, area, flat name or keywords..." 
                               class="form-control border-0 bg-transparent text-dark p-0" 
                               style="height: 38px; box-shadow: none; font-size: 0.95rem; font-weight: 500;" />
                    </div>
                    <button type="submit" class="btn-nx rounded-pill" style="height: 44px; padding: 0 28px; font-weight: 700; font-size: 0.92rem;">
                        Search Space
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Popular Location Chips -->
    <div class="mb-5 text-center fade-up" style="animation-delay: 0.1s;">
        <span style="font-size: 0.82rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 1.2px;" class="d-block mb-3">
            Popular Locations
        </span>
        <div class="d-flex flex-wrap justify-content-center gap-2">
            <a asp-controller="Room" asp-action="Index" asp-route-searchText="Mirpur" class="btn-nx outline rounded-pill sm px-3">
                📍 Mirpur
            </a>
            <a asp-controller="Room" asp-action="Index" asp-route-searchText="Dhanmondi" class="btn-nx outline rounded-pill sm px-3">
                📍 Dhanmondi
            </a>
            <a asp-controller="Room" asp-action="Index" asp-route-searchText="Uttara" class="btn-nx outline rounded-pill sm px-3">
                📍 Uttara
            </a>
            <a asp-controller="Room" asp-action="Index" asp-route-searchText="Badda" class="btn-nx outline rounded-pill sm px-3">
                📍 Badda
            </a>
            <a asp-controller="Room" asp-action="Index" asp-route-searchText="Dhaka" class="btn-nx outline rounded-pill sm px-3">
                🏢 Dhaka
            </a>
            <a asp-controller="Room" asp-action="Index" asp-route-searchText="Chittagong" class="btn-nx outline rounded-pill sm px-3">
                🏢 Chittagong
            </a>
        </div>
    </div>

    <!-- Platform Statistics Counters Grid -->
    <div class="row g-4 mb-5 fade-up" style="animation-delay: 0.15s;">
        <div class="col-6 col-lg-3">
            <div class="nx-card p-4 text-center h-100" style="border-radius: var(--radius-xl);">
                <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-circle" style="width: 52px; height: 52px; background: rgba(59, 130, 246, 0.1); color: var(--primary);">
                    <i class="bi bi-houses" style="font-size: 1.45rem;"></i>
                </div>
                <h3 style="font-size: 1.85rem; font-weight: 800; margin-bottom: 0.25rem;">1,200+</h3>
                <p style="color: var(--muted); font-size: 0.85rem; font-weight: 600; margin: 0;">Active Spaces</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="nx-card p-4 text-center h-100" style="border-radius: var(--radius-xl);">
                <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-circle" style="width: 52px; height: 52px; background: rgba(16, 185, 129, 0.1); color: var(--success);">
                    <i class="bi bi-people" style="font-size: 1.45rem;"></i>
                </div>
                <h3 style="font-size: 1.85rem; font-weight: 800; margin-bottom: 0.25rem;">4,500+</h3>
                <p style="color: var(--muted); font-size: 0.85rem; font-weight: 600; margin: 0;">Happy Bachelors</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="nx-card p-4 text-center h-100" style="border-radius: var(--radius-xl);">
                <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-circle" style="width: 52px; height: 52px; background: rgba(245, 158, 11, 0.1); color: var(--warning);">
                    <i class="bi bi-handshake" style="font-size: 1.45rem;"></i>
                </div>
                <h3 style="font-size: 1.85rem; font-weight: 800; margin-bottom: 0.25rem;">98%</h3>
                <p style="color: var(--muted); font-size: 0.85rem; font-weight: 600; margin: 0;">Match Accuracy</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="nx-card p-4 text-center h-100" style="border-radius: var(--radius-xl);">
                <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-circle" style="width: 52px; height: 52px; background: rgba(239, 68, 68, 0.1); color: var(--danger);">
                    <i class="bi bi-geo" style="font-size: 1.45rem;"></i>
                </div>
                <h3 style="font-size: 1.85rem; font-weight: 800; margin-bottom: 0.25rem;">15+</h3>
                <p style="color: var(--muted); font-size: 0.85rem; font-weight: 600; margin: 0;">Cities Reached</p>
            </div>
        </div>
    </div>

    <!-- Highlighted App Features Grid -->
    <div class="mb-5 fade-up" style="animation-delay: 0.2s;">
        <div class="text-center mb-4">
            <h3 style="font-weight: 800; font-size: 1.45rem; margin-bottom: 0.4rem;">Why Bachelor's Point?</h3>
            <p style="color: var(--muted); font-size: 0.9rem; max-width: 520px; margin: 0 auto;">Tailored housing and seat-finding matching system for bachelors, students, and professionals.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="nx-card p-4 h-100 d-flex flex-column align-items-start" style="border-radius: var(--radius-xl);">
                    <div class="mb-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; border-radius: var(--radius-md); background: rgba(59, 130, 246, 0.08); color: var(--primary);">
                        <i class="bi bi-chat-square-text-fill" style="font-size: 1.4rem;"></i>
                    </div>
                    <h5 style="font-weight: 700; font-size: 1.05rem; margin-bottom: 0.5rem;">Direct Chatting</h5>
                    <p style="color: var(--muted); font-size: 0.86rem; margin: 0; line-height: 1.5;" class="flex-grow-1">
                        Skip high broker fees. Use our secure, instant built-in messenger to negotiate directly with mess owners or current residents.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="nx-card p-4 h-100 d-flex flex-column align-items-start" style="border-radius: var(--radius-xl);">
                    <div class="mb-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; border-radius: var(--radius-md); background: rgba(16, 185, 129, 0.08); color: var(--success);">
                        <i class="bi bi-shield-fill-check" style="font-size: 1.4rem;"></i>
                    </div>
                    <h5 style="font-weight: 700; font-size: 1.05rem; margin-bottom: 0.5rem;">Verified Listings</h5>
                    <p style="color: var(--muted); font-size: 0.86rem; margin: 0; line-height: 1.5;" class="flex-grow-1">
                        Avoid real estate spam. Every listing goes through a comprehensive visual check and manual admin approval process before going live.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="nx-card p-4 h-100 d-flex flex-column align-items-start" style="border-radius: var(--radius-xl);">
                    <div class="mb-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; border-radius: var(--radius-md); background: rgba(245, 158, 11, 0.08); color: var(--warning);">
                        <i class="bi bi-lightning-charge-fill" style="font-size: 1.4rem;"></i>
                    </div>
                    <h5 style="font-weight: 700; font-size: 1.05rem; margin-bottom: 0.5rem;">Quick Setup</h5>
                    <p style="color: var(--muted); font-size: 0.86rem; margin: 0; line-height: 1.5;" class="flex-grow-1">
                        Got a free seat or flat? Upload photographs, set flat parameters, and list your vacancy in under 2 minutes to start receiving calls!
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Latest Available Rooms Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 style="font-weight: 800; margin: 0; font-size: 1.35rem;">
            <i class="bi bi-houses-fill me-2" style="color: var(--primary);"></i>Latest Available Rooms
        </h3>
        @if (Model.TotalCount > 0)
        {
            <span style="color: var(--muted); font-size: 0.85rem; font-weight: 500;">
                Showing @((Model.Page - 1) * Model.PageSize + 1)
                – @((Model.Page - 1) * Model.PageSize + Model.Items.Count)
                of @Model.TotalCount
            </span>
        }
    </div>

    @if (!Model.Items.Any())
    {
        <div class="nx-alert nx-alert-info">
            <i class="bi bi-info-circle-fill" style="font-size: 1.1rem;"></i>
            <span>No rooms have been posted yet. Check back soon!</span>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var room in Model.Items)
            {
                string cover = GetCoverImage(room);
                <div class="col-md-6 col-lg-4 fade-up">
                    <div class="nx-card h-100 d-flex flex-column">
                        <!-- Card cover container with hover zoom -->
                        <div class="room-card-image" style="height: 210px; background: var(--bg); display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative;">
                            @if (!string.IsNullOrEmpty(cover))
                            {
                                <img src="@cover" alt="@room.Title" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);" />
                            }
                            else
                            {
                                <i class="bi bi-image" style="color: var(--border); font-size: 3rem;"></i>
                            }
                            <!-- Premium badge overlays -->
                            <div style="position: absolute; top: 12px; left: 12px; display: flex; gap: 6px;">
                                <span class="badge-approved" style="background: rgba(16, 185, 129, 0.95); border: none; color: #fff; font-size: 0.72rem; font-weight: 700; padding: 4px 10px;">
                                    Verified
                                </span>
                            </div>
                        </div>
                        
                        <div style="padding: 1.25rem 1.4rem 1.4rem;" class="d-flex flex-column flex-grow-1">
                            <h5 style="font-size: 1.05rem; font-weight: 700; margin-bottom: 0.35rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">@room.Title</h5>
                            <p style="font-size: 0.85rem; color: var(--muted); margin-bottom: 0.75rem;">
                                <i class="bi bi-geo-alt-fill me-1" style="color: var(--primary);"></i> @room.Location
                            </p>
                            <p style="font-size: 0.86rem; color: var(--muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.7em; line-height: 1.5; margin-bottom: 1rem;">
                                @room.Description
                            </p>
                            
                            <div class="d-flex justify-content-between align-items-center mt-auto pt-3" style="border-top: 1px solid var(--border);">
                                <div>
                                    <span style="font-size: 0.75rem; color: var(--muted); display: block; font-weight: 600; text-transform: uppercase;">Rent / Month</span>
                                    <span style="font-size: 1.2rem; font-weight: 850; color: var(--success);">BDT @room.Price</span>
                                </div>
                                <a asp-controller="Room" asp-action="Details" asp-route-id="@room.Id" class="btn-nx outline" style="height: 36px; padding: 0 14px; font-size: 0.8rem; font-weight: 700;">
                                    View Space <i class="bi bi-chevron-right" style="font-size: 0.75rem;"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)">
                            <i class="bi bi-chevron-left"></i> Previous
                        </a>
                    </li>
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.HasNext ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }

    <!-- Visual Testimonials Segment -->
    <div class="mt-5 mb-4 fade-up" style="animation-delay: 0.25s;">
        <div class="text-center mb-4 pt-3">
            <h3 style="font-weight: 800; font-size: 1.45rem; margin-bottom: 0.4rem;">Loved by Bachelors</h3>
            <p style="color: var(--muted); font-size: 0.9rem; max-width: 520px; margin: 0 auto;">Read genuine stories of students and job holders finding flats effortlessly.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="nx-card p-4 h-100" style="border-radius: var(--radius-xl); background: var(--white);">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="nav-avatar-default" style="width: 48px; height: 48px; border-radius: 50%; font-size: 1.25rem; background: var(--primary-light); color: var(--primary);">
                            A
                        </span>
                        <div>
                            <h6 style="margin: 0; font-weight: 700; font-size: 0.95rem;">Asif Rahman</h6>
                            <span style="color: var(--muted); font-size: 0.78rem; font-weight: 500;">Student, DU</span>
                        </div>
                    </div>
                    <p style="color: var(--muted); font-size: 0.86rem; font-style: italic; margin: 0; line-height: 1.5;">
                        "Finding a clean flat in Mirpur was extremely tedious. Through Bachelor's Point, I directly contacted a flatmate manager, inspected the room, and secured my seat in 2 days. Super effective!"
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="nx-card p-4 h-100" style="border-radius: var(--radius-xl); background: var(--white);">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="nav-avatar-default" style="width: 48px; height: 48px; border-radius: 50%; font-size: 1.25rem; background: var(--success-light); color: var(--success);">
                            T
                        </span>
                        <div>
                            <h6 style="margin: 0; font-weight: 700; font-size: 0.95rem;">Tanvir Ahmed</h6>
                            <span style="color: var(--muted); font-size: 0.78rem; font-weight: 500;">Software Engineer</span>
                        </div>
                    </div>
                    <p style="color: var(--muted); font-size: 0.86rem; font-style: italic; margin: 0; line-height: 1.5;">
                        "We had a vacant sub-let room in our flat. I listed it on Bachelor's Point and got direct queries in hours. Direct messaging within the app saved me huge broker fees!"
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

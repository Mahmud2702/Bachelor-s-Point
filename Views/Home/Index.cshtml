            grid-template-columns: 1fr;
        }

        .public-room-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@if (isAdminUser)
{
    <section class="admin-home-page">
        <div class="admin-home-shell">

            <div class="admin-hero">
                <div class="admin-hero-content">
                    <div>
                        <div class="admin-kicker">
                            <i class="bi bi-shield-check"></i>
                            <span>Admin Control Center</span>
                        </div>

                        <h1>Welcome back, Admin</h1>

                        <p>
                            Monitor user verification, roles, listings, and platform activity from one clean dashboard. Room publishing and payments are now fully automatic.
                        </p>

                        <div class="admin-hero-actions">
                            <a asp-controller="Kyc" asp-action="Pending" class="admin-btn admin-btn-primary">
                                <i class="bi bi-person-vcard-fill"></i>
                                Verify Users
                            </a>

                            <a asp-controller="User" asp-action="Index" class="admin-btn admin-btn-soft">
                                <i class="bi bi-people-fill"></i>
                                Manage Users
                            </a>

                            <a asp-controller="Role" asp-action="Index" class="admin-btn admin-btn-soft">
                                <i class="bi bi-person-badge-fill"></i>
                                Manage Roles
                            </a>
                        </div>
                    </div>

                    <div class="admin-status-panel">
                        <div class="admin-status-number">@totalAttentionCount</div>
                        <span>KYC item@(totalAttentionCount == 1 ? "" : "s") need admin attention</span>

                        <div class="admin-status-mini">
                            <div>
                                <strong>@pendingKycCount</strong>
                                <small>KYC</small>
                            </div>
                            <div>
                                <strong>@activeRoomCount</strong>
                                <small>Live Rooms</small>
                            </div>
                            <div>
                                <strong>@totalUserCount</strong>
                                <small>Users</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-section">
                <div class="admin-section-head">
                    <div>
                        <h2 class="admin-section-title">
                            <i class="bi bi-bar-chart-fill"></i>
                            Platform Overview
                        </h2>
                        <p class="admin-section-subtitle">Quick numbers for system health and platform activity.</p>
                    </div>
                </div>

                <div class="admin-stat-grid">
                    <div class="admin-stat-card">
                        <div class="admin-stat-icon">
                            <i class="bi bi-person-vcard"></i>
                        </div>
                        <h3 class="admin-stat-value">@pendingKycCount</h3>
                        <p class="admin-stat-label">KYC Requests</p>
                        <p class="admin-stat-hint">Identity submissions awaiting review.</p>
                    </div>

                    <div class="admin-stat-card">
                        <div class="admin-stat-icon">
                            <i class="bi bi-house-check-fill"></i>
                        </div>
                        <h3 class="admin-stat-value">@activeRoomCount</h3>
                        <p class="admin-stat-label">Active Rooms</p>
                        <p class="admin-stat-hint">Approved and available listings.</p>
                    </div>

                    <div class="admin-stat-card">
                        <div class="admin-stat-icon">
                            <i class="bi bi-houses-fill"></i>
                        </div>
                        <h3 class="admin-stat-value">@totalRoomCount</h3>
                        <p class="admin-stat-label">Total Rooms</p>
                        <p class="admin-stat-hint">All listings ever posted on the platform.</p>
                    </div>

                    <div class="admin-stat-card">
                        <div class="admin-stat-icon">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <h3 class="admin-stat-value">@totalUserCount</h3>
                        <p class="admin-stat-label">Total Users</p>
                        <p class="admin-stat-hint">Registered accounts on platform.</p>
                    </div>
                </div>
            </div>

            <div class="admin-section">
                <div class="admin-content-grid">

                    <div class="admin-panel">
                        <div class="admin-section-head">
                            <div>
                                <h2 class="admin-section-title">
                                    <i class="bi bi-lightning-charge-fill"></i>
                                    Quick Management
                                </h2>
                                <p class="admin-section-subtitle">Jump directly to important admin tasks.</p>
                            </div>
                        </div>

                        <div class="admin-actions-grid">
                            <a asp-controller="Kyc" asp-action="Pending" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="bi bi-fingerprint"></i>
                                </div>
                                <h3>KYC Verification</h3>
                                <p>Approve or reject submitted identity documents.</p>
                            </a>

                            <a asp-controller="User" asp-action="Index" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="bi bi-person-gear"></i>
                                </div>
                                <h3>User Management</h3>
                                <p>View, edit, and manage registered users.</p>
                            </a>

                            <a asp-controller="Role" asp-action="Index" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="bi bi-person-badge-fill"></i>
                                </div>
                                <h3>Role Management</h3>
                                <p>Control admin and user role records.</p>
                            </a>

                            <a asp-controller="Room" asp-action="Index" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="bi bi-houses-fill"></i>
                                </div>
                                <h3>Browse Listings</h3>
                                <p>View all live rooms currently on the platform.</p>
                            </a>

                            <a asp-controller="Kyc" asp-action="LoginActivity" class="admin-action-card">
                                <div class="admin-action-icon">
                                    <i class="bi bi-graph-up-arrow"></i>
                                </div>
                                <h3>Login Activity</h3>
                                <p>Monitor recent account access and activity.</p>
                            </a>
                        </div>
                    </div>

                    <div class="admin-panel">
                        <div class="admin-section-head">
                            <div>
                                <h2 class="admin-section-title">
                                    <i class="bi bi-bell-fill"></i>
                                    Admin Activity
                                </h2>
                                <p class="admin-section-subtitle">Current workload and system reminders.</p>
                            </div>
                        </div>

                        <div class="admin-activity-list">
                            <div class="admin-activity-item">
                                <div class="admin-activity-icon">
                                    <i class="bi bi-person-vcard-fill"></i>
                                </div>
                                <div>
                                    <h4>@pendingKycCount KYC request(s) pending</h4>
                                    <p>Review identity documents to keep the platform trusted.</p>
                                </div>
                            </div>

                            <div class="admin-activity-item">
                                <div class="admin-activity-icon">
                                    <i class="bi bi-lightning-charge-fill"></i>
                                </div>
                                <div>
                                    <h4>Room publishing is automatic</h4>
                                    <p>Rooms go live the moment the owner's posting fee payment is confirmed — no manual review needed.</p>
                                </div>
                            </div>

                            <div class="admin-activity-item">
                                <div class="admin-activity-icon">
                                    <i class="bi bi-shield-fill-check"></i>
                                </div>
                                <div>
                                    <h4>System status looks stable</h4>
                                    <p>Use the sidebar to inspect users, roles, messages, and listings.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="admin-section">
                <div class="admin-panel">
                    <div class="admin-section-head">
                        <div>
                            <h2 class="admin-section-title">
                                <i class="bi bi-house-gear-fill"></i>
                                Latest Approved Rooms
                            </h2>
                            <p class="admin-section-subtitle">Recently visible rooms currently shown to platform users.</p>
                        </div>

                        @if (Model.TotalCount > 0)
                        {
                            <a asp-controller="Room" asp-action="Index" class="admin-btn admin-btn-soft" style="background: rgba(17, 24, 68, .08); color: var(--ah-navy); border-color: rgba(17, 24, 68, .12);">
                                <i class="bi bi-box-arrow-up-right"></i>
                                Browse All
                            </a>
                        }
                    </div>

                    @if (!Model.Items.Any())
                    {
                        <div class="admin-empty">
                            <i class="bi bi-info-circle-fill"></i>
                            <span>No approved rooms are available yet.</span>
                        </div>
                    }
                    else
                    {
                        <div class="admin-table-list">
                            @foreach (var room in Model.Items.Take(5))
                            {
                                string cover = GetCoverImage(room);

                                <div class="admin-room-row">
                                    <div class="admin-room-cover">
                                        @if (!string.IsNullOrEmpty(cover))
                                        {
                                            <img src="@cover" alt="@room.Title" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-image"></i>
                                        }
                                    </div>

                                    <div>
                                        <h3 class="admin-room-title">@room.Title</h3>
                                        <p class="admin-room-meta">
                                            <i class="bi bi-geo-alt-fill me-1"></i>
                                            @room.Location
                                            <span class="mx-1">•</span>
                                            @GetRoomAge(room.CreatedAt)
                                        </p>
                                    </div>

                                    <div class="admin-room-price">
                                        BDT @room.Price.ToString("N0")
                                        <small>per month</small>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

        </div>
    </section>
}
else
{
    <section class="bpz-home-page">
        <div class="bpz-home-shell">

            <section class="bpz-hero" aria-label="Bachelor room search hero">
                <div class="bpz-hero-shade"></div>

                <div class="bpz-hero-content">
                    <h1>Find your fresh start</h1>
                    <p class="bpz-hero-subtitle">
                        Discover verified bachelor rooms, mess seats, sublets, and flatmates for rent.
                    </p>

                    <form asp-controller="Room" asp-action="Index" method="get" class="bpz-search-form">
                        <div class="bpz-search-box">
                            <span class="bpz-search-icon">
                                <i class="bi bi-search"></i>
                            </span>

                            <input type="text"
                                   name="searchText"
                                   value="@Context.Request.Query["searchText"]"
                                   placeholder="Search by location or property name"
                                   aria-label="Search rooms by location or property name" />

                            <button type="submit" class="bpz-search-btn">
                                Search
                                <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </section>

            <section class="bpz-popular" aria-label="Popular bachelor-room areas">
                <div class="bpz-popular-title">
                    <i class="bi bi-geo-alt-fill"></i>
                    <span>Popular areas</span>
                </div>

                <div class="bpz-popular-list">
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Dhaka">Dhaka</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Mirpur">Mirpur</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Dhanmondi">Dhanmondi</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Uttara">Uttara</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Badda">Badda</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Bashundhara">Bashundhara</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Mohammadpur">Mohammadpur</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Banani">Banani</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Gulshan">Gulshan</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Farmgate">Farmgate</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Khilgaon">Khilgaon</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Chittagong">Chittagong</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-searchText="Sylhet">Sylhet</a>
                    <a asp-controller="Room" asp-action="Index" asp-route-showFilters="true" class="bpz-filter-chip">
                        <i class="bi bi-sliders"></i>
                        Filter rooms
                    </a>
                </div>
            </section>

            <section class="bpz-rooms-section">
                <div class="bpz-section-head">
                    <div>
                        <p class="bpz-section-eyebrow">
                            <i class="bi bi-house-check-fill"></i>
                            Latest listings
                        </p>
                        <h2>Latest Available Rooms</h2>
                        <p>Recently approved rooms ready for browsing.</p>
                    </div>

                    <a asp-controller="Room" asp-action="Index" class="bpz-view-all">
                        Browse all
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                @if (!Model.Items.Any())
                {
                    <div class="bpz-empty-state">
                        <div class="bpz-empty-icon">
                            <i class="bi bi-house-slash"></i>
                        </div>
                        <h3>No rooms available yet</h3>
                        <p>Approved listings will appear here when owners post rooms.</p>
                    </div>
                }
                else
                {
                    <div class="bpz-room-grid">
                        @foreach (var room in Model.Items)
                        {
                            string cover = GetCoverImage(room);

                            <article class="bpz-room-card">
                                <a asp-controller="Room"
                                   asp-action="Details"
                                   asp-route-id="@room.Id"
                                   class="bpz-room-image">
                                    @if (!string.IsNullOrEmpty(cover))
                                    {
                                        <img src="@cover" alt="@room.Title" />
                                    }
                                    else
                                    {
                                        <div class="bpz-room-image-empty">
                                            <i class="bi bi-image"></i>
                                        </div>
                                    }

                                    <span class="bpz-room-status">
                                        <i class="bi bi-patch-check-fill"></i>
                                        Verified
                                    </span>
                                </a>

                                <div class="bpz-room-body">
                                    <div class="bpz-room-price-row">
                                        <strong>BDT @room.Price.ToString("N0")</strong>
                                        <span>/ month</span>
                                    </div>

                                    <h3>
                                        <a asp-controller="Room" asp-action="Details" asp-route-id="@room.Id">
                                            @room.Title
                                        </a>
                                    </h3>

                                    <p class="bpz-room-location">
                                        <i class="bi bi-geo-alt-fill"></i>
                                        @room.Location
                                    </p>

                                    <p class="bpz-room-desc">
                                        @GetShortText(room.Description, 86)
                                    </p>

                                    <div class="bpz-room-tags">
                                        @if (room.WifiCost.HasValue)
                                        {
                                            <span><i class="bi bi-wifi"></i> WiFi</span>
                                        }
                                        @if (room.MealCostPerMonth.HasValue)
                                        {
                                            <span><i class="bi bi-egg-fried"></i> Meal</span>
                                        }
                                        @if (room.MaidCostPerMonth.HasValue)
                                        {
                                            <span><i class="bi bi-stars"></i> Maid</span>
                                        }
                                        <span><i class="bi bi-clock-history"></i> @GetRoomAge(room.CreatedAt)</span>
                                    </div>

                                    <a asp-controller="Room"
                                       asp-action="Details"
                                       asp-route-id="@room.Id"
                                       class="bpz-room-action">
                                        View details
                                        <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>

            @if (Model.TotalPages > 1)
            {
                <nav class="bpz-pagination-wrap" aria-label="Room listing pages">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                            </li>
                        }

                        <li class="page-item @(Model.HasNext ? "" : "disabled")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }

        </div>
    </section>
}

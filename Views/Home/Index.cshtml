@using Bachelor_s_Point.Application.Interfaces.Services
@model Bachelor_s_Point.Application.DTOs.PagedResult<Room>
@inject IUserService UserService
@inject IRoomService RoomService
@inject IKycService KycService

@{
    ViewData["Title"] = "Home";

    bool isAdminUser = User.Identity != null
                       && User.Identity.IsAuthenticated
                       && User.IsInRole("Admin");

    string GetCoverImage(Room r)
    {
        if (r.Images == null || !r.Images.Any()) return "";
        var primary = r.Images.FirstOrDefault(i => i.IsPrimary);
        return (primary?.ImagePath ?? r.Images.OrderBy(i => i.DisplayOrder).First().ImagePath) ?? "";
    }

    string GetShortText(string? text, int maxLength = 90)
    {
        if (string.IsNullOrWhiteSpace(text)) return "No description available.";
        return text.Length <= maxLength ? text : text.Substring(0, maxLength) + "...";
    }

    string GetRoomAge(DateTime createdAt)
    {
        var days = (DateTime.Now.Date - createdAt.Date).Days;

        if (days <= 0) return "Today";
        if (days == 1) return "1 day ago";
        if (days < 30) return $"{days} days ago";

        var months = days / 30;
        if (months == 1) return "1 month ago";
        return $"{months} months ago";
    }

    int pendingKycCount = 0;
    int totalUserCount = 0;
    int totalRoomCount = 0;
    int activeRoomCount = Model?.TotalCount ?? 0;
    int totalAttentionCount = 0;

    if (isAdminUser)
    {
        var allUsers = await UserService.GetAllUsersAsync();
        var allRooms = await RoomService.GetAllRoomsAsync();

        pendingKycCount = await KycService.CountPendingAsync();
        totalUserCount = allUsers.Count;
        totalRoomCount = allRooms.Count;
        totalAttentionCount = pendingKycCount;
    }
}


@using Bachelor_s_Point.Models
@model List<Payment>
@{
    ViewData["Title"] = "Pending Payments";
    var regPayments  = Model.Where(p => p.Type == PaymentType.Registration).ToList();
    var roomPayments = Model.Where(p => p.Type == PaymentType.RoomPosting).ToList();
}

<style>
    .pay-table th {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.4px;
        padding: 0.65rem 1rem;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
    }
    .pay-table td {
        padding: 0.85rem 1rem;
        font-size: 0.88rem;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
    }
    .pay-table tr:last-child td { border-bottom: none; }
    .trxid-badge {
        font-family: monospace;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 2px 8px;
        font-size: 0.88rem;
        letter-spacing: 0.5px;
        cursor: pointer;
    }
</style>

<div class="container py-3">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 style="font-weight:800;margin:0;">
            <i class="bi bi-wallet2 me-2" style="color:var(--primary);"></i>
            Pending Payments
        </h2>
        <span style="color:var(--muted);font-size:0.9rem;">
            @Model.Count pending
        </span>
    </div>

    @if (!Model.Any())
    {
        <div class="nx-alert nx-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <span>No pending payments. All caught up!</span>
        </div>
    }
    else
    {
        <!-- ── Registration Payments ── -->
        @if (regPayments.Any())
        {
            <div class="nx-card mb-4">
                <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--border);">
                    <h5 style="margin:0;font-weight:700;">
                        <i class="bi bi-person-plus-fill me-2" style="color:var(--primary);"></i>
                        Registration Fees
                        <span class="nx-badge ms-2">@regPayments.Count</span>
                    </h5>
                </div>
                <div style="overflow-x:auto;">
                    <table class="pay-table w-100">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>User</th>
                                <th>Email</th>
                                <th>Amount</th>
                                <th>TrxID</th>
                                <th>Submitted</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in regPayments)
                            {
                                <tr>
                                    <td style="color:var(--muted);">@p.Id</td>
                                    <td style="font-weight:600;">@(p.User?.UserName ?? "—")</td>
                                    <td style="color:var(--muted);">@(p.User?.Email ?? "—")</td>
                                    <td>
                                        <span style="font-weight:700;color:var(--success);">
                                            BDT @p.Amount.ToString("0")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="trxid-badge" title="Click to copy"
                                              onclick="navigator.clipboard.writeText('@p.TransactionId');this.textContent='Copied!';setTimeout(()=>this.textContent='@p.TransactionId',1500)">
                                            @p.TransactionId
                                        </span>
                                    </td>
                                    <td style="color:var(--muted);font-size:0.8rem;">
                                        @p.SubmittedAt.ToString("dd MMM yyyy")
                                        <br />@p.SubmittedAt.ToString("hh:mm tt")
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <form asp-action="Verify" asp-route-id="@p.Id" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-nx success sm"
                                                        onclick="return confirm('Verify TrxID: @p.TransactionId ?')">
                                                    <i class="bi bi-check-lg"></i> Verify
                                                </button>
                                            </form>
                                            <button type="button" class="btn-nx outline-danger sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#rejectModal"
                                                    data-id="@p.Id"
                                                    data-trx="@p.TransactionId"
                                                    data-user="@(p.User?.UserName)">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- ── Room Posting Payments ── -->
        @if (roomPayments.Any())
        {
            <div class="nx-card mb-4">
                <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--border);">
                    <h5 style="margin:0;font-weight:700;">
                        <i class="bi bi-house-add-fill me-2" style="color:var(--warning);"></i>
                        Room Posting Fees
                        <span class="nx-badge nx-badge-warning ms-2">@roomPayments.Count</span>
                    </h5>
                </div>
                <div style="overflow-x:auto;">
                    <table class="pay-table w-100">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Owner</th>
                                <th>Room</th>
                                <th>Rent</th>
                                <th>Fee (20%)</th>
                                <th>TrxID</th>
                                <th>Submitted</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in roomPayments)
                            {
                                <tr>
                                    <td style="color:var(--muted);">@p.Id</td>
                                    <td style="font-weight:600;">@(p.User?.UserName ?? "—")</td>
                                    <td>
                                        @if (p.Room != null)
                                        {
                                            <a asp-controller="Room" asp-action="Details" asp-route-id="@p.Room.Id"
                                               class="auth-link" style="font-size:0.85rem;">
                                                @p.Room.Title
                                            </a>
                                            <br />
                                            <span style="color:var(--muted);font-size:0.78rem;">
                                                @(p.Room.District ?? p.Room.Location)
                                            </span>
                                        }
                                        else { <span style="color:var(--muted);">Deleted</span> }
                                    </td>
                                    <td style="color:var(--muted);">
                                        @(p.Room != null ? "BDT " + p.Room.Price : "—")
                                    </td>
                                    <td>
                                        <span style="font-weight:700;color:var(--success);">
                                            BDT @p.Amount.ToString("0")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="trxid-badge" title="Click to copy"
                                              onclick="navigator.clipboard.writeText('@p.TransactionId');this.textContent='Copied!';setTimeout(()=>this.textContent='@p.TransactionId',1500)">
                                            @p.TransactionId
                                        </span>
                                    </td>
                                    <td style="color:var(--muted);font-size:0.8rem;">
                                        @p.SubmittedAt.ToString("dd MMM yyyy")
                                        <br />@p.SubmittedAt.ToString("hh:mm tt")
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <form asp-action="Verify" asp-route-id="@p.Id" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-nx success sm"
                                                        onclick="return confirm('Verify and PUBLISH room: @(p.Room?.Title) ?')">
                                                    <i class="bi bi-check-lg"></i> Verify &amp; Publish
                                                </button>
                                            </form>
                                            <button type="button" class="btn-nx outline-danger sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#rejectModal"
                                                    data-id="@p.Id"
                                                    data-trx="@p.TransactionId"
                                                    data-user="@(p.User?.UserName)">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border:1px solid var(--border);border-radius:var(--radius-xl);
                                          background:var(--white);">
            <form id="rejectForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header" style="border-color:var(--border);">
                    <h5 class="modal-title" style="font-weight:700;">Reject Payment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="rejectDesc" style="font-size:0.9rem;color:var(--muted);"></p>
                    <div class="mb-2">
                        <label class="form-label" style="font-size:0.85rem;font-weight:600;">
                            Reason (optional)
                        </label>
                        <textarea name="note" class="form-control" rows="3"
                                  placeholder="e.g. Transaction ID not found, wrong amount…"
                                  style="height:auto;"></textarea>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border);">
                    <button type="button" class="btn-nx outline" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-nx danger">
                        <i class="bi bi-x-circle"></i> Confirm Reject
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const rejectModal = document.getElementById('rejectModal');
        rejectModal.addEventListener('show.bs.modal', function (e) {
            const btn  = e.relatedTarget;
            const id   = btn.dataset.id;
            const trx  = btn.dataset.trx;
            const user = btn.dataset.user;
            document.getElementById('rejectDesc').textContent =
                `Rejecting payment from ${user} — TrxID: ${trx}`;
            document.getElementById('rejectForm').action = `/Payment/Reject/${id}`;
        });
    </script>
}

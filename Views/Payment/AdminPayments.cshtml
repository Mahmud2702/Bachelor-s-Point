            linear-gradient(90deg, rgba(234, 224, 207, .045) 1px, transparent 1px);
    }

    .payment-shell {
        width: min(100%, 1320px);
        margin: 0 auto;
    }

    .payment-hero {
        position: relative;
        overflow: hidden;
        border-radius: 30px;
        padding: clamp(1.35rem, 3vw, 2.25rem);
        color: #ffffff;
        background:

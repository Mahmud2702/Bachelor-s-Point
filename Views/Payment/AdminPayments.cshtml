        box-shadow: var(--pay-shadow);
        border: 1px solid rgba(255, 255, 255, .13);
    }

    .payment-hero::before {
        content: "";
        position: absolute;
        width: 420px;
        height: 420px;
        right: -150px;
        top: -160px;
        border-radius: 50%;
        background: rgba(234, 224, 207, .18);
        pointer-events: none;
    }

    .payment-hero::after {
        content: "";
        position: absolute;
        width: 280px;
        height: 280px;
        left: -110px;
        bottom: -150px;
        border-radius: 50%;
        background: rgba(255, 255, 255, .10);
        pointer-events: none;
    }

    .payment-hero-content {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(320px, .8fr);
        gap: 1.4rem;

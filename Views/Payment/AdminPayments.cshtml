@using Bachelor_s_Point.Models
@model List<Payment>
@{
    ViewData["Title"] = "Pending Payments";

    var regPayments = Model.Where(p => p.Type == PaymentType.Registration).OrderByDescending(p => p.SubmittedAt).ToList();
    var roomPayments = Model.Where(p => p.Type == PaymentType.RoomPosting).OrderByDescending(p => p.SubmittedAt).ToList();

    var totalPending = Model.Count;
    var totalAmount = Model.Sum(p => p.Amount);
    DateTime? latestSubmitted = Model.Any() ? Model.Max(p => p.SubmittedAt) : null;

    string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "?";

        var parts = value.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
            return parts[0].Length >= 2 ? parts[0].Substring(0, 2).ToUpper() : parts[0].ToUpper();

        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }

    string GetUserName(Payment p) => p.User?.UserName ?? p.User?.FullName ?? "Unknown";
    string GetUserEmail(Payment p) => p.User?.Email ?? "No email";

    string FormatDate(DateTime date) => date.ToString("dd MMM yyyy");
    string FormatTime(DateTime date) => date.ToString("hh:mm tt");
}

<style>
    /*
        Admin Pending Payments UI
        Palette:
        #111844 - Deep navy
        #4B5694 - Soft indigo
        #7288AE - Muted blue
        #EAE0CF - Warm beige

        Scope: this page only. No functionality change.
    */

    :root {
        --pay-navy: #111844;
        --pay-indigo: #4B5694;
        --pay-bluegray: #7288AE;
        --pay-beige: #EAE0CF;
        --pay-white: rgba(255, 255, 255, .88);
        --pay-border: rgba(17, 24, 68, .12);
        --pay-soft: rgba(234, 224, 207, .48);
        --pay-shadow: 0 22px 62px rgba(17, 24, 68, .12);
        --pay-shadow-hover: 0 28px 76px rgba(17, 24, 68, .18);
        --pay-success: #10b981;
        --pay-danger: #ef4444;
        --pay-warning: #f59e0b;
    }

    body:has(.payment-admin-page) {
        background:
            radial-gradient(circle at 8% 18%, rgba(75, 86, 148, .12), transparent 30%),
            radial-gradient(circle at 94% 88%, rgba(234, 224, 207, .58), transparent 34%),
            linear-gradient(135deg, #fbfbfd 0%, #f4f0e8 48%, #eef2f8 100%);
    }

    [data-theme="dark"] body:has(.payment-admin-page) {
        background:
            radial-gradient(circle at 8% 18%, rgba(114, 136, 174, .13), transparent 30%),
            radial-gradient(circle at 94% 88%, rgba(75, 86, 148, .24), transparent 34%),
            linear-gradient(135deg, #070b18 0%, #111844 58%, #151b33 100%);
    }

    .payment-admin-page {
        position: relative;
        padding: 1.1rem 1rem 2rem;
        min-height: calc(100dvh - 64px);
    }

    .payment-admin-page::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        background-image:
            linear-gradient(rgba(17, 24, 68, .035) 1px, transparent 1px),
            linear-gradient(90deg, rgba(17, 24, 68, .035) 1px, transparent 1px);
        background-size: 46px 46px;
        mask-image: radial-gradient(circle at center, black, transparent 76%);

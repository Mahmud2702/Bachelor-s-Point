        border-radius: 999px;
        background: rgba(234, 224, 207, .16);
        color: #ffffff;
        font-size: .78rem;
        font-weight: 850;
        border: 1px solid rgba(234, 224, 207, .22);
        margin-bottom: .9rem;
    }

    .payment-hero h1 {
        margin: 0 0 .55rem;
        font-size: clamp(2rem, 4vw, 3.75rem);
        line-height: 1;
        letter-spacing: -1.6px;
        font-weight: 950;
    }

    .payment-hero p {
        max-width: 650px;
        margin: 0;
        color: rgba(255, 255, 255, .76);
        font-size: clamp(.94rem, 1.25vw, 1.05rem);
        line-height: 1.6;
        font-weight: 500;
    }

    .payment-hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        margin-top: 1.25rem;
    }

    .payment-hero-btn {
        min-height: 44px;
        border-radius: 14px;
        padding: .75rem 1rem;

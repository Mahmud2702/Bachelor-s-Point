<div class="modal fade payment-modal" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="rejectForm" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title payment-modal-title">
                        <i class="bi bi-slash-circle"></i>
                        Reject Payment
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <p id="rejectDesc" class="payment-modal-desc mb-3"></p>

                    <div>
                        <label class="form-label" style="font-size:.85rem;font-weight:900;color:var(--pay-navy);">
                            <i class="bi bi-sticky-fill me-1"></i>
                            Reason <span style="color:var(--pay-bluegray);font-weight:700;">(optional)</span>
                        </label>
                        <textarea name="note" class="form-control" rows="3" placeholder="Example: Transaction ID not found, wrong amount, duplicate payment..."></textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="payment-modal-btn cancel" data-bs-dismiss="modal">
                        <i class="bi bi-arrow-left"></i>
                        Cancel
                    </button>
                    <button type="submit" class="payment-modal-btn danger">
                        <i class="bi bi-x-lg"></i>
                        Confirm Reject
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('[data-copy]').forEach(function (button) {
            button.addEventListener('click', function () {
                const value = button.getAttribute('data-copy') || '';
                const text = button.querySelector('.payment-trx-text');
                const oldText = text ? text.textContent : '';

                const showCopied = function () {
                    if (text) {
                        text.textContent = 'Copied!';
                        setTimeout(function () {
                            text.textContent = oldText;
                        }, 1300);
                    }
                };

                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(value).then(showCopied).catch(showCopied);
                } else {
                    showCopied();
                }
            });
        });

        const rejectModal = document.getElementById('rejectModal');
        if (rejectModal) {
            rejectModal.addEventListener('show.bs.modal', function (e) {
                const btn = e.relatedTarget;
                const action = btn.getAttribute('data-action');
                const trx = btn.getAttribute('data-trx') || 'Unknown transaction';
                const user = btn.getAttribute('data-user') || 'Unknown user';

                document.getElementById('rejectDesc').textContent =
                    `You are rejecting payment from ${user}. Transaction ID: ${trx}. Add a note if needed.`;

                document.getElementById('rejectForm').action = action;
            });
        }
    </script>
}

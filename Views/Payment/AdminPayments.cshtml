    }

    [data-theme="dark"] .payment-modal-desc {
        color: #cbd5e1;
    }

    .payment-modal textarea {
        border-radius: 16px;
        border: 1px solid rgba(17, 24, 68, .13);
        background: rgba(255, 255, 255, .76);
        color: var(--pay-navy);
        box-shadow: none;
    }

    .payment-modal textarea:focus {

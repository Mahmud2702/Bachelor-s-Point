@using Bachelor_s_Point.Models
@using Bachelor_s_Point.Infrastructure.Settings
@{
    ViewData["Title"] = "Registration Payment";
    var pay     = ViewBag.PaySettings as PaymentSettings ?? new PaymentSettings();
    var existing = ViewBag.ExistingPayment as Payment;
}

<div class="container py-4" style="max-width: 560px;">
    <div class="nx-card p-4 fade-up">

        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:52px;height:52px;background:var(--primary-light);color:var(--primary);
                        border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">
                <i class="bi bi-credit-card-2-front-fill"></i>
            </div>
            <div>
                <h2 style="font-size:1.25rem;font-weight:800;margin:0;">Registration Fee</h2>
                <p style="color:var(--muted);font-size:0.82rem;margin:0;">One-time fee to activate your account</p>
            </div>
        </div>

        @if (existing?.Status == PaymentStatus.Verified)
        {
            <div class="nx-alert nx-alert-success">
                <i class="bi bi-check-circle-fill"></i>
                <span>Your registration payment has been verified. Your account is active!</span>
            </div>
        }
        else if (existing?.Status == PaymentStatus.Pending)
        {
            <div class="nx-alert nx-alert-warning mb-3">
                <i class="bi bi-hourglass-split"></i>
                <div>
                    <strong>Payment under review</strong><br />
                    <span style="font-size:0.85rem;">
                        TrxID submitted: <code>@existing.TransactionId</code><br />
                        Submitted: @existing.SubmittedAt.ToString("dd MMM yyyy, hh:mm tt")
                    </span>
                </div>
            </div>
            <p style="color:var(--muted);font-size:0.85rem;text-align:center;">
                Admin will verify and activate your account shortly.<br />
                If you entered the wrong TrxID, resubmit below.
            </p>
        }
        else if (existing?.Status == PaymentStatus.Rejected)
        {
            <div class="nx-alert nx-alert-danger mb-3">
                <i class="bi bi-x-circle-fill"></i>
                <div>
                    <strong>Payment rejected</strong><br />
                    @if (!string.IsNullOrEmpty(existing.AdminNote))
                    {
                        <span style="font-size:0.85rem;">Reason: @existing.AdminNote</span>
                    }
                </div>
            </div>
        }

        <!-- Payment instructions -->
        <div style="background:var(--primary-light);border:1px solid rgba(59,130,246,0.15);
                    border-radius:var(--radius-lg);padding:1.2rem 1.4rem;margin-bottom:1.5rem;">
            <p style="font-weight:700;font-size:0.88rem;color:var(--primary);margin:0 0 0.8rem;">
                <i class="bi bi-info-circle me-1"></i> Payment Instructions
            </p>
            <table style="width:100%;font-size:0.88rem;border-collapse:collapse;">
                <tr>
                    <td style="color:var(--muted);padding:3px 0;width:40%;">Amount</td>
                    <td style="font-weight:700;color:var(--success);font-size:1.1rem;">
                        BDT @pay.RegistrationFee.ToString("0")
                    </td>
                </tr>
                <tr>
                    <td style="color:var(--muted);padding:3px 0;">Method</td>
                    <td style="font-weight:600;">@pay.ReceiverMethod</td>
                </tr>
                <tr>
                    <td style="color:var(--muted);padding:3px 0;">Send To</td>
                    <td style="font-weight:700;font-size:1rem;letter-spacing:0.5px;">@pay.ReceiverNumber</td>
                </tr>
                <tr>
                    <td style="color:var(--muted);padding:3px 0;">Name</td>
                    <td style="font-weight:600;">@pay.ReceiverName</td>
                </tr>
            </table>
        </div>

        @if (existing?.Status != PaymentStatus.Verified)
        {
            <!-- Submit form -->
            <form asp-action="RegistrationFee" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label" style="font-weight:700;">
                        <i class="bi bi-receipt me-1" style="color:var(--primary);"></i>
                        Transaction ID (TrxID)
                    </label>
                    <input type="text" name="transactionId"
                           class="form-control"
                           placeholder="e.g. 8N7A2B3C4D"
                           value="@(existing?.TransactionId ?? "")"
                           required maxlength="150" />
                    <div class="form-text" style="font-size:0.8rem;">
                        After sending money, enter the TrxID from your @pay.ReceiverMethod confirmation message.
                    </div>
                </div>
                <button type="submit" class="btn-nx success" style="width:100%;height:46px;">
                    <i class="bi bi-send-fill"></i>
                    @(existing?.Status == PaymentStatus.Rejected ? "Resubmit Transaction ID" : "Submit Transaction ID")
                </button>
            </form>
        }

        <p class="mt-3 text-center" style="font-size:0.8rem;color:var(--muted);">
            <i class="bi bi-shield-check me-1"></i>
            Your account will be activated once admin verifies the payment.
        </p>
    </div>
</div>

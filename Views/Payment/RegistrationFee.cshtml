@using Bachelor_s_Point.Models
@using Bachelor_s_Point.Infrastructure.Settings
@{
    ViewData["Title"] = "Unlock Room Listings";
    var pay      = ViewBag.PaySettings as PaymentSettings ?? new PaymentSettings();
    var existing = ViewBag.ExistingPayment as Payment;
}

<div class="container py-4" style="max-width: 520px;">
    <div class="nx-card p-4 fade-up">

        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:52px;height:52px;background:var(--primary-light);color:var(--primary);
                        border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">
                <i class="bi bi-unlock-fill"></i>
            </div>
            <div>
                <h2 style="font-size:1.2rem;font-weight:800;margin:0;">Unlock All Rooms</h2>
                <p style="color:var(--muted);font-size:0.82rem;margin:0;">One-time BDT @pay.RegistrationFee.ToString("0") platform fee</p>
            </div>
        </div>

        @if (existing?.Status == PaymentStatus.Verified)
        {
            <div class="nx-alert nx-alert-success">
                <i class="bi bi-check-circle-fill"></i>
                <span>Your account is unlocked! You can see all room listings.</span>
            </div>
            <div class="mt-3 text-center">
                <a asp-controller="Room" asp-action="Index" class="btn-nx success">
                    <i class="bi bi-search"></i> Browse Rooms
                </a>
            </div>
        }
        else if (existing?.Status == PaymentStatus.Pending)
        {
            <div class="nx-alert nx-alert-warning mb-3">
                <i class="bi bi-hourglass-split"></i>
                <div>
                    <strong>Payment under review</strong><br />
                    <span style="font-size:0.83rem;">TrxID: <code>@existing.TransactionId</code></span>
                </div>
            </div>
            <p style="text-align:center;color:var(--muted);font-size:0.85rem;">
                Your payment is being verified. Once confirmed, all rooms will be unlocked automatically.
            </p>
        }
        else
        {
            @if (existing?.Status == PaymentStatus.Rejected)
            {
                <div class="nx-alert nx-alert-danger mb-3">
                    <i class="bi bi-x-circle-fill"></i>
                    <div>
                        <strong>Payment rejected</strong><br />
                        @if (!string.IsNullOrEmpty(existing.AdminNote))
                        { <span style="font-size:0.83rem;">@existing.AdminNote</span> }
                    </div>
                </div>
            }

            <!-- What you get -->
            <div style="background:var(--primary-light);border-radius:var(--radius-lg);padding:1rem 1.2rem;margin-bottom:1.5rem;">
                <p style="font-weight:700;font-size:0.85rem;color:var(--primary);margin:0 0 0.6rem;">
                    <i class="bi bi-star-fill me-1"></i> After payment you can:
                </p>
                <ul style="margin:0;padding-left:1.2rem;font-size:0.85rem;color:var(--text);">
                    <li>See full details of all room listings</li>
                    <li>View price, description, and owner contact</li>
                    <li>Select and book a room</li>
                </ul>
            </div>

            <!-- SSLCommerz Pay button -->
            <form asp-action="PayRegistrationFee" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-auth success" style="height:56px;font-size:1rem;">
                    <i class="bi bi-credit-card-2-front-fill"></i>
                    Pay BDT @pay.RegistrationFee.ToString("0") — Unlock Now
                </button>
            </form>

            <!-- Accepted methods -->
            <div class="mt-3 text-center" style="font-size:0.78rem;color:var(--muted);">
                <i class="bi bi-shield-check me-1" style="color:var(--success);"></i>
                Secured by SSLCommerz &nbsp;·&nbsp;
                bKash &nbsp;·&nbsp; Nagad &nbsp;·&nbsp; Rocket &nbsp;·&nbsp; Card &nbsp;·&nbsp; Internet Banking
            </div>
        }
    </div>
</div>

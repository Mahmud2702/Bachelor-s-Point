@using Bachelor_s_Point.Models
@using Bachelor_s_Point.Infrastructure.Settings
@{
    ViewData["Title"] = "Room Posting Fee";
    var room     = ViewBag.Room as Room;
    var pay      = ViewBag.PaySettings as PaymentSettings ?? new PaymentSettings();
    var existing = ViewBag.ExistingPayment as Payment;
    decimal fee  = (decimal)(ViewBag.FeeAmount ?? 0m);
    int pct      = (int)(ViewBag.FeePercent ?? 20);
}

<div class="container py-4" style="max-width: 520px;">
    <div class="nx-card p-4 fade-up">

        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:52px;height:52px;background:var(--warning-light);color:var(--warning);
                        border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">
                <i class="bi bi-house-check-fill"></i>
            </div>
            <div>
                <h2 style="font-size:1.2rem;font-weight:800;margin:0;">Room Posting Fee</h2>
                <p style="color:var(--muted);font-size:0.82rem;margin:0;">Pay to publish your listing</p>
            </div>
        </div>

        @if (room != null)
        {
            <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-lg);
                        padding:0.9rem 1.1rem;margin-bottom:1.25rem;">
                <p style="font-weight:700;font-size:0.88rem;margin:0 0 0.3rem;">
                    <i class="bi bi-house-fill me-1" style="color:var(--primary);"></i>@room.Title
                </p>
                <div style="font-size:0.83rem;color:var(--muted);">
                    <i class="bi bi-geo-alt me-1"></i>@(room.District ?? room.Location)
                    &nbsp;·&nbsp;
                    <i class="bi bi-cash me-1"></i>BDT @room.Price / month
                </div>
            </div>
        }

        <!-- Fee breakdown -->
        <div style="background:var(--primary-light);border-radius:var(--radius-lg);padding:1rem 1.2rem;margin-bottom:1.5rem;">
            <table style="width:100%;font-size:0.86rem;border-collapse:collapse;">
                <tr>
                    <td style="color:var(--muted);padding:3px 0;width:55%;">Room Rent</td>
                    <td>BDT @(room?.Price.ToString() ?? "—")</td>
                </tr>
                <tr>
                    <td style="color:var(--muted);padding:3px 0;">Posting Fee (@pct%)</td>
                    <td style="font-weight:800;color:var(--success);font-size:1.1rem;">BDT @fee.ToString("0")</td>
                </tr>
            </table>
        </div>

        @if (existing?.Status == PaymentStatus.Verified)
        {
            <div class="nx-alert nx-alert-success">
                <i class="bi bi-check-circle-fill"></i>
                <span>Payment verified. Your room has been published!</span>
            </div>
            <div class="mt-3 text-center">
                <a asp-controller="Room" asp-action="MyListings" class="btn-nx success">
                    <i class="bi bi-house-fill"></i> My Listings
                </a>
            </div>
        }
        else if (existing?.Status == PaymentStatus.Pending)
        {
            <div class="nx-alert nx-alert-warning">
                <i class="bi bi-hourglass-split"></i>
                <div>
                    <strong>Payment under review</strong><br />
                    <span style="font-size:0.83rem;">TrxID: <code>@existing.TransactionId</code></span>
                </div>
            </div>
            <p class="mt-2 text-center" style="font-size:0.83rem;color:var(--muted);">
                Your room will be published once payment is confirmed.
            </p>
        }
        else
        {
            @if (existing?.Status == PaymentStatus.Rejected)
            {
                <div class="nx-alert nx-alert-danger mb-3">
                    <i class="bi bi-x-circle-fill"></i>
                    <strong>Payment rejected.</strong>
                    @if (!string.IsNullOrEmpty(existing.AdminNote))
                    { <span style="font-size:0.83rem;"> @existing.AdminNote</span> }
                </div>
            }

            <!-- SSLCommerz Pay button -->
            <form asp-action="PayRoomFee" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="roomId" value="@room?.Id" />
                <button type="submit" class="btn-auth success" style="height:56px;font-size:1rem;">
                    <i class="bi bi-credit-card-2-front-fill"></i>
                    Pay BDT @fee.ToString("0") — Publish Room
                </button>
            </form>

            <div class="mt-3 text-center" style="font-size:0.78rem;color:var(--muted);">
                <i class="bi bi-shield-check me-1" style="color:var(--success);"></i>
                Secured by SSLCommerz &nbsp;·&nbsp;
                bKash &nbsp;·&nbsp; Nagad &nbsp;·&nbsp; Rocket &nbsp;·&nbsp; Card
            </div>
        }
    </div>
</div>

@using Bachelor_s_Point.Models
@using Bachelor_s_Point.Infrastructure.Settings
@{
    ViewData["Title"] = "Room Posting Fee";
    var room     = ViewBag.Room as Room;
    var pay      = ViewBag.PaySettings as PaymentSettings ?? new PaymentSettings();
    var existing = ViewBag.ExistingPayment as Payment;
    decimal fee  = (decimal)(ViewBag.FeeAmount ?? 0m);
    int pct      = (int)(ViewBag.FeePercent ?? 20);
}

<div class="container py-4" style="max-width: 580px;">
    <div class="nx-card p-4 fade-up">

        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:52px;height:52px;background:var(--warning-light);color:var(--warning);
                        border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">
                <i class="bi bi-house-check-fill"></i>
            </div>
            <div>
                <h2 style="font-size:1.25rem;font-weight:800;margin:0;">Room Posting Fee</h2>
                <p style="color:var(--muted);font-size:0.82rem;margin:0;">
                    Pay to publish your room listing
                </p>
            </div>
        </div>

        @if (room != null)
        {
            <!-- Room summary -->
            <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-lg);
                        padding:1rem 1.2rem;margin-bottom:1.25rem;">
                <p style="font-weight:700;font-size:0.88rem;margin:0 0 0.5rem;">
                    <i class="bi bi-house-fill me-1" style="color:var(--primary);"></i>@room.Title
                </p>
                <div class="d-flex gap-3 flex-wrap" style="font-size:0.85rem;color:var(--muted);">
                    <span><i class="bi bi-geo-alt"></i> @(room.District ?? room.Location)</span>
                    <span><i class="bi bi-cash"></i> BDT @room.Price / month</span>
                </div>
            </div>
        }

        <!-- Fee calculation -->
        <div style="background:var(--primary-light);border:1px solid rgba(59,130,246,0.15);
                    border-radius:var(--radius-lg);padding:1.2rem 1.4rem;margin-bottom:1.5rem;">
            <p style="font-weight:700;font-size:0.88rem;color:var(--primary);margin:0 0 0.8rem;">
                <i class="bi bi-calculator me-1"></i> Fee Breakdown
            </p>
            <table style="width:100%;font-size:0.88rem;border-collapse:collapse;">
                <tr>
                    <td style="color:var(--muted);padding:3px 0;width:50%;">Room Rent</td>
                    <td style="font-weight:600;">BDT @(room?.Price.ToString() ?? "—")</td>
                </tr>
                <tr>
                    <td style="color:var(--muted);padding:3px 0;">Posting Fee (@pct%)</td>
                    <td style="font-weight:800;color:var(--success);font-size:1.1rem;">BDT @fee.ToString("0")</td>
                </tr>
                <tr style="border-top:1px solid var(--border);">
                    <td style="color:var(--muted);padding:5px 0 3px;">Method</td>
                    <td style="font-weight:600;">@pay.ReceiverMethod</td>
                </tr>
                <tr>
                    <td style="color:var(--muted);padding:3px 0;">Send To</td>
                    <td style="font-weight:700;font-size:1rem;letter-spacing:0.5px;">@pay.ReceiverNumber</td>
                </tr>
                <tr>
                    <td style="color:var(--muted);padding:3px 0;">Name</td>
                    <td style="font-weight:600;">@pay.ReceiverName</td>
                </tr>
            </table>
        </div>

        @if (existing?.Status == PaymentStatus.Verified)
        {
            <div class="nx-alert nx-alert-success">
                <i class="bi bi-check-circle-fill"></i>
                <span>Payment verified. Your room has been published!</span>
            </div>
            <div class="mt-3 text-center">
                <a asp-controller="Room" asp-action="Index" class="btn-nx success">
                    <i class="bi bi-search"></i> Browse Rooms
                </a>
            </div>
        }
        else
        {
            @if (existing?.Status == PaymentStatus.Pending)
            {
                <div class="nx-alert nx-alert-warning mb-3">
                    <i class="bi bi-hourglass-split"></i>
                    <div>
                        <strong>Payment under review</strong><br />
                        <span style="font-size:0.85rem;">
                            TrxID: <code>@existing.TransactionId</code> &nbsp;·&nbsp;
                            @existing.SubmittedAt.ToString("dd MMM yyyy, hh:mm tt")
                        </span>
                    </div>
                </div>
            }
            else if (existing?.Status == PaymentStatus.Rejected)
            {
                <div class="nx-alert nx-alert-danger mb-3">
                    <i class="bi bi-x-circle-fill"></i>
                    <div>
                        <strong>Payment rejected</strong><br />
                        @if (!string.IsNullOrEmpty(existing.AdminNote))
                        {
                            <span style="font-size:0.85rem;">Reason: @existing.AdminNote</span>
                        }
                    </div>
                </div>
            }

            <form asp-action="RoomFee" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="roomId" value="@room?.Id" />
                <div class="mb-3">
                    <label class="form-label" style="font-weight:700;">
                        <i class="bi bi-receipt me-1" style="color:var(--primary);"></i>
                        Transaction ID (TrxID)
                    </label>
                    <input type="text" name="transactionId"
                           class="form-control"
                           placeholder="e.g. 8N7A2B3C4D"
                           value="@(existing?.TransactionId ?? "")"
                           required maxlength="150" />
                    <div class="form-text" style="font-size:0.8rem;">
                        Send <strong>BDT @fee.ToString("0")</strong> via @pay.ReceiverMethod to <strong>@pay.ReceiverNumber</strong>,
                        then paste the TrxID here.
                    </div>
                </div>
                <button type="submit" class="btn-nx success" style="width:100%;height:46px;">
                    <i class="bi bi-send-fill"></i>
                    @(existing?.Status == PaymentStatus.Rejected ? "Resubmit Transaction ID" : "Submit Transaction ID")
                </button>
            </form>

            <p class="mt-3 text-center" style="font-size:0.8rem;color:var(--muted);">
                <i class="bi bi-shield-check me-1"></i>
                Your room will be published once admin verifies the payment.
            </p>
        }

    </div>
</div>

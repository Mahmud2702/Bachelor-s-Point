@model LoginDto
@{
    string loginType = (ViewBag.LoginType as string) ?? "";
    string title = loginType == "admin" ? "Admin Sign In"
                 : loginType == "user"  ? "Welcome back"
                 : "Sign in";
    string subtitle = loginType == "admin"
        ? "Sign in to the admin dashboard."
        : "Sign in to your Bachelor's Point account.";
    ViewData["Title"] = title;
}

<div class="auth-card">
    <div class="d-flex align-items-center gap-2 mb-4">
        <div class="nx-brand-icon"><i class="bi bi-house-heart-fill"></i></div>
        <span class="nx-brand-name">Bachelor's Point</span>
    </div>

    <h2 style="font-size: 1.45rem; font-weight: 800; margin-bottom: 0.35rem;">@title</h2>
    <p style="color: var(--clr-muted); font-size: 0.9rem; margin-bottom: 1.75rem;">@subtitle</p>

    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    <form asp-action="Login" asp-route-as="@(string.IsNullOrEmpty(loginType) ? null : loginType)" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email address</label>
            <div style="position: relative;">
                <i class="bi bi-envelope" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--clr-muted);"></i>
                <input asp-for="Email" class="form-control" style="padding-left: 38px;" placeholder="you@example.com" autocomplete="email" autofocus />
            </div>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-2">
            <label asp-for="Password" class="form-label">Password</label>
            <div style="position: relative;">
                <i class="bi bi-lock" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--clr-muted);"></i>
                <input asp-for="Password" type="password" class="form-control" style="padding-left: 38px; padding-right: 38px;" placeholder="Your password" id="loginPass" autocomplete="current-password" />
                <i class="bi bi-eye" id="togglePassIcon" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: var(--clr-muted); cursor: pointer;" onclick="togglePass()"></i>
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="text-end mb-3">
            <a asp-action="ForgotPassword" style="font-size: 0.85rem; color: var(--clr-primary); font-weight: 600; text-decoration: none;">
                Forgot password?
            </a>
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-3" style="height: 46px;">
            <i class="bi bi-arrow-right-circle me-1"></i> Sign In
        </button>

        <a asp-action="RoleSelect" class="btn btn-outline-secondary w-100">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </form>

    @if (loginType != "admin")
    {
        <div class="text-center mt-4 pt-3" style="border-top: 1px solid var(--clr-border);">
            <span style="color: var(--clr-muted); font-size: 0.88rem;">Don't have an account?</span>
            <a asp-action="Register" asp-route-as="@(string.IsNullOrEmpty(loginType) ? "user" : loginType)" style="color: var(--clr-primary); font-weight: 600; text-decoration: none; font-size: 0.88rem;">
                Create one free
            </a>
        </div>
    }
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function togglePass() {
            const inp = document.getElementById('loginPass');
            const icon = document.getElementById('togglePassIcon');
            if (inp.type === 'password') {
                inp.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                inp.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
}

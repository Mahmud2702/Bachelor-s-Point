@model RegisterDto
@{
    string regType = (ViewBag.RegisterType as string) ?? "user";
    string title = regType == "admin" ? "Create Admin Account" : "Create your account";
    ViewData["Title"] = title;
}

<div class="auth-card fade-up" style="max-width: 620px;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <div class="nx-brand-icon"><i class="bi bi-house-heart-fill"></i></div>
        <span class="nx-brand-name">Bachelor's Point</span>
    </div>

    <h2 style="font-size: 1.55rem; font-weight: 800; margin-bottom: 0.35rem;">@title</h2>
    <p style="color: var(--muted); font-size: 0.92rem; margin-bottom: 1.75rem;">
        Get started — it's free and only takes a minute.
    </p>

    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    <form asp-action="Register" asp-route-as="@regType" method="post" autocomplete="off">
        @Html.AntiForgeryToken()

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FullName" class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="UserName" class="form-label">User Name</label>
                <input asp-for="UserName" class="form-control" placeholder="e.g. sajid007" />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
                <input asp-for="DateOfBirth" type="date" class="form-control" />
                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label">Phone <span style="color: var(--muted); font-weight: 400;">(optional)</span></label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="01XXXXXXXXX" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Email" class="form-label">Email address</label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
                <small style="color: var(--muted); font-size: 0.78rem;">We'll send a 6-digit verification code here.</small>
            </div>

            <div class="col-12">
                <label asp-for="Address" class="form-label">Address</label>
                <textarea asp-for="Address" class="form-control" rows="2" placeholder="Your address"></textarea>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="At least 8 characters" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
        </div>

        <button type="submit" class="btn-auth mt-4">
            <i class="bi bi-shield-check"></i> Send Verification Code
        </button>
    </form>

    <div class="text-center mt-4 pt-3" style="border-top: 1px solid var(--border); font-size: 0.9rem; color: var(--muted);">
        Already have an account?
        <a asp-action="Login" asp-route-as="@regType" class="auth-link">Sign in</a>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

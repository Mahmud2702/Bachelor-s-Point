@model RegisterDto
@{
    string regType = (ViewBag.RegisterType as string) ?? "user";
    bool isAdminRegister = regType == "admin";
    string title = isAdminRegister ? "Create Admin Account" : "Create your account";
    string subtitle = isAdminRegister
        ? "Create an admin profile and verify it with email OTP."
        : "Create your profile and verify it with email OTP.";

    ViewData["Title"] = title;
}

<style>
    /*
            Register Page UI/UX
            Palette:
            #111844 - Deep navy
            #4B5694 - Soft indigo
            #7288AE - Muted blue
            #EAE0CF - Warm beige

            Goal:
            - Desktop/laptop: fit all registration fields in one clean screen.
            - Mobile/tablet: responsive and scrollable, because forcing everything into one mobile screen would be poor UX.
            - No functionality change.
        */

    :root {
        --reg-navy: #111844;
        --reg-indigo: #4B5694;
        --reg-bluegray: #7288AE;
        --reg-beige: #EAE0CF;
        --reg-white: #ffffff;
        --reg-border: rgba(17, 24, 68, .14);
        --reg-shadow: 0 24px 70px rgba(17, 24, 68, .15);
    }

    body:has(.register-page-screen) {
        height: 100dvh;
        min-height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: radial-gradient(circle at 8% 18%, rgba(75, 86, 148, .18), transparent 30%), radial-gradient(circle at 92% 82%, rgba(234, 224, 207, .72), transparent 34%), linear-gradient(135deg, #fbfbfd 0%, #f4f0e8 48%, #eef2f8 100%);
    }

    [data-theme="dark"] body:has(.register-page-screen) {
        background: radial-gradient(circle at 8% 18%, rgba(114, 136, 174, .16), transparent 30%), radial-gradient(circle at 90% 82%, rgba(75, 86, 148, .26), transparent 34%), linear-gradient(135deg, #070b18 0%, #111844 58%, #151b33 100%);
    }

    body:has(.register-page-screen) main[role="main"] {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

        body:has(.register-page-screen) main[role="main"] > .container.mt-3 {
            margin-top: 0 !important;
            padding-top: 0 !important;
        }

    body:has(.register-page-screen) footer.nx-footer {
        display: none !important;
    }

    body:has(.register-page-screen) .bp-brand-icon,
    body:has(.register-page-screen) .bp-brand:hover .bp-brand-icon {
        width: 42px !important;
        height: 42px !important;
        min-width: 42px !important;
        border-radius: 14px !important;
        background: linear-gradient(135deg, #111844 0%, #4B5694 60%, #7288AE 100%) !important;
        color: #ffffff !important;
        transform: none !important;
        rotate: 0deg !important;
        animation: none !important;
        box-shadow: 0 12px 26px rgba(17, 24, 68, .24), 0 0 0 4px rgba(234, 224, 207, .55) !important;
        transition: box-shadow .22s ease, filter .22s ease !important;
    }

        body:has(.register-page-screen) .bp-brand-icon i {
            color: #ffffff !important;
            font-size: 1.25rem !important;
        }

    body:has(.register-page-screen) .bp-brand:hover .bp-brand-icon {
        filter: brightness(1.08);
        box-shadow: 0 14px 30px rgba(17, 24, 68, .30), 0 0 0 5px rgba(234, 224, 207, .78), 0 0 24px rgba(75, 86, 148, .42) !important;
    }

    body:has(.register-page-screen) .bp-brand-name {
        background: linear-gradient(135deg, #111844 0%, #4B5694 70%) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
        font-weight: 900 !important;
    }

    [data-theme="dark"] body:has(.register-page-screen) .bp-brand-name {
        background: linear-gradient(135deg, #EAE0CF 0%, #7288AE 100%) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
    }

    .register-page-screen {
        position: relative;
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: .9rem 1rem 3.8rem;
        overflow: hidden;
    }

        .register-page-screen::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(17, 24, 68, .035) 1px, transparent 1px), linear-gradient(90deg, rgba(17, 24, 68, .035) 1px, transparent 1px);
            background-size: 46px 46px;
            mask-image: radial-gradient(circle at center, black, transparent 76%);
            pointer-events: none;
        }

    [data-theme="dark"] .register-page-screen::before {
        background-image: linear-gradient(rgba(234, 224, 207, .045) 1px, transparent 1px), linear-gradient(90deg, rgba(234, 224, 207, .045) 1px, transparent 1px);
    }

    .register-shell {
        position: relative;
        z-index: 1;
        width: min(100%, 1040px);
        display: grid;
        grid-template-columns: 315px minmax(0, 1fr);
        border-radius: 30px;
        overflow: hidden;
        border: 1px solid var(--reg-border);
        box-shadow: var(--reg-shadow);
        background: linear-gradient(180deg, rgba(255, 255, 255, .96), rgba(255, 255, 255, .86));
    }

    [data-theme="dark"] .register-shell {
        background: linear-gradient(180deg, rgba(21, 27, 51, .96), rgba(17, 24, 68, .90));
        border-color: rgba(234, 224, 207, .12);
        box-shadow: 0 24px 70px rgba(0, 0, 0, .34);
    }

    .register-side {
        position: relative;
        padding: 1.6rem;
        background: radial-gradient(circle at 20% 15%, rgba(234, 224, 207, .45), transparent 34%), linear-gradient(145deg, var(--reg-navy), var(--reg-indigo) 65%, var(--reg-bluegray));
        color: #ffffff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 475px;
    }

        .register-side::after {
            content: "";
            position: absolute;
            width: 210px;
            height: 210px;
            right: -90px;
            bottom: -90px;
            border-radius: 50%;
            background: rgba(234, 224, 207, .18);
            pointer-events: none;
        }

    .register-side-top,
    .register-side-bottom {
        position: relative;
        z-index: 1;
    }

    .register-brand-mini {
        display: inline-flex;
        align-items: center;
        gap: .7rem;
        margin-bottom: 1.1rem;
        color: #ffffff;
        font-weight: 900;
        letter-spacing: -.25px;
    }

    .register-brand-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, .14);
        box-shadow: 0 0 0 5px rgba(234, 224, 207, .12);
    }

    .register-side-title {
        margin: 0 0 .55rem;
        font-size: 1.65rem;
        line-height: 1.08;
        font-weight: 950;
        letter-spacing: -.9px;
    }

    .register-side-text {
        margin: 0;
        color: rgba(255, 255, 255, .78);
        font-size: .9rem;
        line-height: 1.55;
        font-weight: 500;
    }

    .register-benefits {
        display: grid;
        gap: .65rem;
        margin: 1.1rem 0 0;
        padding: 0;
        list-style: none;
    }

        .register-benefits li {
            display: flex;
            align-items: center;
            gap: .65rem;
            color: rgba(255, 255, 255, .88);
            font-size: .84rem;
            font-weight: 650;
        }

        .register-benefits i {
            width: 26px;
            height: 26px;
            border-radius: 9px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(234, 224, 207, .16);
            color: var(--reg-beige);
            flex-shrink: 0;
        }

    .register-note {
        border-radius: 18px;
        padding: .85rem;
        background: rgba(255, 255, 255, .12);
        border: 1px solid rgba(255, 255, 255, .14);
        color: rgba(255, 255, 255, .82);
        font-size: .82rem;
        line-height: 1.45;
        backdrop-filter: blur(12px);
    }

        .register-note strong {
            color: #ffffff;
        }

    .register-form-panel {
        position: relative;
        padding: 1.45rem 1.55rem;
        background: radial-gradient(circle at 90% 12%, rgba(234, 224, 207, .40), transparent 28%), radial-gradient(circle at 10% 96%, rgba(114, 136, 174, .16), transparent 30%), rgba(255, 255, 255, .72);
    }

    [data-theme="dark"] .register-form-panel {
        background: radial-gradient(circle at 90% 12%, rgba(234, 224, 207, .07), transparent 28%), radial-gradient(circle at 10% 96%, rgba(114, 136, 174, .13), transparent 30%), rgba(17, 24, 68, .48);
    }

    .register-mobile-heading {
        display: none;
        margin-bottom: 1rem;
    }

    .register-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .7rem .85rem;
    }

    .register-field.full {
        grid-column: 1 / -1;
    }

    .register-label {
        display: flex;
        align-items: center;
        gap: .45rem;
        margin-bottom: .28rem;
        color: var(--reg-navy);
        font-size: .78rem;
        font-weight: 900;
    }

    [data-theme="dark"] .register-label {
        color: #f8fafc;
    }

    .register-label i {
        color: var(--reg-indigo);
        font-size: .78rem;
    }

    [data-theme="dark"] .register-label i {
        color: var(--reg-beige);
    }

    .register-label .optional {
        color: var(--reg-bluegray);
        font-weight: 650;
    }

    .register-control {
        width: 100%;
        height: 41px;
        padding: .56rem .8rem;
        border-radius: 14px;
        border: 1px solid rgba(17, 24, 68, .13);
        background: rgba(255, 255, 255, .78);
        color: var(--reg-navy);
        font-size: .88rem;
        font-weight: 550;
        box-shadow: none;
        transition: border-color .18s ease, box-shadow .18s ease, background .18s ease;
    }

        .register-control:focus {
            border-color: var(--reg-bluegray);
            background: rgba(255, 255, 255, .96);
            box-shadow: 0 0 0 4px rgba(114, 136, 174, .18), 0 10px 24px rgba(17, 24, 68, .08);
            outline: none;
        }

        .register-control::placeholder {
            color: rgba(75, 86, 148, .48);
        }

    textarea.register-control {
        resize: none;
        height: 41px;
        min-height: 41px;
        overflow: hidden;
    }

    [data-theme="dark"] .register-control {
        background: rgba(234, 224, 207, .08);
        color: #f8fafc;
        border-color: rgba(234, 224, 207, .14);
    }

        [data-theme="dark"] .register-control:focus {
            background: rgba(17, 24, 68, .88);
            border-color: var(--reg-beige);
            box-shadow: 0 0 0 4px rgba(234, 224, 207, .12), 0 10px 24px rgba(0, 0, 0, .22);
        }

    .field-hint {
        display: block;
        margin-top: .22rem;
        color: var(--reg-bluegray);
        font-size: .72rem;
        font-weight: 600;
        line-height: 1.25;
    }

    .register-validation {
        display: block;
        min-height: 13px;
        margin-top: .16rem;
        font-size: .69rem;
        line-height: 1.1;
    }

    .register-actions {
        margin-top: .25rem;
        grid-column: 1 / -1;
    }

    .register-submit {
        width: 100%;
        min-height: 44px;
        border: none;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .65rem;
        color: #ffffff;
        background: linear-gradient(135deg, var(--reg-navy), var(--reg-indigo));
        font-size: .95rem;
        font-weight: 950;
        box-shadow: 0 13px 28px rgba(17, 24, 68, .22);
        transition: box-shadow .22s ease, filter .22s ease;
    }

        .register-submit:hover {
            filter: brightness(1.07);
            box-shadow: 0 16px 34px rgba(17, 24, 68, .28), 0 0 0 5px rgba(234, 224, 207, .88), 0 0 0 9px rgba(114, 136, 174, .28), 0 0 24px rgba(75, 86, 148, .42);
        }

        .register-submit i {
            transition: transform .2s ease;
        }

        .register-submit:hover i {
            transform: translateX(3px);
        }

    .register-bottom {
        grid-column: 1 / -1;
        margin-top: .25rem;
        padding-top: .65rem;
        border-top: 1px solid rgba(17, 24, 68, .10);
        text-align: center;
        color: var(--reg-indigo);
        font-size: .84rem;
        font-weight: 600;
    }

    [data-theme="dark"] .register-bottom {
        color: #cbd5e1;
        border-top-color: rgba(234, 224, 207, .12);
    }

    .register-bottom a {
        color: var(--reg-navy);
        font-weight: 950;
        text-decoration: none;
    }

        .register-bottom a:hover {
            text-decoration: underline;
        }

    [data-theme="dark"] .register-bottom a {
        color: var(--reg-beige);
    }

    .register-page-footer {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 2;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--reg-indigo);
        font-size: .8rem;
        font-weight: 550;
        background: rgba(255, 255, 255, .70);
        border-top: 1px solid rgba(17, 24, 68, .08);
        backdrop-filter: blur(14px);
    }

        .register-page-footer strong {
            color: var(--reg-navy);
            font-weight: 850;
        }

        .register-page-footer a {
            color: #2563eb;
            font-weight: 800;
            text-decoration: none;
        }

            .register-page-footer a:hover {
                text-decoration: underline;
            }

    [data-theme="dark"] .register-page-footer {
        color: #cbd5e1;
        background: rgba(7, 11, 24, .72);
        border-top-color: rgba(234, 224, 207, .10);
    }

        [data-theme="dark"] .register-page-footer strong {
            color: var(--reg-beige);
        }

        [data-theme="dark"] .register-page-footer a {
            color: var(--reg-beige);
        }

    @@media (max-width: 991.98px) {
        body:has(.register-page-screen) {
            height: auto;
            min-height: 100dvh;
            overflow: auto;
            display: block;
        }

            body:has(.register-page-screen) footer.nx-footer {
                display: none !important;
            }

        .register-page-screen {
            min-height: calc(100dvh - 105px);
            padding: 1.1rem .85rem 4.4rem;
            overflow: visible;
        }

        .register-shell {
            grid-template-columns: 1fr;
            max-width: 720px;
        }

        .register-side {
            display: none;
        }

        .register-form-panel {
            padding: 1.35rem;
        }

        .register-mobile-heading {
            display: block;
            text-align: center;
        }

        .register-mobile-icon {
            width: 58px;
            height: 58px;
            margin: 0 auto .75rem;
            border-radius: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            background: linear-gradient(135deg, var(--reg-navy), var(--reg-indigo));
            box-shadow: 0 14px 28px rgba(17, 24, 68, .22), 0 0 0 6px rgba(234, 224, 207, .55);
            font-size: 1.4rem;
        }

        .register-mobile-heading h2 {
            margin: 0 0 .25rem;
            color: var(--reg-navy);
            font-size: 1.55rem;
            font-weight: 950;
            letter-spacing: -.6px;
        }

        [data-theme="dark"] .register-mobile-heading h2 {
            color: #f8fafc;
        }

        .register-mobile-heading p {
            margin: 0 0 1rem;
            color: var(--reg-indigo);
            font-size: .9rem;
            font-weight: 500;
        }

        [data-theme="dark"] .register-mobile-heading p {
            color: #cbd5e1;
        }
    }

    @@media (max-width: 575.98px) {
        .register-page-screen {
            padding: 1rem .7rem 4.3rem;
        }

        .register-form-panel {
            padding: 1rem;
        }

        .register-shell {
            border-radius: 24px;
        }

        .register-form-grid {
            grid-template-columns: 1fr;
            gap: .6rem;
        }

        .register-control,
        textarea.register-control {
            height: 44px;
            min-height: 44px;
        }

        .register-submit {
            min-height: 46px;
        }

        .register-bottom {
            font-size: .82rem;
        }

        .register-page-footer {
            height: 54px;
            font-size: .76rem;
            padding: 0 .75rem;
            text-align: center;
        }
    }

    @@media (max-height: 760px) and (min-width: 992px) {
        .register-page-screen {
            padding: .55rem 1rem 3.2rem;
        }

        .register-shell {
            grid-template-columns: 285px minmax(0, 1fr);
        }

        .register-side {
            min-height: 420px;
            padding: 1.2rem;
        }

        .register-side-title {
            font-size: 1.35rem;
        }

        .register-side-text {
            font-size: .78rem;
            line-height: 1.4;
        }

        .register-benefits {
            gap: .45rem;
            margin-top: .8rem;
        }

            .register-benefits li {
                font-size: .76rem;
            }

        .register-note {
            font-size: .74rem;
            padding: .7rem;
        }

        .register-form-panel {
            padding: 1rem 1.25rem;
        }

        .register-form-grid {
            gap: .45rem .75rem;
        }

        .register-label {
            font-size: .72rem;
            margin-bottom: .18rem;
        }

        .register-control,
        textarea.register-control {
            height: 36px;
            min-height: 36px;
            border-radius: 12px;
            font-size: .82rem;
            padding: .45rem .7rem;
        }

        .field-hint {
            display: none;
        }

        .register-validation {
            min-height: 10px;
            font-size: .64rem;
            margin-top: .1rem;
        }

        .register-submit {
            min-height: 38px;
            border-radius: 13px;
            font-size: .86rem;
        }

        .register-bottom {
            padding-top: .45rem;
            font-size: .76rem;
        }

        .register-page-footer {
            height: 42px;
            font-size: .74rem;
        }
    }

    @@media (max-height: 630px) and (min-width: 992px) {
        body:has(.register-page-screen) {
            height: auto;
            min-height: 100dvh;
            overflow: auto;
            display: block;
        }

        .register-page-screen {
            min-height: auto;
            padding: .9rem 1rem 3.8rem;
        }
    }
</style>

<section class="register-page-screen">
    <div class="register-shell fade-up">

        <aside class="register-side">
            <div class="register-side-top">
                <div class="register-brand-mini">
                    <span class="register-brand-icon">
                        <i class="bi bi-house-door-fill"></i>
                    </span>
                    <span>Bachelor's Point</span>
                </div>

                <h1 class="register-side-title">@title</h1>
                <p class="register-side-text">@subtitle</p>

                <ul class="register-benefits">
                    <li>
                        <i class="bi bi-envelope-check-fill"></i>
                        Email OTP verification
                    </li>
                    <li>
                        <i class="bi bi-shield-check"></i>
                        Secure account setup
                    </li>
                    <li>
                        <i class="bi @(isAdminRegister ? "bi-person-badge-fill" : "bi-person-check-fill")"></i>
                        @(isAdminRegister ? "Admin access request" : "Room seeker/owner profile")
                    </li>
                </ul>
            </div>

            <div class="register-side-bottom">
                <div class="register-note">
                    <strong>Note:</strong> Use a real email address. A 6-digit verification code will be sent there.
                </div>
            </div>
        </aside>

        <div class="register-form-panel">
            <div class="register-mobile-heading">
                <div class="register-mobile-icon">
                    <i class="bi @(isAdminRegister ? "bi-person-badge-fill" : "bi-person-plus-fill")"></i>
                </div>
                <h2>@title</h2>
                <p>@subtitle</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <form asp-action="Register" asp-route-as="@regType" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div class="register-form-grid">

                    <div class="register-field">
                        <label asp-for="FullName" class="register-label">
                            <i class="bi bi-person-vcard"></i>
                            Full Name
                        </label>
                        <input asp-for="FullName" class="register-control" placeholder="Your full name" />
                        <span asp-validation-for="FullName" class="text-danger register-validation"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="UserName" class="register-label">
                            <i class="bi bi-person-fill"></i>
                            User Name
                        </label>
                        <input asp-for="UserName" class="register-control" placeholder="e.g. sajid007" />
                        <span asp-validation-for="UserName" class="text-danger register-validation"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="DateOfBirth" class="register-label">
                            <i class="bi bi-calendar3"></i>
                            Date of Birth
                        </label>
                        <input asp-for="DateOfBirth" type="date" class="register-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger register-validation"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="PhoneNumber" class="register-label">
                            <i class="bi bi-telephone-fill"></i>
                            Phone <span class="optional">(optional)</span>
                        </label>
                        <input asp-for="PhoneNumber" class="register-control" placeholder="01XXXXXXXXX" />
                        <span asp-validation-for="PhoneNumber" class="text-danger register-validation"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="Email" class="register-label">
                            <i class="bi bi-envelope-fill"></i>
                            Email address
                        </label>
                        <input asp-for="Email" class="register-control" placeholder="you@example.com" />
                        <span asp-validation-for="Email" class="text-danger register-validation"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="Address" class="register-label">
                            <i class="bi bi-geo-alt-fill"></i>
                            Address
                        </label>
                        <textarea asp-for="Address" class="register-control" rows="1" placeholder="Your address"></textarea>
                        <span asp-validation-for="Address" class="text-danger register-validation"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="Password" class="register-label">
                            <i class="bi bi-lock-fill"></i>
                            Password
                        </label>
                        <input asp-for="Password" type="password" class="register-control" placeholder="At least 8 characters" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger register-validation"></span>
                    </div>

                    <div class="register-field">
                        <label asp-for="ConfirmPassword" class="register-label">
                            <i class="bi bi-unlock-fill"></i>
                            Confirm Password
                        </label>
                        <input asp-for="ConfirmPassword" type="password" class="register-control" placeholder="Re-enter password" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger register-validation"></span>
                    </div>

                    <div class="register-actions">
                        <button type="submit" class="register-submit">
                            <i class="bi bi-send-fill"></i>
                            Send Verification Code
                        </button>
                    </div>

                    <div class="register-bottom">
                        Already have an account?
                        <a asp-action="Login" asp-route-as="@regType">Sign in</a>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <div class="register-page-footer">
        &copy; 2026&nbsp;<strong>Bachelor's Point</strong>&nbsp;&middot;&nbsp;
        <a asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
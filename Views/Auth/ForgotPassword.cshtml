@model ForgotPasswordDto
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-card" style="max-width: 460px;">
    <div class="text-center mb-4">
        <div style="width: 80px; height: 80px; background: var(--clr-warning-light); color: var(--clr-warning); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 2.2rem; margin-bottom: 1rem;">
            <i class="bi bi-key-fill"></i>
        </div>
        <h2 style="font-size: 1.45rem; font-weight: 800; margin-bottom: 0.5rem;">Forgot password?</h2>
        <p style="color: var(--clr-muted); font-size: 0.9rem; margin: 0;">
            No worries — enter your email and we'll send you a code to reset it.
        </p>
    </div>

    <form asp-action="ForgotPassword" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email address</label>
            <div style="position: relative;">
                <i class="bi bi-envelope" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--clr-muted);"></i>
                <input asp-for="Email" class="form-control" style="padding-left: 38px;" placeholder="you@example.com" autofocus />
            </div>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-2" style="height: 46px;">
            <i class="bi bi-send-fill me-1"></i> Send Reset Code
        </button>
        <a asp-action="Login" asp-route-as="user" class="btn btn-outline-secondary w-100">
            <i class="bi bi-arrow-left me-1"></i> Back to Sign In
        </a>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

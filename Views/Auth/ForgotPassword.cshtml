@model ForgotPasswordDto
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-card fade-up" style="max-width: 460px;">
    <div class="text-center mb-4">
        <div style="width: 80px; height: 80px; background: var(--warning-light); color: var(--warning); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 2.2rem; margin-bottom: 1rem;">
            <i class="bi bi-key-fill"></i>
        </div>
        <h2 style="font-size: 1.55rem; font-weight: 800; margin-bottom: 0.5rem;">Forgot password?</h2>
        <p style="color: var(--muted); font-size: 0.92rem; margin: 0;">
            No worries — enter your email and we'll send you a code to reset it.
        </p>
    </div>

    <form asp-action="ForgotPassword" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email address</label>
            <input asp-for="Email" class="form-control" placeholder="you@example.com" autofocus />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn-auth warning mb-2">
            <i class="bi bi-send-fill"></i> Send Reset Code
        </button>
        <a asp-action="Login" asp-route-as="user" class="btn-auth outline">
            <i class="bi bi-arrow-left"></i> Back to Sign In
        </a>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

@model ForgotPasswordDto
@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    .forgot-icon-wrap {
        width: 76px;
        height: 76px;
        border-radius: 50%;
        background: #fff7ed;
        color: #c2410c;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
    }
</style>

<div class="container">
    <div class="auth-card" style="max-width: 480px;">
        <div class="text-center mb-4">
            <div class="forgot-icon-wrap"><i class="bi bi-key-fill"></i></div>
            <h3 class="mt-3 mb-1">Forgot Password?</h3>
            <p class="text-muted small mb-0">
                Enter your email address and we'll send you a 6-digit code to reset your password.
            </p>
        </div>

        <form asp-action="ForgotPassword" method="post" autocomplete="off">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">
                    <i class="bi bi-envelope me-1 text-secondary"></i>Email
                </label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" autofocus />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-warning btn-lg">
                    <i class="bi bi-send-fill me-1"></i> Send Reset Code
                </button>
                <a asp-action="Login" asp-route-as="user" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Back to Login
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

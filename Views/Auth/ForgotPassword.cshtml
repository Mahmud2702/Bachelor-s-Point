@model ForgotPasswordDto
@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    /*
            Forgot Password Page UI/UX
            Palette:
            #111844 - Deep navy
            #4B5694 - Soft indigo
            #7288AE - Muted blue
            #EAE0CF - Warm beige

            Main fix:
            - Hide layout footer only on this page.
            - Make body a full-height flex layout.
            - Put a custom footer inside this page at the actual bottom.
        */

    :root {
        --fp-navy: #111844;
        --fp-indigo: #4B5694;
        --fp-bluegray: #7288AE;
        --fp-beige: #EAE0CF;
        --fp-white: #ffffff;
        --fp-border: rgba(17, 24, 68, .14);
        --fp-shadow: 0 24px 70px rgba(17, 24, 68, .15);
    }

    body:has(.forgot-page-screen) {
        height: 100dvh;
        min-height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: radial-gradient(circle at 8% 18%, rgba(75, 86, 148, .18), transparent 30%), radial-gradient(circle at 92% 82%, rgba(234, 224, 207, .72), transparent 34%), linear-gradient(135deg, #fbfbfd 0%, #f4f0e8 48%, #eef2f8 100%);
    }

    [data-theme="dark"] body:has(.forgot-page-screen) {
        background: radial-gradient(circle at 8% 18%, rgba(114, 136, 174, .16), transparent 30%), radial-gradient(circle at 90% 82%, rgba(75, 86, 148, .26), transparent 34%), linear-gradient(135deg, #070b18 0%, #111844 58%, #151b33 100%);
    }

    body:has(.forgot-page-screen) .bp-guest-nav {
        flex: 0 0 auto;
    }

    body:has(.forgot-page-screen) main[role="main"] {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    body:has(.forgot-page-screen) main > .container.mt-3:empty {
        display: none !important;
    }

    body:has(.forgot-page-screen) footer.nx-footer {
        display: none !important;
    }

    body:has(.forgot-page-screen) .bp-brand-icon,
    body:has(.forgot-page-screen) .bp-brand:hover .bp-brand-icon {
        width: 42px !important;
        height: 42px !important;
        min-width: 42px !important;
        border-radius: 14px !important;
        background: linear-gradient(135deg, #111844 0%, #4B5694 60%, #7288AE 100%) !important;
        color: #ffffff !important;
        transform: none !important;
        rotate: 0deg !important;
        animation: none !important;
        box-shadow: 0 12px 26px rgba(17, 24, 68, .24), 0 0 0 4px rgba(234, 224, 207, .55) !important;
        transition: box-shadow .22s ease, filter .22s ease !important;
    }

        body:has(.forgot-page-screen) .bp-brand-icon i {
            color: #ffffff !important;
            font-size: 1.25rem !important;
        }

    body:has(.forgot-page-screen) .bp-brand:hover .bp-brand-icon {
        filter: brightness(1.08);
        box-shadow: 0 14px 30px rgba(17, 24, 68, .30), 0 0 0 5px rgba(234, 224, 207, .78), 0 0 24px rgba(75, 86, 148, .42) !important;
    }

    body:has(.forgot-page-screen) .bp-brand-name {
        background: linear-gradient(135deg, #111844 0%, #4B5694 70%) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
        font-weight: 900 !important;
    }

    [data-theme="dark"] body:has(.forgot-page-screen) .bp-brand-name {
        background: linear-gradient(135deg, #EAE0CF 0%, #7288AE 100%) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
    }

    .forgot-page-screen {
        position: relative;
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 1rem 4.4rem;
        overflow: hidden;
    }

        .forgot-page-screen::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(17, 24, 68, .035) 1px, transparent 1px), linear-gradient(90deg, rgba(17, 24, 68, .035) 1px, transparent 1px);
            background-size: 46px 46px;
            mask-image: radial-gradient(circle at center, black, transparent 76%);
            pointer-events: none;
        }

    [data-theme="dark"] .forgot-page-screen::before {
        background-image: linear-gradient(rgba(234, 224, 207, .045) 1px, transparent 1px), linear-gradient(90deg, rgba(234, 224, 207, .045) 1px, transparent 1px);
    }

    .forgot-card {
        position: relative;
        z-index: 1;
        width: min(100%, 500px);
        padding: clamp(1.2rem, 2.4vh, 1.7rem);
        border-radius: 28px;
        background: linear-gradient(180deg, rgba(255, 255, 255, .96), rgba(255, 255, 255, .84));
        border: 1px solid var(--fp-border);
        box-shadow: var(--fp-shadow);
        overflow: hidden;
        text-align: center;
    }

        .forgot-card::before {
            content: "";
            position: absolute;
            inset: 0;
            z-index: -1;
            background: radial-gradient(circle at 10% 10%, rgba(234, 224, 207, .58), transparent 34%), radial-gradient(circle at 95% 92%, rgba(114, 136, 174, .22), transparent 36%);
            pointer-events: none;
        }

    [data-theme="dark"] .forgot-card {
        background: linear-gradient(180deg, rgba(21, 27, 51, .96), rgba(17, 24, 68, .88));
        border-color: rgba(234, 224, 207, .12);
        box-shadow: 0 24px 70px rgba(0, 0, 0, .34);
    }

        [data-theme="dark"] .forgot-card::before {
            background: radial-gradient(circle at 10% 10%, rgba(234, 224, 207, .08), transparent 34%), radial-gradient(circle at 95% 92%, rgba(114, 136, 174, .16), transparent 36%);
        }

    .forgot-icon {
        width: 72px;
        height: 72px;
        margin: 0 auto .85rem;
        border-radius: 23px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--fp-navy), var(--fp-indigo));
        color: #ffffff;
        font-size: 1.75rem;
        box-shadow: 0 16px 34px rgba(17, 24, 68, .24), 0 0 0 6px rgba(234, 224, 207, .70);
    }

    .forgot-title {
        margin: 0 0 .35rem;
        color: var(--fp-navy);
        font-size: clamp(1.55rem, 2.4vw, 1.95rem);
        line-height: 1.08;
        font-weight: 950;
        letter-spacing: -.8px;
    }

    [data-theme="dark"] .forgot-title {
        color: #f8fafc;
    }

    .forgot-subtitle {
        max-width: 400px;
        margin: 0 auto 1rem;
        color: var(--fp-indigo);
        font-size: .92rem;
        line-height: 1.48;
        font-weight: 500;
    }

    [data-theme="dark"] .forgot-subtitle {
        color: #cbd5e1;
    }

    .forgot-form {
        text-align: left;
    }

    .forgot-form-group {
        margin-bottom: .75rem;
    }

    .forgot-form-label {
        display: block;
        margin-bottom: .32rem;
        color: var(--fp-navy);
        font-size: .84rem;
        font-weight: 850;
    }

    [data-theme="dark"] .forgot-form-label {
        color: #f8fafc;
    }

    .forgot-card .form-control {
        width: 100%;
        height: 44px;
        padding: .62rem .95rem;
        border-radius: 15px;
        border: 1px solid rgba(17, 24, 68, .13);
        background: rgba(234, 224, 207, .34);
        color: var(--fp-navy);
        font-size: .91rem;
        font-weight: 500;
        box-shadow: none;
        transition: border-color .2s ease, box-shadow .2s ease, background .2s ease;
    }

        .forgot-card .form-control:focus {
            border-color: var(--fp-bluegray);
            background: rgba(255, 255, 255, .94);
            box-shadow: 0 0 0 4px rgba(114, 136, 174, .20), 0 12px 28px rgba(17, 24, 68, .10);
            outline: none;
        }

        .forgot-card .form-control::placeholder {
            color: rgba(75, 86, 148, .55);
        }

    [data-theme="dark"] .forgot-card .form-control {
        background: rgba(234, 224, 207, .08);
        color: #f8fafc;
        border-color: rgba(234, 224, 207, .14);
    }

        [data-theme="dark"] .forgot-card .form-control:focus {
            background: rgba(17, 24, 68, .88);
            border-color: var(--fp-beige);
            box-shadow: 0 0 0 4px rgba(234, 224, 207, .12), 0 12px 28px rgba(0, 0, 0, .24);
        }

    .forgot-btn {
        width: 100%;
        min-height: 44px;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .65rem;
        font-size: .93rem;
        font-weight: 900;
        text-decoration: none;
        border: none;
        transition: box-shadow .22s ease, filter .22s ease, background .22s ease, border-color .22s ease;
    }

    .forgot-btn-primary {
        color: #ffffff;
        background: linear-gradient(135deg, var(--fp-navy), var(--fp-indigo));
        box-shadow: 0 13px 28px rgba(17, 24, 68, .22);
    }

        .forgot-btn-primary:hover {
            color: #ffffff;
            filter: brightness(1.07);
            box-shadow: 0 16px 34px rgba(17, 24, 68, .28), 0 0 0 5px rgba(234, 224, 207, .88), 0 0 0 9px rgba(114, 136, 174, .28), 0 0 24px rgba(75, 86, 148, .42);
        }

    .forgot-btn-outline {
        margin-top: .55rem;
        color: var(--fp-indigo);
        background: rgba(255, 255, 255, .72);
        border: 1px solid rgba(17, 24, 68, .13);
    }

        .forgot-btn-outline:hover {
            color: var(--fp-navy);
            background: rgba(234, 224, 207, .45);
            border-color: rgba(75, 86, 148, .36);
            box-shadow: 0 12px 26px rgba(17, 24, 68, .10), 0 0 0 5px rgba(114, 136, 174, .14);
        }

    [data-theme="dark"] .forgot-btn-outline {
        color: #f8fafc;
        background: rgba(234, 224, 207, .08);
        border-color: rgba(234, 224, 207, .14);
    }

        [data-theme="dark"] .forgot-btn-outline:hover {
            background: rgba(234, 224, 207, .13);
            color: var(--fp-beige);
        }

    .forgot-btn i {
        transition: transform .2s ease;
    }

    .forgot-btn-primary:hover i {
        transform: translateX(3px);
    }

    .forgot-btn-outline:hover i {
        transform: translateX(-3px);
    }

    .forgot-page-footer {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 2;
        height: 58px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--fp-indigo);
        font-size: .84rem;
        font-weight: 500;
        background: rgba(255, 255, 255, .70);
        border-top: 1px solid rgba(17, 24, 68, .08);
        backdrop-filter: blur(14px);
    }

        .forgot-page-footer strong {
            color: var(--fp-navy);
            font-weight: 850;
        }

        .forgot-page-footer a {
            color: #2563eb;
            font-weight: 800;
            text-decoration: none;
        }

            .forgot-page-footer a:hover {
                text-decoration: underline;
            }

    [data-theme="dark"] .forgot-page-footer {
        color: #cbd5e1;
        background: rgba(7, 11, 24, .72);
        border-top-color: rgba(234, 224, 207, .10);
    }

        [data-theme="dark"] .forgot-page-footer strong {
            color: var(--fp-beige);
        }

        [data-theme="dark"] .forgot-page-footer a {
            color: var(--fp-beige);
        }

    @@media (max-width: 575.98px) {
        body:has(.forgot-page-screen) {
            height: auto;
            min-height: 100dvh;
            overflow: auto;
            display: block;
        }

            body:has(.forgot-page-screen) footer.nx-footer {
                display: none !important;
            }

        .forgot-page-screen {
            min-height: calc(100dvh - 105px);
            padding: 1.1rem .75rem 4.5rem;
        }

        .forgot-card {
            padding: 1.15rem;
            border-radius: 24px;
        }

        .forgot-icon {
            width: 64px;
            height: 64px;
            border-radius: 20px;
            font-size: 1.5rem;
            margin-bottom: .8rem;
        }

        .forgot-title {
            font-size: 1.45rem;
        }

        .forgot-subtitle {
            font-size: .88rem;
            margin-bottom: .9rem;
        }

        .forgot-card .form-control {
            height: 44px;
        }

        .forgot-btn {
            min-height: 44px;
        }

        .forgot-page-footer {
            height: 56px;
            font-size: .78rem;
            padding: 0 .8rem;
            text-align: center;
        }
    }

    @@media (max-height: 720px) and (min-width: 768px) {
        .forgot-page-screen {
            padding: .55rem 1rem 3.8rem;
        }

        .forgot-card {
            padding: 1rem 1.65rem;
        }

        .forgot-icon {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            font-size: 1.35rem;
            margin-bottom: .55rem;
        }

        .forgot-title {
            font-size: 1.45rem;
            margin-bottom: .18rem;
        }

        .forgot-subtitle {
            margin-bottom: .65rem;
            font-size: .82rem;
            line-height: 1.4;
        }

        .forgot-form-group {
            margin-bottom: .55rem;
        }

        .forgot-form-label {
            margin-bottom: .22rem;
            font-size: .78rem;
        }

        .forgot-card .form-control {
            height: 38px;
            border-radius: 13px;
            font-size: .86rem;
        }

        .forgot-btn {
            min-height: 38px;
            border-radius: 13px;
            font-size: .86rem;
        }

        .forgot-page-footer {
            height: 48px;
            font-size: .78rem;
        }
    }

    @@media (max-height: 610px) and (min-width: 768px) {
        body:has(.forgot-page-screen) {
            height: auto;
            min-height: 100dvh;
            overflow: auto;
            display: block;
        }

        .forgot-page-screen {
            min-height: auto;
            padding: 1rem 1rem 4.2rem;
        }
    }
</style>

<section class="forgot-page-screen">
    <div class="forgot-card fade-up">
        <div class="forgot-icon">
            <i class="bi bi-key-fill"></i>
        </div>

        <h2 class="forgot-title">Forgot password?</h2>

        <p class="forgot-subtitle">
            Enter your email address and we’ll send you a secure code to reset your password.
        </p>

        <form asp-action="ForgotPassword" method="post" autocomplete="off" class="forgot-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="forgot-form-group">
                <label asp-for="Email" class="forgot-form-label">Email address</label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" autofocus />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="forgot-btn forgot-btn-primary">
                <i class="bi bi-send-fill"></i>
                Send Reset Code
            </button>

            <a asp-action="Login" asp-route-as="user" class="forgot-btn forgot-btn-outline">
                <i class="bi bi-arrow-left"></i>
                Back to Sign In
            </a>
        </form>
    </div>

    <div class="forgot-page-footer">
        &copy; 2026&nbsp;<strong>Bachelor's Point</strong>&nbsp;&middot;&nbsp;
        <a asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model ChangePasswordDto
@{
    ViewData["Title"] = "Change Password";
}

<div class="auth-card fade-up" style="max-width: 520px;">
    <div class="d-flex align-items-center justify-content-between gap-3 mb-4">
        <div class="d-flex align-items-center gap-3">
            <div style="width: 56px; height: 56px; background: var(--primary-light); color: var(--primary); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 1.65rem;">
                <i class="bi bi-key-fill"></i>
            </div>
            <div>
                <h2 style="font-size: 1.45rem; font-weight: 800; margin: 0;">Change Password</h2>
                <p style="color: var(--muted); font-size: 0.85rem; margin: 0;">Update your account password.</p>
            </div>
        </div>
        <a asp-action="EditProfile" class="btn-nx outline sm">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    <form asp-action="ChangePassword" method="post" autocomplete="off">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="CurrentPassword" class="form-label">Current Password</label>
            <div style="position: relative;">
                <input asp-for="CurrentPassword" type="password" class="form-control"
                       style="padding-right: 44px;" placeholder="Enter your current password" autofocus id="currentPass" />
                <i class="bi bi-eye" id="curEyeIcon"
                   style="position:absolute; right:14px; top:50%; transform:translateY(-50%); color:var(--muted); cursor:pointer;"
                   onclick="toggleEye('currentPass','curEyeIcon')"></i>
            </div>
            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
        </div>

        <hr style="border-color: var(--border); margin: 1.25rem 0;" />

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label">New Password</label>
            <div style="position: relative;">
                <input asp-for="NewPassword" type="password" class="form-control"
                       style="padding-right: 44px;" placeholder="At least 8 characters" id="newPass" />
                <i class="bi bi-eye" id="newEyeIcon"
                   style="position:absolute; right:14px; top:50%; transform:translateY(-50%); color:var(--muted); cursor:pointer;"
                   onclick="toggleEye('newPass','newEyeIcon')"></i>
            </div>
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
            <div style="position: relative;">
                <input asp-for="ConfirmPassword" type="password" class="form-control"
                       style="padding-right: 44px;" placeholder="Re-enter new password" id="confirmPass" />
                <i class="bi bi-eye" id="confEyeIcon"
                   style="position:absolute; right:14px; top:50%; transform:translateY(-50%); color:var(--muted); cursor:pointer;"
                   onclick="toggleEye('confirmPass','confEyeIcon')"></i>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-auth" style="flex: 1;">
                <i class="bi bi-check-circle"></i> Update Password
            </button>
            <a asp-action="EditProfile" class="btn-auth outline" style="flex: 1;">
                <i class="bi bi-x-circle"></i> Cancel
            </a>
        </div>
    </form>

    <hr style="border-color: var(--border); margin: 1.75rem 0 1.25rem;" />

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h5 style="font-size: 0.95rem; font-weight: 700; margin: 0;">Forgot your current password?</h5>
            <p style="color: var(--muted); font-size: 0.82rem; margin: 0;">Reset it via your email (OTP).</p>
        </div>
        <a asp-action="ForgotPassword" class="btn-nx outline">
            <i class="bi bi-envelope"></i> Reset via Email
        </a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function toggleEye(inputId, iconId) {
            const inp = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (inp.type === 'password') {
                inp.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                inp.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
}

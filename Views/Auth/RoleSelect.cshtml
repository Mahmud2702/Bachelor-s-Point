@{
    ViewData["Title"] = "Welcome";
}

<div class="container py-5">
    <div class="text-center mb-5 fade-up">
        <div style="display:inline-flex; align-items:center; gap:10px; padding: 6px 18px; background: var(--primary-light); border-radius: 999px; margin-bottom: 1.5rem;">
            <i class="bi bi-house-heart-fill" style="color: var(--primary);"></i>
            <span style="color: var(--primary); font-weight: 700; font-size: 0.85rem;">Bachelor's Point</span>
        </div>
        <h1 style="font-size: 2.6rem; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 0.75rem;">
            Find your perfect bachelor room
        </h1>
        <p style="font-size: 1.05rem; color: var(--muted); max-width: 560px; margin: 0 auto;">
            Choose how you'd like to continue.
        </p>
    </div>

    <div class="row g-4 justify-content-center" style="max-width: 880px; margin: 0 auto;">
        <div class="col-md-6 fade-up">
            <a asp-action="Login" asp-route-as="admin" class="role-card h-100">
                <div class="icon-wrap icon-admin">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <h4 style="font-weight: 800; margin-bottom: 0.5rem; font-size: 1.25rem;">Admin</h4>
                <p style="color: var(--muted); margin: 0 0 1.5rem; font-size: 0.92rem;">
                    Approve room postings, manage users and roles.
                </p>
                <span class="btn-nx" style="pointer-events: none;">
                    Continue as Admin <i class="bi bi-arrow-right"></i>
                </span>
            </a>
        </div>
        <div class="col-md-6 fade-up">
            <a asp-action="Login" asp-route-as="user" class="role-card h-100">
                <div class="icon-wrap icon-user">
                    <i class="bi bi-person-fill"></i>
                </div>
                <h4 style="font-weight: 800; margin-bottom: 0.5rem; font-size: 1.25rem;">User</h4>
                <p style="color: var(--muted); margin: 0 0 1.5rem; font-size: 0.92rem;">
                    Post a room or find a bachelor room to rent.
                </p>
                <span class="btn-nx success" style="pointer-events: none;">
                    Continue as User <i class="bi bi-arrow-right"></i>
                </span>
            </a>
        </div>
    </div>

    <div class="text-center mt-5">
        <p style="color: var(--muted); font-size: 0.92rem; margin: 0;">
            Don't have an account?
            <a asp-action="Register" asp-route-as="user" class="auth-link">Create one free</a>
        </p>
    </div>
</div>

@model ResetPasswordDto
@{
    ViewData["Title"] = "Reset Password";
    bool allowResend = ViewBag.AllowResend is bool b && b;
}

<div class="auth-card fade-up" style="max-width: 520px;">
    <div class="text-center mb-4">
        <div style="width: 80px; height: 80px; background: var(--warning-light); color: var(--warning); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 2.2rem; margin-bottom: 1rem;">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h2 style="font-size: 1.55rem; font-weight: 800; margin-bottom: 0.5rem;">Reset your password</h2>
        <p style="color: var(--muted); font-size: 0.92rem; margin: 0;">
            Enter the 6-digit code sent to<br />
            <strong style="color: var(--text);">@Model.Email</strong>
        </p>
    </div>

    <form asp-action="ResetPassword" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

        <input asp-for="Email" type="hidden" />

        <div class="mb-3">
            <label asp-for="Otp" class="form-label">Verification Code</label>
            <input asp-for="Otp" class="form-control text-center"
                   style="font-size: 1.5rem; letter-spacing: 0.7rem; font-weight: 700; padding: 0.75rem 0.5rem; height: 60px;"
                   inputmode="numeric" pattern="\d{6}" maxlength="6"
                   placeholder="——————" autofocus />
            <span asp-validation-for="Otp" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label">New Password</label>
            <input asp-for="NewPassword" type="password" class="form-control" placeholder="At least 8 characters" />
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter new password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn-auth mb-2">
            <i class="bi bi-check-circle"></i> Reset Password
        </button>

        <p class="text-center mb-0" style="color: var(--muted); font-size: 0.82rem;">
            Code expires in <strong style="color: var(--text);">5 minutes</strong>.
        </p>
    </form>

    <hr style="border-color: var(--border); margin: 1.5rem 0;" />

    <div class="text-center">
        <p style="color: var(--muted); font-size: 0.85rem; margin-bottom: 0.75rem;">
            Didn't receive the code?
            @if (allowResend)
            {
                <br /><span style="color: var(--danger);">Your code expired — please request a new one.</span>
            }
        </p>
        <form asp-action="ResendResetOtp" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@Model.Email" />
            <button type="submit" class="btn-nx outline sm">
                <i class="bi bi-arrow-clockwise"></i> Resend Code
            </button>
        </form>
        <a asp-action="ForgotPassword" class="auth-link" style="margin-left: 0.5rem; font-size: 0.85rem;">
            <i class="bi bi-pencil"></i> Change email
        </a>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function() {
            const input = document.querySelector('input[name="Otp"]');
            if (input) {
                input.addEventListener('input', () => {
                    input.value = input.value.replace(/\D/g, '').slice(0, 6);
                });
            }
        })();
    </script>
}

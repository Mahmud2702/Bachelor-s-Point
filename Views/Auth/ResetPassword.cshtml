@model ResetPasswordDto
@{
    ViewData["Title"] = "Reset Password";
    bool allowResend = ViewBag.AllowResend is bool b && b;
}

<style>
    .otp-input {
        font-size: 1.6rem;
        letter-spacing: 0.8rem;
        text-align: center;
        font-weight: 700;
        padding: 0.85rem 0.5rem;
    }
    .reset-icon-wrap {
        width: 76px;
        height: 76px;
        border-radius: 50%;
        background: #fff7ed;
        color: #c2410c;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
    }
</style>

<div class="container">
    <div class="auth-card" style="max-width: 520px;">
        <div class="text-center mb-4">
            <div class="reset-icon-wrap"><i class="bi bi-shield-lock-fill"></i></div>
            <h3 class="mt-3 mb-1">Reset Your Password</h3>
            <p class="text-muted small mb-0">
                Enter the 6-digit code sent to<br />
                <strong>@Model.Email</strong>
                <br />and choose a new password.
            </p>
        </div>

        <form asp-action="ResetPassword" method="post" autocomplete="off">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <input asp-for="Email" type="hidden" />

            <div class="mb-3">
                <label asp-for="Otp" class="form-label">Verification Code</label>
                <input asp-for="Otp" class="form-control otp-input"
                       inputmode="numeric" pattern="\d{6}" maxlength="6"
                       placeholder="——————" autofocus />
                <span asp-validation-for="Otp" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">
                    <i class="bi bi-lock me-1 text-secondary"></i>New Password
                </label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="At least 8 characters" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">
                    <i class="bi bi-lock-fill me-1 text-secondary"></i>Confirm New Password
                </label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter new password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="d-grid gap-2 mb-3">
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-check-circle me-1"></i> Reset Password
                </button>
            </div>

            <p class="text-center small text-muted mb-0">
                The code expires in <strong>5 minutes</strong>.
            </p>
        </form>

        <hr class="my-3" />

        <div class="text-center">
            <p class="small text-muted mb-2">
                Didn't receive the code?
                @if (allowResend)
                {
                    <span class="text-danger">Your code has expired — please request a new one.</span>
                }
            </p>
            <form asp-action="ResendResetOtp" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model.Email" />
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-arrow-clockwise me-1"></i> Resend Code
                </button>
            </form>
            <a asp-action="ForgotPassword" class="btn btn-link btn-sm ms-1">
                <i class="bi bi-pencil me-1"></i> Change Email
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function() {
            const input = document.querySelector('.otp-input');
            if (input) {
                input.addEventListener('input', () => {
                    input.value = input.value.replace(/\D/g, '').slice(0, 6);
                });
            }
        })();
    </script>
}

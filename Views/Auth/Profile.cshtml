        .profile-hero-inner {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .profile-avatar-wrap {
            margin: 0 auto;
        }

        .profile-contact-grid {
            justify-content: center;
        }

        .profile-chip {
            width: 100%;
            justify-content: center;
            border-radius: 16px;
        }

        .profile-side-row {
            align-items: flex-start;
            flex-direction: column;
            gap: .28rem;
        }

        .profile-side-value {
            text-align: left;
        }

        .profile-section-head {
            align-items: flex-start;
            flex-direction: column;
        }

        .profile-stat-grid,
        .profile-room-grid,
        .profile-booked-grid {
            grid-template-columns: 1fr;
        }

        .profile-card-top {
            flex-direction: column;
        }

        .profile-room-facts {
            grid-template-columns: 1fr;
        }

        .profile-actions {
            flex-direction: column;
        }

        .profile-mini-btn {
            width: 100%;
        }
    }
</style>

<section class="profile-page">
    <div class="profile-shell">

        <div class="profile-hero">
            <div class="profile-hero-inner">
                <form asp-controller="Auth" asp-action="UploadProfilePicture" method="post"
                      enctype="multipart/form-data" id="profilePicForm" class="profile-avatar-form">
                    @Html.AntiForgeryToken()

                    <div class="profile-avatar-wrap">
                        @if (hasPic)
                        {
                            <img src="@Model.ProfilePicturePath" alt="Profile picture" class="profile-photo" />
                        }
                        else
                        {
                            <div class="profile-avatar-fallback">
                                @GetInitials(displayName)
                            </div>
                        }

                        <label for="profilePicInput" class="profile-photo-edit" title="Change profile picture">
                            <i class="bi bi-camera-fill"></i>
                        </label>

                        <input type="file" name="profilePicture" id="profilePicInput"
                               accept="image/jpeg,image/png,image/gif,image/webp"
                               onchange="document.getElementById('profilePicForm').submit();"
                               style="display:none;" />
                    </div>
                </form>

                <div>
                    <div class="profile-kicker">
                        <i class="bi bi-shield-lock-fill"></i>
                        <span>@roleName Profile</span>
                    </div>

                    <h1 class="profile-name">@displayName</h1>
                    <p class="profile-username">@@@username</p>

                    <div class="profile-contact-grid">
                        <div class="profile-chip">
                            <i class="bi bi-envelope-fill"></i>
                            <span>@Model.Email</span>
                        </div>

                        <div class="profile-chip">
                            <i class="bi bi-telephone-fill"></i>
                            <span>@phoneText</span>
                        </div>

                        <div class="profile-chip">
                            <i class="bi bi-geo-alt-fill"></i>
                            <span>@addressText</span>
                        </div>
                    </div>
                </div>

                <aside class="profile-side-panel">
                    <a asp-action="EditProfile" class="profile-edit-btn">
                        <i class="bi bi-pencil-square"></i>
                        Edit Profile
                    </a>

                    @if (hasPic)
                    {
                        <form asp-controller="Auth" asp-action="RemoveProfilePicture" method="post"
                              onsubmit="return confirm('Remove your profile picture?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="profile-remove-btn">
                                <i class="bi bi-trash-fill"></i>
                                Remove Picture
                            </button>
                        </form>
                    }

                    <div class="profile-side-row">
                        <span class="profile-side-label">
                            <i class="bi bi-person-badge-fill"></i>
                            Role
                        </span>
                        <span class="profile-side-value">@roleName</span>
                    </div>

                    <div class="profile-side-row">
                        <span class="profile-side-label">
                            <i class="bi bi-clock-history"></i>
                            Last Login
                        </span>
                        <span class="profile-side-value">@lastLoginText</span>
                    </div>

                    <div class="profile-side-row">
                        <span class="profile-side-label">
                            <i class="bi bi-bar-chart-fill"></i>
                            Total Activity
                        </span>
                        <span class="profile-side-value">@totalActivity</span>
                    </div>
                </aside>
            </div>
        </div>

        <div class="profile-section">
            <div class="profile-stat-grid">
                <div class="profile-stat-card">
                    <div class="profile-stat-icon">
                        <i class="bi bi-house-check-fill"></i>
                    </div>
                    <h2 class="profile-stat-value">@postedRooms.Count</h2>
                    <p class="profile-stat-label">Rooms Posted</p>
                    <p class="profile-stat-hint">Total room listings created from this account.</p>
                </div>

                <div class="profile-stat-card">
                    <div class="profile-stat-icon">
                        <i class="bi bi-bookmark-check-fill"></i>
                    </div>
                    <h2 class="profile-stat-value">@selections.Count</h2>
                    <p class="profile-stat-label">Rooms Booked</p>
                    <p class="profile-stat-hint">Rooms selected or booked as a seeker.</p>
                </div>

                <div class="profile-stat-card">
                    <div class="profile-stat-icon">
                        <i class="bi bi-inbox-fill"></i>
                    </div>
                    <h2 class="profile-stat-value">@incomingSelections.Count</h2>
                    <p class="profile-stat-label">Booking Requests</p>
                    <p class="profile-stat-hint">Requests received on your own rooms.</p>
                </div>

                <div class="profile-stat-card">
                    <div class="profile-stat-icon">
                        <i class="bi bi-fire"></i>
                    </div>
                    <h2 class="profile-stat-value">@activePosted</h2>
                    <p class="profile-stat-label">Active Listings</p>
                    <p class="profile-stat-hint">Approved rooms currently available to users.</p>
                </div>
            </div>
        </div>

        <div class="profile-section">
            <div class="profile-grid-2">
                <div class="profile-panel">
                    <div class="profile-section-head">
                        <div>
                            <h2 class="profile-section-title">
                                <i class="bi bi-inbox-fill"></i>
                                Booking Requests on My Rooms
                                @if (incomingSelections.Any())
                                {
                                    <span class="profile-status-badge status-pending">@incomingSelections.Count</span>
                                }
                            </h2>
                            <p class="profile-section-subtitle">People who selected your posted rooms and may need your response.</p>
                        </div>
                    </div>

                    @if (incomingSelections.Any())
                    {
                        <div class="profile-request-list">
                            @foreach (var s in incomingSelections)
                            {
                                <article class="profile-request-card">
                                    <div class="profile-card-top">
                                        <div class="d-flex gap-3 align-items-start">
                                            <div class="profile-card-icon">
                                                <i class="bi bi-hand-thumbs-up-fill"></i>
                                            </div>
                                            <div>
                                                <h3 class="profile-card-title">@s.Room?.Title</h3>
                                                <p class="profile-card-meta">
                                                    <i class="bi bi-person-fill me-1"></i>@(s.Seeker?.UserName ?? "Unknown user")
                                                    <span class="mx-1">•</span>
                                                    <i class="bi bi-calendar-event-fill me-1"></i>@s.SelectedAt.ToString("dd-MMM-yyyy hh:mm tt")
                                                </p>
                                                <p class="profile-card-meta">
                                                    <i class="bi bi-envelope-fill me-1"></i>@(s.Seeker?.Email ?? "Email unavailable")
                                                </p>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="profile-message-box">
                                        <i class="bi bi-quote me-1"></i>
                                        @ShortText(s.Message, 110)
                                    </div>

                                    <div class="profile-actions">
                                        <a asp-controller="Room" asp-action="Details" asp-route-id="@s.RoomId" class="profile-mini-btn">
                                            <i class="bi bi-eye-fill"></i>
                                            View Room
                                        </a>

                                        @if (s.Seeker != null)
                                        {
                                            <a asp-controller="Chat" asp-action="Conversation" asp-route-id="@s.SeekerUserId" class="profile-mini-btn primary">
                                                <i class="bi bi-chat-dots-fill"></i>
                                                Start Chat
                                            </a>
                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="profile-empty">
                            <div class="profile-empty-icon">
                                <i class="bi bi-check-circle-fill"></i>
                            </div>
                            <h3>No booking requests yet</h3>
                            <p>No one has selected your rooms yet. Once someone shows interest, requests will appear here.</p>
                            <a asp-controller="Room" asp-action="Create" class="profile-mini-btn primary">
                                <i class="bi bi-plus-lg"></i>
                                Post a Room
                            </a>
                        </div>
                    }
                </div>

                <div class="profile-panel">
                    <div class="profile-section-head">
                        <div>
                            <h2 class="profile-section-title">
                                <i class="bi bi-speedometer2"></i>
                                Profile Snapshot
                            </h2>
                            <p class="profile-section-subtitle">A quick view of your account and listing status.</p>
                        </div>
                    </div>

                    <div class="profile-request-list">
                        <div class="profile-request-card">
                            <div class="profile-card-top">
                                <div class="d-flex gap-3 align-items-start">
                                    <div class="profile-card-icon">
                                        <i class="bi bi-shield-fill-check"></i>
                                    </div>
                                    <div>
                                        <h3 class="profile-card-title">Account Role</h3>
                                        <p class="profile-card-meta">You are currently using this platform as <strong>@roleName</strong>.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="profile-request-card">
                            <div class="profile-card-top">
                                <div class="d-flex gap-3 align-items-start">
                                    <div class="profile-card-icon">
                                        <i class="bi bi-house-lock-fill"></i>
                                    </div>
                                    <div>
                                        <h3 class="profile-card-title">Room Status</h3>
                                        <p class="profile-card-meta">
                                            @activePosted active, @pendingPosted pending, @closedPosted closed listings from your account.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="profile-request-card">
                            <div class="profile-card-top">
                                <div class="d-flex gap-3 align-items-start">
                                    <div class="profile-card-icon">
                                        <i class="bi bi-bell-fill"></i>
                                    </div>
                                    <div>
                                        <h3 class="profile-card-title">Response Reminder</h3>
                                        <p class="profile-card-meta">Reply to booking requests quickly to keep your listing experience smooth.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="profile-section">
            <div class="profile-panel">
                <div class="profile-section-head">
                    <div>
                        <h2 class="profile-section-title">
                            <i class="bi bi-house-heart-fill"></i>
                            My Posted Rooms
                        </h2>
                        <p class="profile-section-subtitle">Manage the rooms you have shared on Bachelor’s Point.</p>
                    </div>

                    <a asp-controller="Room" asp-action="Create" class="profile-mini-btn primary">
                        <i class="bi bi-plus-lg"></i>
                        Post New Room
                    </a>
                </div>

                @if (postedRooms.Any())
                {
                    <div class="profile-room-grid">
                        @foreach (var room in postedRooms)
                        {
                            <article class="profile-room-card">
                                <div class="profile-card-top">
                                    <div class="d-flex gap-3 align-items-start">
                                        <div class="profile-card-icon">
                                            <i class="bi bi-building-fill-check"></i>
                                        </div>
                                        <div>
                                            <h3 class="profile-card-title">@room.Title</h3>
                                            <p class="profile-card-meta">
                                                <i class="bi bi-geo-alt-fill me-1"></i>@room.Location
                                            </p>
                                        </div>
                                    </div>

                                    @if (!room.IsApproved)
                                    {
                                        <span class="profile-status-badge status-pending">
                                            <i class="bi bi-clock-fill"></i>
                                            Pending
                                        </span>
                                    }
                                    else if (room.IsAvailable)
                                    {
                                        <span class="profile-status-badge status-approved">
                                            <i class="bi bi-check-circle-fill"></i>
                                            Approved
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="profile-status-badge status-closed">
                                            <i class="bi bi-lock-fill"></i>
                                            Closed
                                        </span>
                                    }
                                </div>

                                <div class="profile-room-facts">
                                    <div class="profile-fact">
                                        <small>Rent</small>
                                        <strong>BDT @room.Price</strong>
                                    </div>
                                    <div class="profile-fact">
                                        <small>Posted</small>
                                        <strong>@room.CreatedAt.ToString("dd-MMM-yyyy")</strong>
                                    </div>
                                    <div class="profile-fact">
                                        <small>Status</small>
                                        <strong>@(room.IsApproved ? (room.IsAvailable ? "Live" : "Closed") : "Review")</strong>
                                    </div>
                                </div>

                                <div class="profile-actions">
                                    <a asp-controller="Room" asp-action="Details" asp-route-id="@room.Id" class="profile-mini-btn primary">
                                        <i class="bi bi-eye-fill"></i>
                                        View Details
                                    </a>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="profile-empty">
                        <div class="profile-empty-icon">
                            <i class="bi bi-house-exclamation-fill"></i>
                        </div>
                        <h3>You have not posted any rooms yet</h3>
                        <p>Create your first room listing so seekers can find and contact you.</p>
                        <a asp-controller="Room" asp-action="Create" class="profile-mini-btn primary">
                            <i class="bi bi-house-check-fill"></i>
                            Post Your First Room
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="profile-section">
            <div class="profile-panel">
                <div class="profile-section-head">
                    <div>
                        <h2 class="profile-section-title">
                            <i class="bi bi-bookmark-check-fill"></i>
                            My Booked Rooms
                        </h2>
                        <p class="profile-section-subtitle">Rooms you selected or booked as a seeker.</p>
                    </div>

                    <a asp-controller="Room" asp-action="Index" class="profile-mini-btn">
                        <i class="bi bi-search"></i>
                        Browse Rooms
                    </a>
                </div>

                @if (selections.Any())
                {
                    <div class="profile-booked-grid">
                        @foreach (var s in selections)
                        {
                            <article class="profile-booked-card">
                                <div class="profile-card-top">
                                    <div class="d-flex gap-3 align-items-start">
                                        <div class="profile-card-icon">
                                            <i class="bi bi-key-fill"></i>
                                        </div>
                                        <div>
                                            <h3 class="profile-card-title">@s.Room?.Title</h3>
                                            <p class="profile-card-meta">
                                                <i class="bi bi-person-workspace me-1"></i>Owner: @(s.Room?.Owner?.UserName ?? "Unknown")
                                            </p>
                                            <p class="profile-card-meta">
                                                <i class="bi bi-geo-alt-fill me-1"></i>@(s.Room?.Location ?? "Location unavailable")
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <div class="profile-room-facts">
                                    <div class="profile-fact">
                                        <small>Booked On</small>
                                        <strong>@s.SelectedAt.ToString("dd-MMM-yyyy")</strong>
                                    </div>
                                    <div class="profile-fact">
                                        <small>Time</small>
                                        <strong>@s.SelectedAt.ToString("hh:mm tt")</strong>
                                    </div>
                                    <div class="profile-fact">
                                        <small>Type</small>
                                        <strong>Selection</strong>
                                    </div>
                                </div>

                                <div class="profile-actions">
                                    @if (s.Room != null)
                                    {
                                        <a asp-controller="Room" asp-action="Details" asp-route-id="@s.RoomId" class="profile-mini-btn primary">
                                            <i class="bi bi-eye-fill"></i>
                                            View Room
                                        </a>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="profile-empty">
                        <div class="profile-empty-icon">
                            <i class="bi bi-search"></i>
                        </div>
                        <h3>You have not booked any rooms yet</h3>
                        <p>Browse available rooms and select the ones that match your location and budget.</p>
                        <a asp-controller="Room" asp-action="Index" class="profile-mini-btn primary">
                            <i class="bi bi-arrow-right"></i>
                            Browse Rooms
                        </a>
                    </div>
                }
            </div>
        </div>

    </div>
</section>

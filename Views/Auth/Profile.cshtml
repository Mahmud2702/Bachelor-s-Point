@model User
@{
    ViewData["Title"] = "My Profile";

    var postedRooms = ViewBag.PostedRooms as List<Room> ?? new List<Room>();
    var selections = ViewBag.Selections as List<RoomSelection> ?? new List<RoomSelection>();
    var incomingSelections = ViewBag.IncomingSelections as List<RoomSelection> ?? new List<RoomSelection>();

    bool hasPic = !string.IsNullOrWhiteSpace(Model.ProfilePicturePath);
    string displayName = !string.IsNullOrWhiteSpace(Model.FullName) ? Model.FullName : Model.UserName;
    string username = !string.IsNullOrWhiteSpace(Model.UserName) ? Model.UserName : "user";
    string roleName = Model.Role?.RoleName ?? "User";
    string addressText = !string.IsNullOrWhiteSpace(Model.Address) ? Model.Address : "Address not added";
    string phoneText = !string.IsNullOrWhiteSpace(Model.PhoneNumber) ? Model.PhoneNumber : "Phone not added";
    string lastLoginText = Model.LastLogin.HasValue ? Model.LastLogin.Value.ToString("dd-MMM-yyyy") : "Not recorded";

    int pendingPosted = postedRooms.Count(r => !r.IsApproved);
    int activePosted = postedRooms.Count(r => r.IsApproved && r.IsAvailable);
    int closedPosted = postedRooms.Count(r => r.IsApproved && !r.IsAvailable);
    int totalActivity = postedRooms.Count + selections.Count + incomingSelections.Count;

    string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";

        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        }

        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }

    string ShortText(string? text, int max = 70)
    {
        if (string.IsNullOrWhiteSpace(text)) return "No message added.";
        return text.Length <= max ? text : text.Substring(0, max) + "...";
    }
}


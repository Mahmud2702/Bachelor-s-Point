@model User
@{
    ViewData["Title"] = "My Profile";
    var postedRooms = ViewBag.PostedRooms as List<Room> ?? new List<Room>();
    var selections = ViewBag.Selections as List<RoomSelection> ?? new List<RoomSelection>();
    var incomingSelections = ViewBag.IncomingSelections as List<RoomSelection> ?? new List<RoomSelection>();
    bool hasPic = !string.IsNullOrEmpty(Model.ProfilePicturePath);
}

<style>
    .profile-avatar-wrapper {
        position: relative; display: inline-block;
        width: 96px; height: 96px;
    }
    .profile-pic {
        width: 96px; height: 96px; border-radius: 50%; object-fit: cover;
        border: 3px solid var(--border); display: block;
    }
    .profile-default-avatar {
        width: 96px; height: 96px; border-radius: 50%;
        background: var(--primary-light); color: var(--primary-dark);
        display: flex; align-items: center; justify-content: center;
        font-size: 2.6rem; border: 3px solid var(--border);
    }
    .profile-pic-edit {
        position: absolute; bottom: 0; right: 0;
        background: var(--primary); color: white;
        width: 32px; height: 32px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; box-shadow: 0 2px 6px rgba(17,24,68,0.3);
        font-size: 0.95rem; border: 3px solid var(--white);
        transition: background 0.15s ease;
    }
    .profile-pic-edit:hover { background: var(--primary-dark); }
    .request-message {
        background: var(--primary-light); border-left:3px solid var(--primary);
        padding: 0.5rem 0.75rem; border-radius: 6px; margin-top: 0.4rem;
    }
</style>

<div class="container">

    <!-- Profile header -->
    <div class="card stat-card mb-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center flex-wrap">

                <form asp-controller="Auth" asp-action="UploadProfilePicture" method="post"
                      enctype="multipart/form-data" id="profilePicForm" class="me-3">
                    @Html.AntiForgeryToken()
                    <div class="profile-avatar-wrapper">
                        @if (hasPic)
                        {
                            <img src="@Model.ProfilePicturePath" alt="Profile picture" class="profile-pic" />
                        }
                        else
                        {
                            <div class="profile-default-avatar">
                                <i class="bi bi-person-fill"></i>
                            </div>
                        }
                        <label for="profilePicInput" class="profile-pic-edit" title="Change profile picture">
                            <i class="bi bi-camera-fill"></i>
                        </label>
                        <input type="file" name="profilePicture" id="profilePicInput"
                               accept="image/jpeg,image/png,image/gif,image/webp"
                               onchange="document.getElementById('profilePicForm').submit();"
                               style="display:none;" />
                    </div>
                </form>

                <div class="flex-grow-1">
                    @if (!string.IsNullOrWhiteSpace(Model.FullName))
                    {
                        <h3 class="mb-0">@Model.FullName</h3>
                        <p class="text-muted mb-1" style="font-size: 0.9rem;">@@@Model.UserName</p>
                    }
                    else
                    {
                        <h3 class="mb-1">@Model.UserName</h3>
                    }
                    <p class="text-muted mb-1">
                        <i class="bi bi-envelope me-1"></i>@Model.Email
                    </p>
                    @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
                    {
                        <p class="text-muted mb-1">
                            <i class="bi bi-telephone me-1"></i>@Model.PhoneNumber
                        </p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Address))
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-geo-alt me-1"></i>@Model.Address
                        </p>
                    }
                    @if (hasPic)
                    {
                        <form asp-controller="Auth" asp-action="RemoveProfilePicture" method="post" class="mt-2"
                              onsubmit="return confirm('Remove your profile picture?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash me-1"></i>Remove picture
                            </button>
                        </form>
                    }
                </div>

                <div class="text-end d-flex flex-column align-items-end gap-2">
                    <a asp-action="EditProfile" class="btn-nx outline sm">
                        <i class="bi bi-pencil-square"></i> Edit Profile
                    </a>
                    <div class="small text-muted">
                        Role: <strong>@Model.Role?.RoleName</strong><br />
                        @if (Model.LastLogin.HasValue)
                        {
                            <span>Last login: @Model.LastLogin.Value.ToString("dd-MMM-yyyy")</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats — 3 cards now -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card stat-card">
                <div class="card-body text-center p-4">
                    <i class="bi bi-house-add-fill text-primary" style="font-size:2.2rem;"></i>
                    <h2 class="mt-2 mb-0">@postedRooms.Count</h2>
                    <p class="text-muted mb-0">Rooms Posted</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card">
                <div class="card-body text-center p-4">
                    <i class="bi bi-bookmark-check-fill text-success" style="font-size:2.2rem;"></i>
                    <h2 class="mt-2 mb-0">@selections.Count</h2>
                    <p class="text-muted mb-0">Rooms Booked</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card @(incomingSelections.Any() ? "border-warning" : "")">
                <div class="card-body text-center p-4">
                    <i class="bi bi-inbox-fill text-warning" style="font-size:2.2rem;"></i>
                    <h2 class="mt-2 mb-0">@incomingSelections.Count</h2>
                    <p class="text-muted mb-0">Booking Requests</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Booking Requests on My Rooms (NEW) -->
    <h4 class="mb-3 mt-4">
        <i class="bi bi-inbox me-2 text-warning"></i>Booking Requests on My Rooms
        @if (incomingSelections.Any())
        {
            <span class="badge bg-warning text-dark ms-2">@incomingSelections.Count</span>
        }
    </h4>
    @if (incomingSelections.Any())
    {
        <div class="card stat-card mb-4">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Room</th>
                            <th>Interested User</th>
                            <th>Email</th>
                            <th>When</th>
                            <th>Message</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in incomingSelections)
                        {
                            <tr>
                                <td><strong>@s.Room?.Title</strong></td>
                                <td>@s.Seeker?.UserName</td>
                                <td><small class="text-muted">@s.Seeker?.Email</small></td>
                                <td><small class="text-muted">@s.SelectedAt.ToString("dd-MMM-yyyy hh:mm tt")</small></td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(s.Message))
                                    {
                                        <span class="text-muted small">
                                            @(s.Message.Length > 40 ? s.Message.Substring(0, 40) + "..." : s.Message)
                                        </span>
                                    }
                                    else
                                    {
                                        <em class="text-muted small">No message</em>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="Room" asp-action="Details" asp-route-id="@s.RoomId"
                                       class="btn btn-sm btn-outline-primary">View</a>
                                    @if (s.Seeker != null)
                                    {
                                        <a asp-controller="Chat" asp-action="Conversation" asp-route-id="@s.SeekerUserId"
                                           class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-chat-dots"></i> Chat
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i> No one has selected your rooms yet.
        </div>
    }

    <!-- Posted Rooms -->
    <h4 class="mb-3 mt-4"><i class="bi bi-house-add-fill me-2"></i>My Posted Rooms</h4>
    @if (postedRooms.Any())
    {
        <div class="card stat-card mb-4">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Location</th>
                            <th>Price</th>
                            <th>Posted</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var room in postedRooms)
                        {
                            <tr>
                                <td>@room.Title</td>
                                <td>@room.Location</td>
                                <td>BDT @room.Price</td>
                                <td>@room.CreatedAt.ToString("dd-MMM-yyyy")</td>
                                <td>
                                    @if (!room.IsApproved)
                                    {
                                        <span class="badge-pending"><i class="bi bi-cash-coin"></i> Due Payment</span>
                                    }
                                    else if (room.IsAvailable)
                                    {
                                        <span class="badge bg-success">Live</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Closed</span>
                                    }
                                </td>
                                <td>
                                    @if (!room.IsApproved)
                                    {
                                        <form asp-controller="Payment" asp-action="PayRoomFee" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="roomId" value="@room.Id" />
                                            <button type="submit" class="btn btn-sm btn-warning">Pay Now</button>
                                        </form>
                                    }
                                    <a asp-controller="Room" asp-action="Details" asp-route-id="@room.Id" class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i> You haven't posted any rooms yet.
            <a asp-controller="Room" asp-action="Create" class="alert-link">Post your first room</a>.
        </div>
    }

    <!-- Booked Rooms (as seeker) -->
    <h4 class="mb-3 mt-4"><i class="bi bi-bookmark-check-fill me-2"></i>My Booked Rooms</h4>
    @if (selections.Any())
    {
        <div class="card stat-card mb-4">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Room</th>
                            <th>Owner</th>
                            <th>Location</th>
                            <th>Booked On</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in selections)
                        {
                            <tr>
                                <td>@s.Room?.Title</td>
                                <td>@s.Room?.Owner?.UserName</td>
                                <td>@s.Room?.Location</td>
                                <td>@s.SelectedAt.ToString("dd-MMM-yyyy hh:mm tt")</td>
                                <td>
                                    @if (s.Room != null)
                                    {
                                        <a asp-controller="Room" asp-action="Details" asp-route-id="@s.RoomId" class="btn btn-sm btn-outline-primary">View</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i> You haven't booked any rooms yet.
            <a asp-controller="Room" asp-action="Index" class="alert-link">Browse rooms</a>.
        </div>
    }

</div>

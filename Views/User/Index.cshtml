        gap: .65rem;
        align-items: center;
    }

    [data-theme="dark"] .mu-empty {
        background: rgba(234, 224, 207, .08);
        color: #cbd5e1;
    }

    @@media (max-width: 1199.98px) {
        .mu-stat-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .mu-hero {
            grid-template-columns: 1fr;
        }

        .mu-hero-panel {
            max-width: 520px;
        }
    }

    @@media (max-width: 991.98px) {
        .mu-user-table {
            min-width: 900px;
        }
    }

    @@media (max-width: 767.98px) {
        .manage-users-page {
            padding: .9rem .75rem 1.5rem;
        }

        .mu-hero {
            border-radius: 24px;
        }

        .mu-hero-actions {
            flex-direction: column;
        }

        .mu-btn {
            width: 100%;
        }

        .mu-panel-mini {
            grid-template-columns: 1fr;
        }

        .mu-stat-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .mu-section-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .mu-panel-top {
            flex-direction: column;
            align-items: flex-start;
        }

        .mu-table-wrap {
            overflow: visible;
        }

        .mu-user-table,
        .mu-user-table thead,
        .mu-user-table tbody,
        .mu-user-table th,
        .mu-user-table td,
        .mu-user-table tr {
            display: block;
            min-width: 0;
        }

            .mu-user-table thead {
                display: none;
            }

            .mu-user-table tbody {
                display: grid;
                gap: .85rem;
                padding: .9rem;
            }

                .mu-user-table tbody tr {
                    border-radius: 22px;
                    padding: .85rem;
                    background: rgba(255, 255, 255, .68);
                    border: 1px solid rgba(17, 24, 68, .10);
                    box-shadow: 0 14px 32px rgba(17, 24, 68, .08);
                }

        [data-theme="dark"] .mu-user-table tbody tr {
            background: rgba(255, 255, 255, .045);
            border-color: rgba(234, 224, 207, .10);
        }

        .mu-user-table tbody td {
            display: grid;
            grid-template-columns: 120px minmax(0, 1fr);
            gap: .75rem;
            align-items: center;
            padding: .55rem 0;
            border-bottom: 1px solid rgba(17, 24, 68, .07);
        }

        [data-theme="dark"] .mu-user-table tbody td {
            border-bottom-color: rgba(234, 224, 207, .08);
        }

        .mu-user-table tbody td:last-child {
            border-bottom: none;
        }

        .mu-user-table tbody td::before {
            content: attr(data-label);
            color: var(--mu-indigo);
            font-size: .72rem;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: .45px;
        }

        [data-theme="dark"] .mu-user-table tbody td::before {
            color: #EAE0CF;
        }

        .mu-actions {
            justify-content: flex-start;
        }
    }

    @@media (max-width: 575.98px) {
        .mu-stat-grid {
            grid-template-columns: 1fr;
        }

        .mu-user-table tbody td {
            grid-template-columns: 1fr;
            gap: .35rem;
        }

        .mu-hero h1 {
            font-size: 2rem;
        }
    }
</style>

<section class="manage-users-page">
    <div class="mu-shell">

        <div class="mu-hero">
            <div class="mu-hero-main">
                <div class="mu-kicker">
                    <i class="bi bi-people-fill"></i>
                    <span>User Administration</span>
                </div>

                <h1>Manage Users</h1>

                <p>
                    Review user accounts, roles, login activity, and account status from one organized admin workspace.
                </p>

                <div class="mu-hero-actions">
                    <a asp-controller="Home" asp-action="Index" class="mu-btn mu-btn-primary">
                        <i class="bi bi-cash-coin"></i>
                        Review Payments
                    </a>

                    <a asp-controller="Role" asp-action="Index" class="mu-btn mu-btn-soft">
                        <i class="bi bi-person-badge-fill"></i>
                        Manage Roles
                    </a>

                    <a asp-controller="Kyc" asp-action="LoginActivity" class="mu-btn mu-btn-soft">
                        <i class="bi bi-graph-up-arrow"></i>
                        Login Activity
                    </a>
                </div>
            </div>

            <div class="mu-hero-panel">
                <div class="mu-panel-number">
                    <div class="mu-panel-icon">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div>
                        <strong>@totalUsers</strong>
                        <span>registered account(s)</span>
                    </div>
                </div>

                <div class="mu-panel-mini">
                    <div>
                        <strong>@adminUsers</strong>
                        <small>Admins</small>
                    </div>
                    <div>
                        <strong>@regularUsers</strong>
                        <small>Users</small>
                    </div>
                    <div>
                        <strong>@recentlyActive</strong>
                        <small>Active 7d</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="mu-section">
            <div class="mu-section-head">
                <div>
                    <h2 class="mu-section-title">
                        <i class="bi bi-bar-chart-fill"></i>
                        User Overview
                    </h2>
                    <p class="mu-section-subtitle">Quick summary of registered accounts and platform activity.</p>
                </div>
            </div>

            <div class="mu-stat-grid">
                <div class="mu-stat-card">
                    <div class="mu-stat-icon">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <h3 class="mu-stat-value">@totalUsers</h3>
                    <p class="mu-stat-label">Total Users</p>
                    <p class="mu-stat-hint"S>All accounts registered on the platform.</p>
                </div>

                <div class="mu-stat-card">
                    <div class="mu-stat-icon">
                        <i class="bi bi-person-badge-fill"></i>
                    </div>
                    <h3 class="mu-stat-value">@adminUsers</h3>
                    <p class="mu-stat-label">Admins</p>
                    <p class="mu-stat-hint">Accounts with admin-level access.</p>
                </div>

                <div class="mu-stat-card">
                    <div class="mu-stat-icon">
                        <i class="bi bi-person-check-fill"></i>
                    </div>
                    <h3 class="mu-stat-value">@regularUsers</h3>
                    <p class="mu-stat-label">Regular Users</p>
                    <p class="mu-stat-hint">Room seekers and room owners.</p>
                </div>

                <div class="mu-stat-card">
                    <div class="mu-stat-icon">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <h3 class="mu-stat-value">@recentlyActive</h3>
                    <p class="mu-stat-label">Active Recently</p>
                    <p class="mu-stat-hint">Users who logged in within 7 days.</p>
                </div>

                <div class="mu-stat-card">
                    <div class="mu-stat-icon">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <h3 class="mu-stat-value">@verifiedPayments</h3>
                    <p class="mu-stat-label">Payment Verified</p>
                    <p class="mu-stat-hint">Accounts with verified payment status.</p>
                </div>
            </div>
        </div>

        <div class="mu-section">
            <div class="mu-user-panel">
                <div class="mu-panel-top">
                    <div>
                        <h2 class="mu-panel-title">
                            <i class="bi bi-person-lines-fill"></i>
                            User Directory
                        </h2>
                        <p class="mu-section-subtitle">View user identity, role, login status, and available account actions.</p>
                    </div>

                    <span class="mu-badge">
                        <i class="bi bi-database-fill"></i>
                        @totalUsers record(s)
                    </span>
                </div>

                @if (!users.Any())
                {
                    <div class="p-3">
                        <div class="mu-empty">
                            <i class="bi bi-info-circle-fill"></i>
                            <span>No users found in the system.</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="mu-table-wrap">
                        <table class="mu-user-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>User</th>
                                    <th>Email</th>
                                    <th>Address</th>
                                    <th>Role</th>
                                    <th>Payment</th>
                                    <th>Last Login</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in users)
                                {
                                    var roleName = user.Role?.RoleName ?? "User";
                                    var roleClass = GetRoleClass(user);

                                    <tr>
                                        <td data-label="ID">
                                            <span class="mu-user-id">@user.Id</span>
                                        </td>

                                        <td data-label="User">
                                            <div class="mu-user-main">
                                                <div class="mu-avatar">
                                                    @if (!string.IsNullOrWhiteSpace(user.ProfilePicturePath))
                                                    {
                                                        <img src="@user.ProfilePicturePath" alt="@user.UserName" />
                                                    }
                                                    else
                                                    {
                                                        @GetInitials(user)
                                                    }
                                                </div>

                                                <div>
                                                    <span class="mu-user-name">@(user.FullName ?? user.UserName)</span>
                                                    <span class="mu-user-sub">@@@user.UserName</span>
                                                </div>
                                            </div>
                                        </td>

                                        <td data-label="Email">
                                            <span class="mu-email" title="@user.Email">
                                                <i class="bi bi-envelope-fill"></i>
                                                @user.Email
                                            </span>
                                        </td>

                                        <td data-label="Address">
                                            <span class="mu-address" title="@(user.Address ?? "No address")">
                                                <i class="bi bi-geo-alt-fill"></i>
                                                @(string.IsNullOrWhiteSpace(user.Address) ? "No address" : user.Address)
                                            </span>
                                        </td>

                                        <td data-label="Role">
                                            <span class="mu-role-pill @roleClass">
                                                <i class="bi @(roleClass == "admin" ? "bi-person-badge-fill" : "bi-person-fill")"></i>
                                                @roleName
                                            </span>
                                        </td>

                                        <td data-label="Payment">
                                            @if (user.IsPaymentVerified)
                                            {
                                                <span class="mu-pay-status verified">
                                                    <i class="bi bi-check-circle-fill"></i>
                                                    Verified
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="mu-pay-status pending">
                                                    <i class="bi bi-clock-fill"></i>
                                                    Pending
                                                </span>
                                            }
                                        </td>

                                        <td data-label="Last Login">
                                            <span class="mu-login">
                                                <i class="bi bi-box-arrow-in-right"></i>
                                                @FormatLastLogin(user.LastLogin)
                                            </span>
                                        </td>

                                        <td data-label="Actions">
                                            <div class="mu-actions">
                                                <a asp-action="Details"
                                                   asp-route-id="@user.Id"
                                                   class="mu-action-btn mu-action-details"
                                                   title="View details"
                                                   aria-label="View details for @user.UserName">
                                                    <i class="bi bi-eye-fill"></i>
                                                </a>

                                                <a asp-action="Edit"
                                                   asp-route-id="@user.Id"
                                                   class="mu-action-btn mu-action-edit"
                                                   title="Edit user"
                                                   aria-label="Edit @user.UserName">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>

                                                <a asp-action="Delete"
                                                   asp-route-id="@user.Id"
                                                   class="mu-action-btn mu-action-delete"
                                                   title="Delete user"
                                                   aria-label="Delete @user.UserName">
                                                    <i class="bi bi-trash-fill"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>
</section>

@model Role
@{
    ViewData["Title"] = "Edit Role";
}

<div class="container py-4" style="max-width:640px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div style="width:48px;height:48px;border-radius:var(--radius-lg);background:linear-gradient(135deg,var(--primary-dark),var(--primary));display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.3rem;flex-shrink:0;">
            <i class="bi bi-pencil-square"></i>
        </div>
        <div>
            <h2 style="font-weight:800;margin:0;font-size:1.5rem;">Edit Role</h2>
            <p style="color:var(--muted);margin:0;font-size:.88rem;">Update role name and description.</p>
        </div>
    </div>

    <div class="nx-card p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-4">
                <label asp-for="RoleName" class="form-label fw-semibold"></label>
                <input asp-for="RoleName" class="form-control form-control-lg" placeholder="e.g. Admin, User, Moderator" />
                <span asp-validation-for="RoleName" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="RoleDescription" class="form-label fw-semibold"></label>
                <textarea asp-for="RoleDescription" class="form-control" rows="4" placeholder="Describe what this role can do..."></textarea>
                <span asp-validation-for="RoleDescription" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 pt-2">
                <button type="submit" class="btn-nx success">
                    <i class="bi bi-check-lg"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn-nx outline">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

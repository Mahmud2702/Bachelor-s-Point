@model IEnumerable<Role>
@{
    ViewData["Title"] = "Manage Roles";

    var roles = Model?.ToList() ?? new List<Role>();
    int totalRoles = roles.Count;
    int adminRoles = roles.Count(r => (r.RoleName ?? "").Contains("admin", StringComparison.OrdinalIgnoreCase));
    int userRoles = roles.Count(r => (r.RoleName ?? "").Contains("user", StringComparison.OrdinalIgnoreCase));
    int customRoles = Math.Max(totalRoles - adminRoles - userRoles, 0);

    string GetRoleIcon(string? roleName)
    {
        var name = roleName ?? "";

        if (name.Contains("admin", StringComparison.OrdinalIgnoreCase))
        {
            return "fa-user-shield";
        }

        if (name.Contains("user", StringComparison.OrdinalIgnoreCase))
        {
            return "fa-user-check";
        }

        if (name.Contains("owner", StringComparison.OrdinalIgnoreCase))
        {
            return "fa-house-user";
        }

        if (name.Contains("moderator", StringComparison.OrdinalIgnoreCase))
        {
            return "fa-user-lock";
        }

        return "fa-id-badge";
    }

    string GetRoleType(string? roleName)
    {
        var name = roleName ?? "";

        if (name.Contains("admin", StringComparison.OrdinalIgnoreCase))
        {
            return "Administrator";
        }

        if (name.Contains("user", StringComparison.OrdinalIgnoreCase))
        {
            return "General User";
        }

        return "Custom Role";
    }

    string GetRoleHint(string? roleName)
    {
        var name = roleName ?? "";

        if (name.Contains("admin", StringComparison.OrdinalIgnoreCase))
        {
            return "Full system control and administrative access.";
        }

        if (name.Contains("user", StringComparison.OrdinalIgnoreCase))
        {
            return "Standard platform access for regular users.";
        }

        return "Custom permission group for special access.";
    }
}


    @@media (max-width: 1199.98px) {
        .roles-hero-content {
            grid-template-columns: 1fr;
        }

        .roles-status-panel {
            max-width: 520px;
        }

        .roles-stat-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 767.98px) {
        .roles-admin-page {
            padding: .85rem .75rem 1.4rem;
        }

        .roles-hero {
            border-radius: 24px;
        }

        .roles-hero-actions {
            flex-direction: column;
        }

        .roles-btn {
            width: 100%;
        }

        .roles-status-mini {
            grid-template-columns: 1fr;
        }

        .roles-section-head,
        .roles-panel-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .roles-count-pill {
            width: 100%;
            justify-content: center;
        }

        .roles-table-wrap {
            overflow: visible;
        }

        .roles-table,
        .roles-table thead,
        .roles-table tbody,
        .roles-table tr,
        .roles-table th,
        .roles-table td {
            display: block;
            width: 100%;
        }

            .roles-table thead {
                display: none;
            }

            .roles-table tbody {
                display: grid;
                gap: .85rem;
                padding: .85rem;
            }

                .roles-table tbody tr {
                    border-radius: 20px;
                    background: rgba(255, 255, 255, .66);
                    border: 1px solid rgba(17, 24, 68, .08);
                    box-shadow: 0 14px 30px rgba(17, 24, 68, .08);
                    overflow: hidden;
                }

        [data-theme="dark"] .roles-table tbody tr {
            background: rgba(255, 255, 255, .045);
            border-color: rgba(234, 224, 207, .09);
        }

        .roles-table tbody td {
            display: grid;
            grid-template-columns: 110px minmax(0, 1fr);
            gap: .75rem;
            align-items: center;
            padding: .75rem .9rem;
            border-bottom: 1px solid rgba(17, 24, 68, .08);
        }

        [data-theme="dark"] .roles-table tbody td {
            border-bottom-color: rgba(234, 224, 207, .08);
        }

        .roles-table tbody td::before {
            content: attr(data-label);
            color: var(--role-bluegray);
            font-size: .72rem;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .role-main-cell,
        .role-description {
            min-width: 0;
        }

        .role-actions {
            flex-wrap: wrap;
        }
    }

    @@media (max-width: 575.98px) {
        .roles-stat-grid {
            grid-template-columns: 1fr;
        }

        .roles-table tbody td {
            grid-template-columns: 1fr;
            gap: .35rem;
        }
    }
</style>

<section class="roles-admin-page">
    <div class="roles-shell">

        <div class="roles-hero">
            <div class="roles-hero-content">
                <div>
                    <div class="roles-kicker">
                        <i class="fa-solid fa-user-shield"></i>
                        <span>Role Access Control</span>
                    </div>

                    <h1>Manage Roles</h1>

                    <p>
                        Create, review, and maintain platform roles so every user gets the correct level of access inside Bachelor&apos;s Point.
                    </p>

                    <div class="roles-hero-actions">
                        <a asp-action="Create" class="roles-btn roles-btn-primary">
                            <i class="fa-solid fa-circle-plus"></i>
                            Create New Role
                        </a>

                        <a asp-controller="User" asp-action="Index" class="roles-btn roles-btn-soft">
                            <i class="fa-solid fa-users-gear"></i>
                            Manage Users
                        </a>
                    </div>
                </div>

                <div class="roles-status-panel">
                    <div class="roles-status-top">
                        <div class="roles-status-icon">
                            <i class="fa-solid fa-shield-halved"></i>
                        </div>
                        <div>
                            <div class="roles-status-number">@totalRoles</div>
                            <span>role record(s) configured</span>
                        </div>
                    </div>

                    <div class="roles-status-mini">
                        <div>
                            <strong>@adminRoles</strong>
                            <small>Admin</small>
                        </div>
                        <div>
                            <strong>@userRoles</strong>
                            <small>User</small>
                        </div>
                        <div>
                            <strong>@customRoles</strong>
                            <small>Custom</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="roles-section">
            <div class="roles-section-head">
                <div>
                    <h2 class="roles-section-title">
                        <i class="fa-solid fa-chart-simple"></i>
                        Role Overview
                    </h2>
                    <p class="roles-section-subtitle">Quick summary of access groups currently available in the system.</p>
                </div>
            </div>

            <div class="roles-stat-grid">
                <div class="roles-stat-card">
                    <div class="roles-stat-icon">
                        <i class="fa-solid fa-layer-group"></i>
                    </div>
                    <h3 class="roles-stat-value">@totalRoles</h3>
                    <p class="roles-stat-label">Total Roles</p>
                    <p class="roles-stat-hint">All configured permission groups.</p>
                </div>

                <div class="roles-stat-card">
                    <div class="roles-stat-icon">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>
                    <h3 class="roles-stat-value">@adminRoles</h3>
                    <p class="roles-stat-label">Admin Roles</p>
                    <p class="roles-stat-hint">Roles with elevated system control.</p>
                </div>

                <div class="roles-stat-card">
                    <div class="roles-stat-icon">
                        <i class="fa-solid fa-user-check"></i>
                    </div>
                    <h3 class="roles-stat-value">@userRoles</h3>
                    <p class="roles-stat-label">User Roles</p>
                    <p class="roles-stat-hint">Standard platform access groups.</p>
                </div>

                <div class="roles-stat-card">
                    <div class="roles-stat-icon">
                        <i class="fa-solid fa-id-badge"></i>
                    </div>
                    <h3 class="roles-stat-value">@customRoles</h3>
                    <p class="roles-stat-label">Custom Roles</p>
                    <p class="roles-stat-hint">Special roles outside default access.</p>
                </div>
            </div>
        </div>

        <div class="roles-section">
            <div class="roles-panel">
                <div class="roles-panel-header">
                    <div class="roles-panel-heading">
                        <div class="roles-panel-icon">
                            <i class="fa-solid fa-shield-virus"></i>
                        </div>
                        <div>
                            <h2>Role Directory</h2>
                            <p>Review role names, descriptions, and access-control records.</p>
                        </div>
                    </div>

                    <span class="roles-count-pill">
                        <i class="fa-solid fa-database"></i>
                        @totalRoles records
                    </span>
                </div>

                @if (!roles.Any())
                {
                    <div class="roles-empty">
                        <div class="roles-empty-icon">
                            <i class="fa-solid fa-user-lock"></i>
                        </div>
                        <h3>No roles found</h3>
                        <p>No access roles are configured yet. Create the first role to start managing permissions.</p>
                        <a asp-action="Create" class="roles-btn roles-btn-primary">
                            <i class="fa-solid fa-circle-plus"></i>
                            Create New Role
                        </a>
                    </div>
                }
                else
                {
                    <div class="roles-table-wrap">
                        <table class="roles-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Role</th>
                                    <th>Description</th>
                                    <th>Access Type</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var role in roles)
                                {
                                    string roleIcon = GetRoleIcon(role.RoleName);
                                    string roleType = GetRoleType(role.RoleName);
                                    string roleHint = GetRoleHint(role.RoleName);

                                    <tr>
                                        <td data-label="ID">
                                            <span class="role-id-chip">@role.Id</span>
                                        </td>

                                        <td data-label="Role">
                                            <div class="role-main-cell">
                                                <div class="role-avatar">
                                                    <i class="fa-solid @roleIcon"></i>
                                                </div>
                                                <div>
                                                    <p class="role-name-text">@role.RoleName</p>
                                                    <p class="role-type-text">@roleType</p>
                                                </div>
                                            </div>
                                        </td>

                                        <td data-label="Description">
                                            <div class="role-description">
                                                <i class="fa-solid fa-align-left"></i>
                                                <span>@(string.IsNullOrWhiteSpace(role.RoleDescription) ? "No description provided for this role." : role.RoleDescription)</span>
                                            </div>
                                        </td>

                                        <td data-label="Access">
                                            <span class="role-security-badge">
                                                <i class="fa-solid fa-key"></i>
                                                @roleHint
                                            </span>
                                        </td>

                                        <td data-label="Actions">
                                            <div class="role-actions">
                                                <a asp-action="Details"
                                                   asp-route-id="@role.Id"
                                                   class="role-action-btn role-action-details"
                                                   title="View details"
                                                   aria-label="View details for @role.RoleName">
                                                    <i class="fa-solid fa-eye"></i>
                                                </a>

                                                <a asp-action="Edit"
                                                   asp-route-id="@role.Id"
                                                   class="role-action-btn role-action-edit"
                                                   title="Edit role"
                                                   aria-label="Edit @role.RoleName">
                                                    <i class="fa-solid fa-pen-to-square"></i>
                                                </a>

                                                <a asp-action="Delete"
                                                   asp-route-id="@role.Id"
                                                   class="role-action-btn role-action-delete"
                                                   title="Delete role"
                                                   aria-label="Delete @role.RoleName">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>
</section>
a
@model IEnumerable<Bachelor_s_Point.Models.ChatMessage>
@{
    var otherUser = ViewBag.OtherUser as Bachelor_s_Point.Models.User;
    int currentUserId = (int)ViewBag.CurrentUserId;
    ViewData["Title"] = $"Chat with {otherUser?.UserName}";
}

<style>
    .chat-window {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(44, 62, 80, 0.06);
        max-width: 760px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 200px);
        min-height: 480px;
    }
    .chat-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #eef1f4;
        display: flex;
        align-items: center;
        background: linear-gradient(90deg, #2c3e50 0%, #4a6075 100%);
        color: #fff;
        border-radius: 14px 14px 0 0;
    }
    .chat-header-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        object-fit: cover;
        margin-right: 0.75rem;
        border: 2px solid rgba(255,255,255,0.4);
    }
    .chat-header-default {
        width: 42px; height: 42px; border-radius: 50%;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; margin-right: 0.75rem;
    }
    .chat-body {
        flex: 1;
        overflow-y: auto;
        padding: 1.25rem;
        background: #f6f8fb;
    }
    .message-row {
        display: flex;
        margin-bottom: 0.6rem;
    }
    .message-row.mine { justify-content: flex-end; }
    .message-bubble {
        max-width: 70%;
        padding: 0.6rem 0.95rem;
        border-radius: 18px;
        word-wrap: break-word;
        white-space: pre-wrap;
    }
    .message-row.mine .message-bubble {
        background: #2563eb;
        color: #fff;
        border-bottom-right-radius: 4px;
    }
    .message-row.theirs .message-bubble {
        background: #fff;
        color: #1f2937;
        border: 1px solid #e3e8ef;
        border-bottom-left-radius: 4px;
    }
    .message-time {
        font-size: 0.7rem;
        opacity: 0.8;
        margin-top: 0.2rem;
    }
    .message-row.mine .message-time { color: rgba(255,255,255,0.85); text-align: right; }
    .message-row.theirs .message-time { color: #9ca3af; }
    .chat-footer {
        padding: 0.75rem 1rem;
        border-top: 1px solid #eef1f4;
        background: #fff;
        border-radius: 0 0 14px 14px;
    }
    .chat-footer textarea {
        resize: none;
        border-radius: 10px;
    }
</style>

<div class="container">
    <div class="chat-window">
        <div class="chat-header">
            <a asp-action="Index" class="text-white me-2" title="Back to messages" style="text-decoration:none;">
                <i class="bi bi-arrow-left"></i>
            </a>
            @if (!string.IsNullOrEmpty(otherUser?.ProfilePicturePath))
            {
                <img src="@otherUser.ProfilePicturePath" alt="@otherUser?.UserName" class="chat-header-avatar" />
            }
            else
            {
                <div class="chat-header-default"><i class="bi bi-person-fill"></i></div>
            }
            <div>
                <div style="font-weight:600;">@otherUser?.UserName</div>
                <div style="font-size:0.8rem; opacity:0.8;">@otherUser?.Email</div>
            </div>
        </div>

        <div class="chat-body" id="chatBody">
            @if (!Model.Any())
            {
                <div class="text-center text-muted mt-4">
                    <i class="bi bi-chat-text" style="font-size: 2.5rem; opacity: 0.4;"></i>
                    <p class="mt-2">No messages yet. Say hello!</p>
                </div>
            }
            else
            {
                @foreach (var msg in Model)
                {
                    bool mine = msg.SenderId == currentUserId;
                    <div class="message-row @(mine ? "mine" : "theirs")">
                        <div class="message-bubble">
                            <div>@msg.Content</div>
                            <div class="message-time">@msg.SentAt.ToString("dd-MMM hh:mm tt")</div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="chat-footer">
            <form asp-action="Send" method="post" id="sendForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="receiverId" value="@otherUser?.Id" />
                <div class="input-group">
                    <textarea name="content" rows="1" class="form-control"
                              placeholder="Type a message..."
                              maxlength="2000" required
                              onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault();document.getElementById('sendForm').submit();}"></textarea>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
                <small class="text-muted">Press Enter to send, Shift+Enter for new line.</small>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-scroll to bottom on load
        (function() {
            const body = document.getElementById('chatBody');
            if (body) body.scrollTop = body.scrollHeight;
        })();
    </script>
}

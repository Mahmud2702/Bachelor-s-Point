<section class="messages-page">
    <div class="messages-shell">

        <div class="messages-hero">
            <div class="messages-hero-content">
                <div>
                    <div class="messages-kicker">
                        <i class="bi bi-chat-dots-fill"></i>
                        <span>Conversation Hub</span>
                    </div>

                    <h1 class="messages-title">Messages</h1>

                    <p class="messages-subtitle">
                        Manage every room-related conversation in one place. Keep owner, renter, and applicant communication organized and easy to follow.
                    </p>

                    <div class="messages-hero-actions">
                        <a asp-controller="Room" asp-action="Index" class="msg-btn msg-btn-primary">
                            <i class="bi bi-pin-map-fill"></i>
                            Browse Rooms
                        </a>

                        <a asp-controller="Home" asp-action="Index" class="msg-btn msg-btn-soft">
                            <i class="bi bi-layout-split"></i>
                            Dashboard
                        </a>
                    </div>
                </div>

                <div class="messages-status-panel">
                    <div class="messages-status-top">
                        <div>
                            <div class="messages-status-count">@unreadTotal</div>
                            <div class="messages-status-label">unread message(s)</div>
                        </div>
                        <div class="messages-status-icon">
                            <i class="bi bi-envelope-open-fill"></i>
                        </div>
                    </div>

                    <div class="messages-status-grid">
                        <div class="messages-status-mini">
                            <strong>@totalConversations</strong>
                            <span>Threads</span>
                        </div>
                        <div class="messages-status-mini">
                            <strong>@sentByMeCount</strong>
                            <span>Replied</span>
                        </div>
                        <div class="messages-status-mini">
                            <strong>@(latestConversation == null ? "—" : TimeLabel(latestConversation.LastSentAt))</strong>
                            <span>Latest</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="messages-section">
            <div class="messages-grid">
                <div>
                    <div class="messages-section-head">
                        <div>
                            <h2 class="messages-section-title">
                                <i class="bi bi-chat-text-fill"></i>
                                Conversation List
                            </h2>
                            <p class="messages-section-subtitle">
                                @(totalConversations == 0 ? "No active threads yet." : $"Showing {totalConversations} active conversation(s).")
                            </p>
                        </div>
                    </div>

                    @if (!conversations.Any())
                    {
                        <div class="empty-message-panel">
                            <div class="empty-message-icon">
                                <i class="bi bi-chat-dots"></i>
                            </div>

                            <h3>No conversations yet</h3>
                            <p>
                                Conversations will appear here after you start chatting from a room details page or a booking-related interaction.
                            </p>

                            <a asp-controller="Room" asp-action="Index" class="msg-btn msg-btn-primary">
                                <i class="bi bi-house-check-fill"></i>
                                Explore Rooms
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="messages-panel">
                            <div class="chat-list-card">
                                @foreach (var convo in conversations)
                                {
                                    <a asp-action="Conversation" asp-route-id="@convo.OtherUser.Id" class="chat-list-item">
                                        @if (!string.IsNullOrEmpty(convo.OtherUser.ProfilePicturePath))
                                        {
                                            <img src="@convo.OtherUser.ProfilePicturePath" alt="@convo.OtherUser.UserName" class="chat-avatar" />
                                        }
                                        else
                                        {
                                            <div class="chat-avatar-default">@Initials(convo.OtherUser.UserName)</div>
                                        }

                                        <div class="chat-meta">
                                            <div class="chat-name-line">
                                                <h3 class="chat-name">@convo.OtherUser.UserName</h3>
                                                @if (convo.UnreadCount > 0)
                                                {
                                                    <span class="chat-chip">
                                                        <i class="bi bi-bell-fill"></i>
                                                        New
                                                    </span>
                                                }
                                            </div>

                                            <div class="chat-last-msg">
                                                @if (convo.LastMessageFromMe)
                                                {
                                                    <span class="you-label">You:</span>
                                                }
                                                @ShortMessage(convo.LastMessage)
                                            </div>
                                        </div>

                                        <div class="chat-right">
                                            <div class="chat-time">
                                                <i class="bi bi-clock"></i>
                                                @TimeLabel(convo.LastSentAt)
                                            </div>

                                            @if (convo.UnreadCount > 0)
                                            {
                                                <span class="unread-badge">@convo.UnreadCount</span>
                                            }
                                            else
                                            {
                                                <span class="open-chat-icon">
                                                    <i class="bi bi-arrow-right"></i>
                                                </span>
                                            }
                                        </div>
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>

                <aside class="messages-side-panel">
                    <div class="messages-side-card">
                        <h3 class="messages-side-title">
                            <i class="bi bi-bar-chart-fill"></i>
                            Message Summary
                        </h3>

                        <div class="msg-tip-list">
                            <div class="msg-tip-item">
                                <div class="msg-tip-icon">
                                    <i class="bi bi-chat-dots-fill"></i>
                                </div>
                                <div>
                                    <strong>@totalConversations conversation(s)</strong>
                                    <span>Total loaded message threads in your inbox.</span>
                                </div>
                            </div>

                            <div class="msg-tip-item">
                                <div class="msg-tip-icon">
                                    <i class="bi bi-envelope-check-fill"></i>
                                </div>
                                <div>
                                    <strong>@unreadTotal unread message(s)</strong>
                                    <span>Unread messages that may need your attention.</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>

    </div>
</section>

@model IEnumerable<Bachelor_s_Point.Application.DTOs.ConversationSummary>
@{
    ViewData["Title"] = "Messages";

    var conversations = (Model ?? Enumerable.Empty<Bachelor_s_Point.Application.DTOs.ConversationSummary>())
        .OrderByDescending(c => c.LastSentAt)
        .ToList();

    int totalConversations = conversations.Count;
    int unreadTotal = conversations.Sum(c => c.UnreadCount);
    int sentByMeCount = conversations.Count(c => c.LastMessageFromMe);
    var latestConversation = conversations.FirstOrDefault();

    string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }

    string ShortMessage(string? message, int max = 92)
    {
        if (string.IsNullOrWhiteSpace(message)) return "No message preview available.";
        return message.Length <= max ? message : message.Substring(0, max) + "...";
    }

    string TimeLabel(DateTime dateTime)
    {
        var today = DateTime.Now.Date;
        if (dateTime.Date == today) return dateTime.ToString("hh:mm tt");
        if (dateTime.Date == today.AddDays(-1)) return "Yesterday";
        return dateTime.ToString("dd MMM");
    }
}


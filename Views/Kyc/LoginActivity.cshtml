<section class="login-activity-page">
    <div class="la-shell">

        <div class="la-hero">
            <div class="la-hero-inner">
                <div>
                    <div class="la-kicker">
                        <i class="bi bi-activity"></i>
                        <span>Security Activity Monitor</span>
                    </div>

                    <h1>User Login Activity</h1>
                    <p>
                        Track recent sign-ins, identify active users, and monitor account access patterns from one security-focused admin view.
                    </p>

                    <div class="la-hero-pulse">
                        <span class="la-pill">
                            <i class="bi bi-box-arrow-in-right"></i>
                            @totalLogins total logins
                        </span>
                        <span class="la-pill">
                            <i class="bi bi-people-fill"></i>
                            @distinctUsers unique user(s)
                        </span>
                        <span class="la-pill">
                            <i class="bi bi-calendar-day-fill"></i>
                            @todayLogins today
                        </span>
                    </div>
                </div>

                <aside class="la-side-panel">
                    <div class="la-side-icon">
                        <i class="bi bi-shield-fill-check"></i>
                    </div>
                    <strong>@latestLoginText</strong>
                    <span>Latest recorded successful login</span>

                    <div class="la-side-mini">
                        <div>
                            <b>@adminLogins</b>
                            <small>Admin logins</small>
                        </div>
                        <div>
                            <b>@userLogins</b>
                            <small>User logins</small>
                        </div>
                    </div>
                </aside>
            </div>
        </div>

        <div class="la-section">
            <div class="la-section-head">
                <div>
                    <h2 class="la-title">
                        <i class="bi bi-bar-chart-fill"></i>
                        Activity Overview
                    </h2>
                    <p class="la-subtitle">Quick security numbers from recent and historical login records.</p>
                </div>
            </div>

            <div class="la-stat-grid">
                <div class="la-stat-card">
                    <div class="la-stat-icon">
                        <i class="bi bi-box-arrow-in-right"></i>
                    </div>
                    <h3 class="la-stat-value">@totalLogins</h3>
                    <p class="la-stat-label">Total Logins</p>
                    <p class="la-stat-hint">All successful sign-ins stored in login history.</p>
                </div>

                <div class="la-stat-card">
                    <div class="la-stat-icon">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <h3 class="la-stat-value">@distinctUsers</h3>
                    <p class="la-stat-label">Distinct Users</p>
                    <p class="la-stat-hint">Different accounts that logged in at least once.</p>
                </div>

                <div class="la-stat-card">
                    <div class="la-stat-icon">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>
                    <h3 class="la-stat-value">@todayLogins</h3>
                    <p class="la-stat-label">Today</p>
                    <p class="la-stat-hint">Login activity recorded for the current day.</p>
                </div>

                <div class="la-stat-card">
                    <div class="la-stat-icon">
                        <i class="bi bi-trophy-fill"></i>
                    </div>
                    <h3 class="la-stat-value">@busiestUserCount</h3>
                    <p class="la-stat-label">Top User</p>
                    <p class="la-stat-hint">@busiestUserName has the highest recent login count.</p>
                </div>
            </div>
        </div>

        <div class="la-section">
            <div class="la-main-grid">
                <div class="la-panel">
                    <div class="la-section-head">
                        <div>
                            <h2 class="la-title">
                                <i class="bi bi-graph-up"></i>
                                Recent Login Timeline
                            </h2>
                            <p class="la-subtitle">Showing @(rowOffset + 1)–@(rowOffset + Model.Count) of @totalRecords record(s).</p>
                        </div>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="la-empty">
                            <i class="bi bi-info-circle-fill"></i>
                            <span>No login records yet.</span>
                        </div>
                    }
                    else
                    {
                        <div class="la-table-wrap">
                            <table class="la-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>User</th>
                                        <th>Email</th>
                                        <th>Login Date</th>
                                        <th>Time</th>
                                        <th>Age</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int rowNum = rowOffset + 1;
                                    }
                                    @foreach (var l in Model)
                                    {
                                        string userName = l.User?.UserName ?? "Unknown";
                                        string email = l.Email ?? l.User?.Email ?? "No email";
                                        string roleName = l.User?.Role?.RoleName ?? "Account";

                                        <tr>
                                            <td>
                                                <span class="la-row-no">@rowNum</span>
                                            </td>
                                            <td>
                                                <div class="la-user-cell">
                                                    <span class="la-avatar">@Initials(userName, email)</span>
                                                    <div>
                                                        <span class="la-user-name">@userName</span>
                                                        <span class="la-user-role">
                                                            <i class="bi bi-person-badge-fill"></i>
                                                            @roleName
                                                        </span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="la-email">@email</span>
                                            </td>
                                            <td>
                                                <span class="la-date-badge">
                                                    <i class="bi bi-calendar3"></i>
                                                    @l.LoginAt.ToString("dd-MMM-yyyy")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="la-time-badge">
                                                    <i class="bi bi-clock-fill"></i>
                                                    @l.LoginAt.ToString("hh:mm tt")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="la-time-badge">
                                                    <i class="bi bi-hourglass-split"></i>
                                                    @TimeAgo(l.LoginAt)
                                                </span>
                                            </td>
                                        </tr>
                                        rowNum++;
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="la-mobile-list">
                            @{
                                int cardNum = rowOffset + 1;
                            }
                            @foreach (var l in Model)
                            {
                                string userName = l.User?.UserName ?? "Unknown";
                                string email = l.Email ?? l.User?.Email ?? "No email";
                                string roleName = l.User?.Role?.RoleName ?? "Account";

                                <article class="la-login-card">
                                    <div class="la-login-card-top">
                                        <div class="la-user-cell">
                                            <span class="la-avatar">@Initials(userName, email)</span>
                                            <div>
                                                <span class="la-user-name">@userName</span>
                                                <span class="la-user-role">
                                                    <i class="bi bi-person-badge-fill"></i>
                                                    @roleName
                                                </span>
                                            </div>
                                        </div>
                                        <span class="la-row-no">@cardNum</span>
                                    </div>

                                    <div class="la-login-card-meta">
                                        <span>
                                            <i class="bi bi-envelope-fill me-1"></i>
                                            @email
                                        </span>
                                        <span>
                                            <i class="bi bi-calendar3 me-1"></i>
                                            @l.LoginAt.ToString("dd-MMM-yyyy")
                                            <span class="mx-1">•</span>
                                            @l.LoginAt.ToString("hh:mm tt")
                                        </span>
                                        <span>
                                            <i class="bi bi-hourglass-split me-1"></i>
                                            @TimeAgo(l.LoginAt)
                                        </span>
                                    </div>
                                </article>
                                cardNum++;
                            }
                        </div>
                    }

                    @* ── Pagination ── *@
                    @if (totalPages > 1)
                    {
                        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;padding:1rem 1.25rem;border-top:1px solid var(--la-border);">
                            <span style="font-size:.84rem;color:var(--la-bluegray);">
                                Page <strong>@currentPage</strong> of <strong>@totalPages</strong>
                                &nbsp;·&nbsp; @totalRecords records
                            </span>

                            <div style="display:flex;gap:.4rem;flex-wrap:wrap;">
                                @* Previous *@
                                @if (currentPage > 1)
                                {
                                    <a asp-action="LoginActivity" asp-route-page="@(currentPage - 1)" asp-route-pageSize="@pageSize"
                                       style="padding:.4rem .85rem;border-radius:var(--radius-md);border:1.5px solid var(--la-border);background:var(--la-card);color:var(--la-navy);font-size:.83rem;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.3rem;">
                                        <i class="bi bi-chevron-left"></i> Prev
                                    </a>
                                }

                                @* Page numbers (show up to 5 around current) *@
                                @{
                                    int startPg = Math.Max(1, currentPage - 2);
                                    int endPg   = Math.Min(totalPages, startPg + 4);
                                    if (endPg - startPg < 4) startPg = Math.Max(1, endPg - 4);
                                }
                                @for (int p = startPg; p <= endPg; p++)
                                {
                                    bool isActive = p == currentPage;
                                    <a asp-action="LoginActivity" asp-route-page="@p" asp-route-pageSize="@pageSize"
                                       style="padding:.4rem .75rem;border-radius:var(--radius-md);border:1.5px solid @(isActive ? "var(--la-indigo)" : "var(--la-border)");background:@(isActive ? "var(--la-indigo)" : "var(--la-card)");color:@(isActive ? "#fff" : "var(--la-navy)");font-size:.83rem;font-weight:700;text-decoration:none;min-width:36px;text-align:center;">
                                        @p
                                    </a>
                                }

                                @* Next *@
                                @if (currentPage < totalPages)
                                {
                                    <a asp-action="LoginActivity" asp-route-page="@(currentPage + 1)" asp-route-pageSize="@pageSize"
                                       style="padding:.4rem .85rem;border-radius:var(--radius-md);border:1.5px solid var(--la-border);background:var(--la-card);color:var(--la-navy);font-size:.83rem;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.3rem;">
                                        Next <i class="bi bi-chevron-right"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>

    </div>
</section>

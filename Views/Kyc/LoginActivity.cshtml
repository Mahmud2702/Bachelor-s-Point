@model List<Bachelor_s_Point.Models.LoginHistory>
@{
    ViewData["Title"] = "Login Activity";

    int totalLogins = ViewBag.TotalLogins ?? 0;
    int distinctUsers = ViewBag.DistinctUsers ?? 0;
    int todayLogins = ViewBag.TodayLogins ?? 0;
    int currentPage  = ViewBag.CurrentPage ?? 1;
    int totalPages   = ViewBag.TotalPages ?? 1;
    int pageSize     = ViewBag.PageSize ?? 10;
    int totalRecords = ViewBag.TotalRecords ?? 0;
    int rowOffset    = (currentPage - 1) * pageSize;

    var recentLogin = Model.OrderByDescending(x => x.LoginAt).FirstOrDefault();
    string latestLoginText = recentLogin == null ? "No activity yet" : recentLogin.LoginAt.ToString("dd MMM yyyy, hh:mm tt");

    int adminLogins = Model.Count(x => string.Equals(x.User?.Role?.RoleName, "Admin", StringComparison.OrdinalIgnoreCase));
    int userLogins = Math.Max(0, totalLogins - adminLogins);

    var busiestUser = Model
        .GroupBy(x => x.User?.UserName ?? x.Email ?? "Unknown")
        .OrderByDescending(g => g.Count())
        .FirstOrDefault();

    string busiestUserName = busiestUser?.Key ?? "No user yet";
    int busiestUserCount = busiestUser?.Count() ?? 0;

    string Initials(string? name, string? email)
    {
        string source = !string.IsNullOrWhiteSpace(name) ? name : (email ?? "U");
        var parts = source.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        }
        return source.Substring(0, 1).ToUpper();
    }

    string TimeAgo(DateTime time)
    {
        var span = DateTime.Now - time;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} min ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} hr ago";
        if (span.TotalDays < 2) return "Yesterday";
        if (span.TotalDays < 30) return $"{(int)span.TotalDays} days ago";
        return time.ToString("dd MMM yyyy");
    }
}


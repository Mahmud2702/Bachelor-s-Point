        }

    .kyc-side-stack {
        display: grid;
        gap: 1rem;
    }

    .kyc-side-card {
        border-radius: 26px;
        padding: 1rem;
        background: var(--kyc-card);
        border: 1px solid var(--kyc-border);
        box-shadow: var(--kyc-shadow);
    }

    [data-theme="dark"] .kyc-side-card {
        background: rgba(17, 24, 68, .76);
        border-color: rgba(234, 224, 207, .11);
        box-shadow: 0 20px 60px rgba(0, 0, 0, .32);
    }

    .kyc-side-card h3 {
        margin: 0 0 .85rem;
        color: var(--kyc-navy);
        font-size: .98rem;
        font-weight: 950;
        letter-spacing: -.25px;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .kyc-side-card h3 i {
            color: var(--kyc-indigo);
        }

    [data-theme="dark"] .kyc-side-card h3 {
        color: #f8fafc;
    }

    .kyc-check-list {
        display: grid;
        gap: .65rem;
    }

    .kyc-check-item {
        display: flex;
        gap: .65rem;
        align-items: flex-start;
        padding: .68rem;
        border-radius: 17px;
        background: rgba(255, 255, 255, .58);
        border: 1px solid rgba(17, 24, 68, .08);
    }

    [data-theme="dark"] .kyc-check-item {
        background: rgba(255, 255, 255, .045);
        border-color: rgba(234, 224, 207, .09);
    }

    .kyc-check-icon {
        width: 34px;
        height: 34px;
        min-width: 34px;
        border-radius: 13px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        background: linear-gradient(135deg, var(--kyc-navy), var(--kyc-indigo));
    }

    .kyc-check-item strong {
        display: block;
        color: var(--kyc-navy);
        font-size: .82rem;
        font-weight: 950;
        margin-bottom: .1rem;
    }

    .kyc-check-item span {
        display: block;
        color: var(--kyc-indigo);
        font-size: .72rem;
        font-weight: 650;
        line-height: 1.35;
    }

    [data-theme="dark"] .kyc-check-item strong {
        color: #f8fafc;
    }

    [data-theme="dark"] .kyc-check-item span {
        color: #cbd5e1;
    }

    .kyc-latest {
        padding: .9rem;
        border-radius: 18px;
        background: radial-gradient(circle at 95% 5%, rgba(234, 224, 207, .38), transparent 32%), rgba(255, 255, 255, .58);
        border: 1px solid rgba(17, 24, 68, .08);
    }

    [data-theme="dark"] .kyc-latest {
        background: radial-gradient(circle at 95% 5%, rgba(234, 224, 207, .08), transparent 32%), rgba(255, 255, 255, .045);
        border-color: rgba(234, 224, 207, .09);
    }

    .kyc-latest .kyc-user-cell {
        min-width: 0;
    }

    .kyc-latest-time {
        margin-top: .8rem;
        color: var(--kyc-indigo);
        font-size: .78rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    [data-theme="dark"] .kyc-latest-time {
        color: #cbd5e1;
    }

    .kyc-empty {
        padding: clamp(1.4rem, 4vw, 2.4rem);
        text-align: center;
        background: radial-gradient(circle at 50% 0%, rgba(234, 224, 207, .50), transparent 36%), rgba(255, 255, 255, .58);
    }

    [data-theme="dark"] .kyc-empty {
        background: radial-gradient(circle at 50% 0%, rgba(234, 224, 207, .07), transparent 36%), rgba(255, 255, 255, .035);
    }

    .kyc-empty-icon {
        width: 76px;
        height: 76px;
        margin: 0 auto 1rem;
        border-radius: 24px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        background: linear-gradient(135deg, var(--kyc-navy), var(--kyc-indigo));
        box-shadow: 0 18px 40px rgba(17, 24, 68, .18), 0 0 0 7px rgba(234, 224, 207, .58);
        font-size: 1.8rem;
    }

    .kyc-empty h3 {
        margin: 0 0 .35rem;
        color: var(--kyc-navy);
        font-size: 1.25rem;
        font-weight: 950;
        letter-spacing: -.35px;
    }

    .kyc-empty p {
        max-width: 520px;
        margin: 0 auto;
        color: var(--kyc-indigo);
        font-size: .9rem;
        font-weight: 650;
        line-height: 1.5;
    }

    [data-theme="dark"] .kyc-empty h3 {
        color: #f8fafc;
    }

    [data-theme="dark"] .kyc-empty p {
        color: #cbd5e1;
    }

    .kyc-mobile-list {
        display: none;
        gap: .85rem;
        padding: 1rem;
    }

    .kyc-mobile-card {
        border-radius: 20px;
        padding: .95rem;
        background: rgba(255, 255, 255, .66);
        border: 1px solid rgba(17, 24, 68, .09);
    }

    [data-theme="dark"] .kyc-mobile-card {
        background: rgba(255, 255, 255, .045);
        border-color: rgba(234, 224, 207, .09);
    }

    .kyc-mobile-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .65rem;
        margin: .85rem 0;
    }

        .kyc-mobile-meta div {
            padding: .65rem;
            border-radius: 15px;
            background: rgba(234, 224, 207, .34);
            color: var(--kyc-navy);
            font-size: .76rem;
            font-weight: 850;
        }

        .kyc-mobile-meta span {
            display: block;
            color: var(--kyc-bluegray);
            font-size: .66rem;
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: .15rem;
        }

    [data-theme="dark"] .kyc-mobile-meta div {
        background: rgba(234, 224, 207, .07);
        color: #f8fafc;
    }

    @@media (max-width: 1199.98px) {
        .kyc-stat-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .kyc-hero-grid {
            grid-template-columns: 1fr;
        }

        .kyc-radar-panel {
            max-width: 560px;
        }
    }

    @@media (max-width: 991.98px) {
        .kyc-workspace {
            grid-template-columns: 1fr;
        }

        .kyc-side-stack {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 767.98px) {
        .kyc-admin-page {
            padding: .85rem .75rem 1.4rem;
        }

        .kyc-hero,
        .kyc-panel,
        .kyc-side-card {
            border-radius: 24px;
        }

        .kyc-hero-actions {
            flex-direction: column;
        }

        .kyc-btn {
            width: 100%;
        }

        .kyc-status-strip {
            grid-template-columns: 1fr;
        }

        .kyc-section-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .kyc-stat-grid,
        .kyc-side-stack {
            grid-template-columns: 1fr;
        }

        .kyc-table-wrap {
            display: none;
        }

        .kyc-mobile-list {
            display: grid;
        }
    }

    @@media (max-width: 575.98px) {
        .kyc-mobile-meta {
            grid-template-columns: 1fr;
        }

        .kyc-hero h1 {
            font-size: 2rem;
        }
    }
</style>

<section class="kyc-admin-page">
    <div class="kyc-admin-shell">

        <div class="kyc-hero">
            <div class="kyc-hero-grid">
                <div>
                    <div class="kyc-kicker">
                        <i class="fa-solid fa-fingerprint"></i>
                        <span>Identity Review Center</span>
                    </div>

                    <h1>KYC Verifications</h1>

                    <p>
                        Review identity submissions, compare NID information, and keep Bachelor’s Point safe for room owners and tenants.
                    </p>

                    <div class="kyc-hero-actions">
                        <a href="#kyc-submissions" class="kyc-btn kyc-btn-primary">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            Review Submissions
                        </a>

                        <a asp-controller="Kyc" asp-action="LoginActivity" class="kyc-btn kyc-btn-soft">
                            <i class="fa-solid fa-chart-line"></i>
                            Login Activity
                        </a>
                    </div>
                </div>

                <div class="kyc-radar-panel">
                    <div class="kyc-radar-icon">
                        <i class="fa-solid fa-id-card-clip"></i>
                    </div>

                    <div class="kyc-radar-number">@pendingCount</div>
                    <span>submission(s) waiting for review</span>

                    <div class="kyc-status-strip">
                        <div>
                            <strong>@pendingCount</strong>
                            <small>Pending</small>
                        </div>
                        <div>
                            <strong>@verifiedCount</strong>
                            <small>Verified</small>
                        </div>
                        <div>
                            <strong>@rejectedCount</strong>
                            <small>Rejected</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="kyc-section">
            <div class="kyc-section-head">
                <div>
                    <h2 class="kyc-section-title">
                        <i class="fa-solid fa-shield-heart"></i>
                        Verification Overview
                    </h2>
                    <p class="kyc-section-subtitle">A quick snapshot of identity verification workload and trust status.</p>
                </div>
            </div>

            <div class="kyc-stat-grid">
                <div class="kyc-stat-card pending">
                    <div class="kyc-stat-icon">
                        <i class="fa-solid fa-hourglass-half"></i>
                    </div>
                    <h3 class="kyc-stat-value">@pendingCount</h3>
                    <p class="kyc-stat-label">Pending Review</p>
                    <p class="kyc-stat-hint">Submissions waiting for admin verification.</p>
                </div>

                <div class="kyc-stat-card verified">
                    <div class="kyc-stat-icon">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <h3 class="kyc-stat-value">@verifiedCount</h3>
                    <p class="kyc-stat-label">Verified Users</p>
                    <p class="kyc-stat-hint">Users already approved after identity checks.</p>
                </div>

                <div class="kyc-stat-card rejected">
                    <div class="kyc-stat-icon">
                        <i class="fa-solid fa-circle-xmark"></i>
                    </div>
                    <h3 class="kyc-stat-value">@rejectedCount</h3>
                    <p class="kyc-stat-label">Rejected</p>
                    <p class="kyc-stat-hint">Submissions rejected for incorrect or unsafe data.</p>
                </div>

                <div class="kyc-stat-card">
                    <div class="kyc-stat-icon">
                        <i class="fa-solid fa-folder-open"></i>
                    </div>
                    <h3 class="kyc-stat-value">@totalCount</h3>
                    <p class="kyc-stat-label">Total Records</p>
                    <p class="kyc-stat-hint">All KYC submissions stored in the system.</p>
                </div>
            </div>
        </div>

        <div class="kyc-section" id="kyc-submissions">
            <div class="kyc-workspace">
                <div class="kyc-panel">
                    <div class="kyc-panel-header">
                        <h2>
                            <i class="fa-solid fa-user-check"></i>
                            Submitted Identity Records
                        </h2>

                        <span class="kyc-count-pill">
                            <i class="fa-solid fa-database"></i>
                            @totalCount record(s)
                        </span>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="kyc-empty">
                            <div class="kyc-empty-icon">
                                <i class="fa-solid fa-shield-circle-check"></i>
                            </div>
                            <h3>No KYC submissions yet</h3>
                            <p>
                                There are no identity verification requests at the moment. When users submit their NID and photo, they will appear here for review.
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="kyc-table-wrap">
                            <table class="kyc-table">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Name on NID</th>
                                        <th>NID Number</th>
                                        <th>Submitted</th>
                                        <th>Status</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var k in Model.OrderByDescending(x => x.Status == "Pending").ThenByDescending(x => x.SubmittedAt))
                                    {
                                        string displayName = k.User?.UserName ?? "Unknown User";
                                        string displayEmail = k.User?.Email ?? "No email found";
                                        string statusClass = StatusClass(k.Status);

                                        <tr>
                                            <td>
                                                <div class="kyc-user-cell">
                                                    @if (!string.IsNullOrWhiteSpace(k.UserPhotoPath))
                                                    {
                                                        <img src="@k.UserPhotoPath" class="kyc-avatar" alt="@displayName" />
                                                    }
                                                    else
                                                    {
                                                        <div class="kyc-avatar-fallback">@Initials(displayName, displayEmail)</div>
                                                    }

                                                    <div>
                                                        <div class="kyc-user-name">@displayName</div>
                                                        <div class="kyc-user-email">@displayEmail</div>
                                                    </div>
                                                </div>
                                            </td>

                                            <td>
                                                <div class="kyc-name-main">@k.FullNameOnNid</div>
                                                <div class="kyc-name-sub">
                                                    <i class="fa-solid fa-id-card me-1"></i>
                                                    NID holder name
                                                </div>
                                            </td>

                                            <td>
                                                <span class="kyc-nid-chip" title="@k.NidNumber">
                                                    <i class="fa-solid fa-lock"></i>
                                                    @MaskNid(k.NidNumber)
                                                </span>
                                            </td>

                                            <td>
                                                <span class="kyc-date">
                                                    <strong>@k.SubmittedAt.ToString("dd MMM yyyy")</strong>
                                                    <small>@TimeAgo(k.SubmittedAt)</small>
                                                </span>
                                            </td>

                                            <td>
                                                <span class="kyc-status-badge @statusClass">
                                                    <i class="@StatusIcon(k.Status)"></i>
                                                    @k.Status
                                                </span>
                                            </td>

                                            <td class="text-end">
                                                <a asp-action="Review" asp-route-id="@k.Id" class="kyc-action-btn">
                                                    <i class="fa-solid fa-eye"></i>
                                                    Review
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="kyc-mobile-list">
                            @foreach (var k in Model.OrderByDescending(x => x.Status == "Pending").ThenByDescending(x => x.SubmittedAt))
                            {
                                string displayName = k.User?.UserName ?? "Unknown User";
                                string displayEmail = k.User?.Email ?? "No email found";
                                string statusClass = StatusClass(k.Status);

                                <div class="kyc-mobile-card">
                                    <div class="kyc-user-cell">
                                        @if (!string.IsNullOrWhiteSpace(k.UserPhotoPath))
                                        {
                                            <img src="@k.UserPhotoPath" class="kyc-avatar" alt="@displayName" />
                                        }
                                        else
                                        {
                                            <div class="kyc-avatar-fallback">@Initials(displayName, displayEmail)</div>
                                        }

                                        <div>
                                            <div class="kyc-user-name">@displayName</div>
                                            <div class="kyc-user-email">@displayEmail</div>
                                        </div>
                                    </div>

                                    <div class="kyc-mobile-meta">
                                        <div>
                                            <span>Name on NID</span>
                                            @k.FullNameOnNid
                                        </div>
                                        <div>
                                            <span>NID Number</span>
                                            @MaskNid(k.NidNumber)
                                        </div>
                                        <div>
                                            <span>Submitted</span>
                                            @k.SubmittedAt.ToString("dd MMM yyyy")
                                        </div>
                                        <div>
                                            <span>Status</span>
                                            <span class="kyc-status-badge @statusClass">
                                                <i class="@StatusIcon(k.Status)"></i>
                                                @k.Status
                                            </span>
                                        </div>
                                    </div>

                                    <a asp-action="Review" asp-route-id="@k.Id" class="kyc-action-btn w-100">
                                        <i class="fa-solid fa-eye"></i>
                                        Review Submission
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>

                <aside class="kyc-side-stack">
                    <div class="kyc-side-card">
                        <h3>
                            <i class="fa-solid fa-list-check"></i>
                            Review Checklist
                        </h3>

                        <div class="kyc-check-list">
                            <div class="kyc-check-item">
                                <div class="kyc-check-icon">
                                    <i class="fa-solid fa-user"></i>
                                </div>
                                <div>
                                    <strong>Match user identity</strong>
                                    <span>Compare user photo with NID information before approving.</span>
                                </div>
                            </div>

                            <div class="kyc-check-item">
                                <div class="kyc-check-icon">
                                    <i class="fa-solid fa-id-card"></i>
                                </div>
                                <div>
                                    <strong>Check NID clarity</strong>
                                    <span>Reject blurry, cropped, fake, or unreadable identity documents.</span>
                                </div>
                            </div>

                            <div class="kyc-check-item">
                                <div class="kyc-check-icon">
                                    <i class="fa-solid fa-shield-halved"></i>
                                </div>
                                <div>
                                    <strong>Protect platform trust</strong>
                                    <span>Approve only when identity data looks consistent and safe.</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="kyc-side-card">
                        <h3>
                            <i class="fa-solid fa-clock-rotate-left"></i>
                            Latest Submission
                        </h3>

                        @if (latestSubmission == null)
                        {
                            <div class="kyc-empty" style="padding: 1rem; border-radius: 18px;">
                                <div class="kyc-empty-icon" style="width:56px;height:56px;font-size:1.25rem;border-radius:18px;">
                                    <i class="fa-solid fa-inbox"></i>
                                </div>
                                <h3 style="font-size:1rem;">Nothing yet</h3>
                                <p style="font-size:.78rem;">No users have submitted KYC documents.</p>
                            </div>
                        }
                        else
                        {
                            string latestName = latestSubmission.User?.UserName ?? "Unknown User";
                            string latestEmail = latestSubmission.User?.Email ?? "No email found";

                            <div class="kyc-latest">
                                <div class="kyc-user-cell">
                                    @if (!string.IsNullOrWhiteSpace(latestSubmission.UserPhotoPath))
                                    {
                                        <img src="@latestSubmission.UserPhotoPath" class="kyc-avatar" alt="@latestName" />
                                    }
                                    else
                                    {
                                        <div class="kyc-avatar-fallback">@Initials(latestName, latestEmail)</div>
                                    }

                                    <div>
                                        <div class="kyc-user-name">@latestName</div>
                                        <div class="kyc-user-email">@latestEmail</div>
                                    </div>
                                </div>

                                <div class="kyc-latest-time">
                                    <i class="fa-solid fa-calendar-check"></i>
                                    Submitted @TimeAgo(latestSubmission.SubmittedAt)
                                </div>

                                <a asp-action="Review" asp-route-id="@latestSubmission.Id" class="kyc-action-btn w-100 mt-3">
                                    <i class="fa-solid fa-eye"></i>
                                    Open Latest Record
                                </a>
                            </div>
                        }
                    </div>
                </aside>
            </div>
        </div>

    </div>
</section>

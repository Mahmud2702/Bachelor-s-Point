@model List<Bachelor_s_Point.Models.KycVerification>
@{
    ViewData["Title"] = "KYC Verifications";

    int pendingCount = ViewBag.PendingCount ?? Model.Count(k => k.Status == "Pending");
    int verifiedCount = ViewBag.VerifiedCount ?? Model.Count(k => k.Status == "Verified");
    int rejectedCount = ViewBag.RejectedCount ?? Model.Count(k => k.Status == "Rejected");
    int totalCount = Model.Count;

    var latestSubmission = Model
        .OrderByDescending(k => k.SubmittedAt)
        .FirstOrDefault();

    string Initials(string? name, string? email)
    {
        string source = !string.IsNullOrWhiteSpace(name) ? name! : email ?? "U";
        var parts = source.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length >= 2)
            return (parts[0][0].ToString() + parts[1][0].ToString()).ToUpperInvariant();

        return source.Length >= 2
            ? source.Substring(0, 2).ToUpperInvariant()
            : source.ToUpperInvariant();
    }

    string MaskNid(string? nid)
    {
        if (string.IsNullOrWhiteSpace(nid)) return "Not provided";
        string clean = nid.Trim();
        if (clean.Length <= 4) return clean;
        return new string('•', Math.Max(4, clean.Length - 4)) + clean[^4..];
    }

    string TimeAgo(DateTime date)
    {
        var span = DateTime.Now - date;

        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} min ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} hr ago";
        if (span.TotalDays < 2) return "Yesterday";
        if (span.TotalDays < 30) return $"{(int)span.TotalDays} days ago";

        return date.ToString("dd MMM yyyy");
    }

    string StatusClass(string status) => status switch
    {
        "Verified" => "verified",
        "Rejected" => "rejected",
        _ => "pending"
    };

    string StatusIcon(string status) => status switch
    {
        "Verified" => "fa-solid fa-circle-check",
        "Rejected" => "fa-solid fa-circle-xmark",
        _ => "fa-solid fa-hourglass-half"
    };
}


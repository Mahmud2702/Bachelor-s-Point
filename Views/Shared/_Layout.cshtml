@using Bachelor_s_Point.Application.Interfaces.Services
@inject IUserService UserService
@inject IChatService ChatService
@inject IRoomService RoomService
@{
    string? currentUserPic = null;
    int unreadCount = 0;
    int pendingRoomCount = 0;
    bool isAuthed = User.Identity != null && User.Identity.IsAuthenticated;
    bool isAdminUser = isAuthed && User.IsInRole("Admin");

    if (isAuthed)
    {
        var idClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(idClaim, out int currentUid))
        {
            var currentUser = await UserService.GetUserByIdAsync(currentUid);
            currentUserPic = currentUser?.ProfilePicturePath;
            unreadCount = await ChatService.GetUnreadCountAsync(currentUid);
        }

        if (isAdminUser)
        {
            var pending = await RoomService.GetPendingApprovalAsync();
            pendingRoomCount = pending.Count;
        }
    }
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bachelor's Point</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --primary-mid: #3b82f6;
            --primary-light: #dbeafe;
            --success: #16a34a;
            --success-light: #dcfce7;
            --warning: #ea580c;
            --warning-light: #ffedd5;
            --danger: #dc2626;
            --danger-light: #fee2e2;
            --border: #e2e8f0;
            --text: #0f172a;
            --muted: #64748b;
            --bg: #f1f5f9;
            --white: #ffffff;
            --radius-sm: 8px;
            --radius-md: 10px;
            --radius-lg: 12px;
            --radius-xl: 16px;
            --radius-2xl: 24px;
            --shadow-sm: 0 1px 3px rgba(15,23,42,0.04), 0 1px 2px rgba(15,23,42,0.06);
            --shadow-md: 0 4px 12px rgba(15,23,42,0.06);
            --shadow-lg: 0 20px 50px rgba(15,23,42,0.12);
            --shadow-glow: 0 0 0 3px rgba(59,130,246,0.15);
            --transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
            --font-base: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
        }

        * { box-sizing: border-box; }
        body {
            font-family: var(--font-base);
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex; flex-direction: column;
            margin: 0;
        }
        main { flex: 1; }
        a { color: var(--primary); }
        a:hover { color: var(--primary-dark); }

        /* ============================================
           UNIVERSAL BUTTON SYSTEM (reference style)
           ============================================ */
        /* Primary call-to-action — used on auth forms */
        .btn-auth {
            width: 100%;
            height: 52px;
            border: none;
            border-radius: var(--radius-lg);
            background: var(--primary);
            color: var(--white);
            font-family: var(--font-base);
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none;
        }
        .btn-auth:hover {
            background: var(--primary-dark);
            color: var(--white);
            text-decoration: none;
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(37, 99, 235, 0.3);
        }
        .btn-auth:active { transform: translateY(0); }

        /* Variants of .btn-auth */
        .btn-auth.outline {
            background: var(--white);
            color: var(--primary);
            border: 2px solid var(--border);
        }
        .btn-auth.outline:hover {
            border-color: var(--primary);
            background: var(--primary-light);
            color: var(--primary-dark);
            box-shadow: none;
        }
        .btn-auth.success {
            background: var(--success);
        }
        .btn-auth.success:hover {
            background: #15803d;
            box-shadow: 0 4px 14px rgba(22, 163, 74, 0.3);
        }
        .btn-auth.warning {
            background: var(--warning);
        }
        .btn-auth.warning:hover {
            background: #c2410c;
            box-shadow: 0 4px 14px rgba(234, 88, 12, 0.3);
        }
        .btn-auth.danger {
            background: var(--danger);
        }
        .btn-auth.danger:hover {
            background: #b91c1c;
            box-shadow: 0 4px 14px rgba(220, 38, 38, 0.3);
        }

        /* Compact button — used inline / in cards */
        .btn-nx {
            height: 38px;
            padding: 0 16px;
            border: none;
            border-radius: var(--radius-md);
            background: var(--primary);
            color: var(--white);
            font-family: var(--font-base);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            text-decoration: none;
        }
        .btn-nx:hover {
            background: var(--primary-dark);
            color: var(--white);
            text-decoration: none;
        }
        .btn-nx.outline {
            background: var(--white);
            color: var(--text);
            border: 1px solid var(--border);
        }
        .btn-nx.outline:hover {
            background: var(--bg);
            color: var(--text);
            border-color: var(--muted);
        }
        .btn-nx.outline-danger {
            background: var(--white);
            color: var(--danger);
            border: 1px solid var(--border);
        }
        .btn-nx.outline-danger:hover {
            background: var(--danger-light);
            color: var(--danger);
            border-color: var(--danger);
        }
        .btn-nx.success { background: var(--success); }
        .btn-nx.success:hover { background: #15803d; color: var(--white); }
        .btn-nx.warning { background: var(--warning); }
        .btn-nx.warning:hover { background: #c2410c; color: var(--white); }
        .btn-nx.danger { background: var(--danger); }
        .btn-nx.danger:hover { background: #b91c1c; color: var(--white); }

        /* Tiny button — used in tables, inline */
        .btn-nx.sm { height: 32px; padding: 0 12px; font-size: 12px; }

        /* ============================================
           AUTH LINK
           ============================================ */
        .auth-link {
            color: var(--primary);
            font-weight: 600;
            text-decoration: none;
        }
        .auth-link:hover {
            color: var(--primary-dark);
            text-decoration: underline;
        }

        /* ============================================
           NAVBAR
           ============================================ */
        .nx-navbar {
            background: var(--white);
            border-bottom: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            padding: 0.85rem 0;
        }
        .nx-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--text);
        }
        .nx-brand:hover { color: var(--text); text-decoration: none; }
        .nx-brand-icon {
            width: 42px;
            height: 42px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: var(--radius-lg);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-size: 1.15rem;
            box-shadow: 0 4px 10px rgba(37, 99, 235, 0.25);
        }
        .nx-brand-name {
            font-size: 1.15rem;
            font-weight: 800;
            letter-spacing: -0.3px;
        }
        .nx-nav-link {
            font-size: 0.92rem;
            font-weight: 600;
            color: var(--muted);
            padding: 0.55rem 0.9rem;
            border-radius: var(--radius-md);
            text-decoration: none;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }
        .nx-nav-link:hover {
            background: var(--primary-light);
            color: var(--primary);
            text-decoration: none;
        }
        .nx-badge {
            display: inline-block;
            background: var(--danger);
            color: var(--white);
            border-radius: 999px;
            padding: 0.1rem 0.5rem;
            font-size: 0.7rem;
            font-weight: 700;
        }
        .nx-badge-warning { background: var(--warning); }
        @@keyframes pulse-dot {
            0%, 100% { transform: scale(1); opacity: 1; }
            50%      { transform: scale(1.18); opacity: 0.85; }
        }
        .nx-badge.pulse { animation: pulse-dot 1.6s ease-in-out infinite; }

        .mode-pill {
            background: var(--primary-light);
            color: var(--primary);
            border-radius: 999px;
            padding: 0.4rem 0.95rem;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            border: 1px solid transparent;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
        }
        .mode-pill:hover {
            border-color: var(--primary);
            color: var(--primary-dark);
            text-decoration: none;
        }

        .nav-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--border);
        }
        .nav-avatar-default {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--primary-light);
            color: var(--primary);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            font-weight: 700;
        }

        /* ============================================
           AUTH CARD
           ============================================ */
        .auth-card {
            max-width: 520px;
            margin: 2rem auto;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-2xl);
            padding: 40px;
            box-shadow: var(--shadow-lg);
        }

        /* ============================================
           NX CARD
           ============================================ */
        .nx-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
            overflow: hidden;
        }
        .nx-card:hover { box-shadow: var(--shadow-md); }

        /* ============================================
           HERO
           ============================================ */
        .nx-hero {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: var(--white);
            padding: 4rem 1.5rem;
            border-radius: var(--radius-2xl);
            margin: 1.5rem 0 2.5rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .nx-hero::before {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(ellipse 70% 80% at 50% -10%, rgba(255,255,255,0.18), transparent);
        }
        .nx-hero > * { position: relative; z-index: 1; }
        .nx-hero h1 {
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 0.6rem;
        }
        .nx-hero .lead { opacity: 0.92; font-weight: 400; }

        /* Hero CTA button — white with blue text */
        .btn-hero {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--white);
            color: var(--primary);
            font-weight: 700;
            font-size: 15px;
            padding: 14px 32px;
            border-radius: var(--radius-lg);
            border: none;
            text-decoration: none;
            transition: var(--transition);
        }
        .btn-hero:hover {
            color: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
            text-decoration: none;
        }

        /* ============================================
           ALERTS
           ============================================ */
        .nx-alert {
            border: 1px solid;
            border-radius: var(--radius-md);
            padding: 0.85rem 1rem;
            font-size: 0.92rem;
            display: flex;
            align-items: center;
            gap: 0.55rem;
        }
        .nx-alert-success { background: var(--success-light); border-color: #86efac; color: #166534; }
        .nx-alert-danger  { background: var(--danger-light);  border-color: #fca5a5; color: #991b1b; }
        .nx-alert-warning { background: var(--warning-light); border-color: #fdba74; color: #9a3412; }
        .nx-alert-info    { background: #e0f2fe; border-color: #7dd3fc; color: #075985; }

        /* ============================================
           BADGES
           ============================================ */
        .badge-pending {
            background: var(--warning-light);
            color: #9a3412;
            padding: 0.25rem 0.65rem;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .badge-approved {
            background: var(--success-light);
            color: #166534;
            padding: 0.25rem 0.65rem;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        /* ============================================
           FORM CONTROLS
           ============================================ */
        .form-control, .form-select {
            font-family: var(--font-base);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 0.7rem 0.95rem;
            font-size: 0.93rem;
            height: 50px;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary-mid);
            box-shadow: var(--shadow-glow);
            outline: none;
        }
        textarea.form-control { height: auto; min-height: 80px; }
        .form-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 0.4rem;
        }

        /* ============================================
           ROLE-SELECT CARDS
           ============================================ */
        .role-card {
            border: 2px solid var(--border);
            border-radius: var(--radius-xl);
            background: var(--white);
            text-decoration: none;
            color: inherit;
            display: block;
            padding: 2rem;
            transition: var(--transition);
            cursor: pointer;
            text-align: center;
        }
        .role-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary);
            color: inherit;
            text-decoration: none;
        }
        .role-card .icon-wrap {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2.4rem;
            margin-bottom: 1rem;
        }
        .icon-admin { background: var(--primary-light); color: var(--primary); }
        .icon-user  { background: var(--success-light); color: var(--success); }

        /* ============================================
           FOOTER
           ============================================ */
        .nx-footer {
            background: var(--white);
            border-top: 1px solid var(--border);
            padding: 1.25rem 0;
            color: var(--muted);
            font-size: 0.85rem;
            margin-top: 3rem;
        }
        .nx-footer a { color: var(--primary); text-decoration: none; font-weight: 600; }

        /* ============================================
           ANIMATIONS
           ============================================ */
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-up { animation: fadeUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) both; }

        /* Override Bootstrap btn-close in alerts */
        .nx-alert .btn-close { padding: 0.5rem; }

        /* Pagination */
        .pagination .page-link {
            color: var(--primary);
            border-color: var(--border);
            font-weight: 600;
            border-radius: var(--radius-md);
            margin: 0 2px;
        }
        .pagination .page-item.active .page-link {
            background: var(--primary);
            border-color: var(--primary);
        }
        .pagination .page-item.disabled .page-link {
            color: var(--muted);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md nx-navbar">
            <div class="container">
                <a class="nx-brand" asp-controller="Home" asp-action="Index">
                    <div class="nx-brand-icon"><i class="bi bi-house-heart-fill"></i></div>
                    <span class="nx-brand-name">Bachelor's Point</span>
                </a>
                @if (isAuthed)
                {
                    string currentMode = Context.Request.Cookies["UserMode"] ?? "owner";
                    bool ownerMode = currentMode == "owner";

                    <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navMain">
                        <ul class="navbar-nav mx-auto align-items-center gap-1">
                            <li class="nav-item">
                                <a class="nx-nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-grid-1x2-fill"></i> Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nx-nav-link" asp-controller="Room" asp-action="Index">
                                    <i class="bi bi-search"></i> Browse Rooms
                                </a>
                            </li>

                            @if (isAdminUser)
                            {
                                <li class="nav-item">
                                    <a class="nx-nav-link" asp-controller="Room" asp-action="Pending"
                                       title="@(pendingRoomCount > 0 ? $"{pendingRoomCount} room(s) waiting for approval" : "No rooms pending")">
                                        <i class="bi bi-clock-history"></i> Pending
                                        @if (pendingRoomCount > 0)
                                        {
                                            <span class="nx-badge nx-badge-warning pulse">@pendingRoomCount</span>
                                        }
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nx-nav-link" asp-controller="User" asp-action="Index">
                                        <i class="bi bi-people-fill"></i> Users
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nx-nav-link" asp-controller="Role" asp-action="Index">
                                        <i class="bi bi-shield-lock-fill"></i> Roles
                                    </a>
                                </li>
                            }
                            else if (ownerMode)
                            {
                                <li class="nav-item">
                                    <a class="nx-nav-link" asp-controller="Room" asp-action="Create">
                                        <i class="bi bi-plus-square-fill"></i> Post a Room
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nx-nav-link" asp-controller="Auth" asp-action="Profile">
                                        <i class="bi bi-bookmark-check-fill"></i> My Bookings
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nx-nav-link" asp-controller="Chat" asp-action="Index">
                                    <i class="bi bi-chat-dots-fill"></i> Messages
                                    @if (unreadCount > 0)
                                    {
                                        <span class="nx-badge">@unreadCount</span>
                                    }
                                </a>
                            </li>
                        </ul>

                        <ul class="navbar-nav align-items-center gap-2">
                            @if (!isAdminUser)
                            {
                                <li class="nav-item dropdown">
                                    <a class="text-decoration-none" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <span class="mode-pill">
                                            <i class="bi @(ownerMode ? "bi-house-add-fill" : "bi-search")"></i>
                                            @(ownerMode ? "Owner Mode" : "Seeker Mode")
                                            <i class="bi bi-caret-down-fill" style="font-size:0.65rem;"></i>
                                        </span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border-color: var(--border); border-radius: var(--radius-lg); padding: 0.5rem;">
                                        <li class="dropdown-header small" style="font-weight: 600; color: var(--muted);">Switch mode</li>
                                        <li>
                                            <form asp-controller="Auth" asp-action="SetMode" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="mode" value="owner" />
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                <button type="submit" class="dropdown-item @(ownerMode ? "active" : "")" style="border-radius: var(--radius-md);">
                                                    <i class="bi bi-house-add-fill me-1"></i> Owner Mode
                                                </button>
                                            </form>
                                        </li>
                                        <li>
                                            <form asp-controller="Auth" asp-action="SetMode" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="mode" value="seeker" />
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                <button type="submit" class="dropdown-item @(!ownerMode ? "active" : "")" style="border-radius: var(--radius-md);">
                                                    <i class="bi bi-search me-1"></i> Seeker Mode
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nx-nav-link d-flex align-items-center gap-2" asp-controller="Auth" asp-action="Profile" title="View profile">
                                    @if (!string.IsNullOrEmpty(currentUserPic))
                                    {
                                        <img src="@currentUserPic" alt="Profile" class="nav-avatar" />
                                    }
                                    else
                                    {
                                        <span class="nav-avatar-default"><i class="bi bi-person-fill"></i></span>
                                    }
                                    <span>@User.Identity.Name</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-nx outline-danger sm" title="Logout">
                                        <i class="bi bi-box-arrow-right"></i>
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </nav>
    </header>

    <main role="main">
        <div class="container mt-3">
            @if (TempData["Success"] != null)
            {
                <div class="nx-alert nx-alert-success alert-dismissible fade show fade-up" role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <span class="flex-grow-1">@TempData["Success"]</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="nx-alert nx-alert-danger alert-dismissible fade show fade-up" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span class="flex-grow-1">@TempData["Error"]</span>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (isAdminUser && pendingRoomCount > 0 && Context.Request.Path != "/Room/Pending")
            {
                <div class="nx-alert nx-alert-warning alert-dismissible fade show fade-up" role="alert">
                    <i class="bi bi-bell-fill"></i>
                    <div class="flex-grow-1">
                        <strong>@pendingRoomCount new post@(pendingRoomCount == 1 ? "" : "s")</strong> waiting for your approval.
                        <a asp-controller="Room" asp-action="Pending" class="auth-link">Review now &rarr;</a>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
        @RenderBody()
    </main>

    <footer class="nx-footer">
        <div class="container text-center">
            &copy; 2026 <strong>Bachelor's Point</strong> &middot;
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

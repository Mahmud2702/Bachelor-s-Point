@using Bachelor_s_Point.Application.Interfaces.Services
@inject IUserService UserService
@inject IChatService ChatService
@inject IRoomService RoomService
@{
    string? currentUserPic = null;
    int unreadCount = 0;
    int pendingRoomCount = 0;
    bool isAuthed = User.Identity != null && User.Identity.IsAuthenticated;
    bool isAdminUser = isAuthed && User.IsInRole("Admin");

    if (isAuthed)
    {
        var idClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(idClaim, out int currentUid))
        {
            var currentUser = await UserService.GetUserByIdAsync(currentUid);
            currentUserPic = currentUser?.ProfilePicturePath;
            unreadCount = await ChatService.GetUnreadCountAsync(currentUid);
        }

        if (isAdminUser)
        {
            var pending = await RoomService.GetPendingApprovalAsync();
            pendingRoomCount = pending.Count;
        }
    }
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bachelor's Point</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root {
            --clr-primary: #1e40af;
            --clr-primary-dark: #1e3a8a;
            --clr-primary-mid: #3b82f6;
            --clr-primary-light: #dbeafe;
            --clr-canvas: #f1f5f9;
            --clr-surface: #ffffff;
            --clr-border: #e2e8f0;
            --clr-text: #0f172a;
            --clr-muted: #64748b;
            --clr-success: #16a34a;
            --clr-success-light: #dcfce7;
            --clr-warning: #ea580c;
            --clr-warning-light: #ffedd5;
            --clr-danger: #dc2626;
            --clr-danger-light: #fee2e2;
            --radius-sm: 8px;
            --radius-md: 10px;
            --radius-lg: 16px;
            --radius-xl: 24px;
            --shadow-sm: 0 1px 3px rgba(15,23,42,0.04), 0 1px 2px rgba(15,23,42,0.06);
            --shadow-md: 0 4px 12px rgba(15,23,42,0.06);
            --shadow-lg: 0 20px 50px rgba(15,23,42,0.12);
            --shadow-glow: 0 0 0 3px rgba(59,130,246,0.25);
            --transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
            --font-base: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
        }

        * { box-sizing: border-box; }

        body {
            font-family: var(--font-base);
            background: var(--clr-canvas);
            color: var(--clr-text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
        }
        main { flex: 1; }

        /* ============= NAVBAR ============= */
        .nx-navbar {
            background: var(--clr-surface);
            border-bottom: 1px solid var(--clr-border);
            box-shadow: var(--shadow-sm);
            padding: 0.85rem 0;
        }
        .nx-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--clr-text);
        }
        .nx-brand-icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #3b82f6, #1e3a8a);
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.05rem;
        }
        .nx-brand-name {
            font-size: 1.1rem;
            font-weight: 800;
            letter-spacing: -0.2px;
        }
        .nx-nav-link {
            font-size: 0.92rem;
            font-weight: 500;
            color: var(--clr-muted);
            padding: 0.5rem 0.85rem;
            border-radius: var(--radius-sm);
            text-decoration: none;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }
        .nx-nav-link:hover {
            background: var(--clr-primary-light);
            color: var(--clr-primary);
        }
        .nx-nav-link.active {
            background: var(--clr-primary-light);
            color: var(--clr-primary);
            font-weight: 600;
        }
        .nx-badge {
            display: inline-block;
            background: var(--clr-danger);
            color: #fff;
            border-radius: 999px;
            padding: 0.1rem 0.5rem;
            font-size: 0.7rem;
            font-weight: 700;
        }
        .nx-badge-warning { background: var(--clr-warning); }
        @@keyframes pulse-dot {
            0%, 100% { transform: scale(1); opacity: 1; }
            50%      { transform: scale(1.18); opacity: 0.85; }
        }
        .nx-badge.pulse { animation: pulse-dot 1.6s ease-in-out infinite; }

        .mode-pill {
            background: var(--clr-primary-light);
            color: var(--clr-primary);
            border-radius: 999px;
            padding: 0.3rem 0.85rem;
            font-size: 0.82rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            border: 1px solid transparent;
            transition: var(--transition);
        }
        .mode-pill:hover { border-color: var(--clr-primary-mid); }

        .nav-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--clr-border);
        }
        .nav-avatar-default {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--clr-primary-light);
            color: var(--clr-primary);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            font-weight: 700;
        }

        /* ============= CARDS ============= */
        .nx-card {
            background: var(--clr-surface);
            border: 1px solid var(--clr-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            transition: var(--transition);
        }
        .nx-card:hover { box-shadow: var(--shadow-md); }
        .stat-card { /* legacy compat */
            background: var(--clr-surface);
            border: 1px solid var(--clr-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
        }

        /* ============= HERO ============= */
        .nx-hero {
            background: linear-gradient(135deg, var(--clr-primary) 0%, var(--clr-primary-dark) 100%);
            color: #fff;
            padding: 3.5rem 1rem;
            border-radius: var(--radius-xl);
            margin: 1.5rem 0 2.5rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .nx-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 70% 80% at 50% -10%, rgba(255,255,255,0.18), transparent);
        }
        .nx-hero > * { position: relative; z-index: 1; }
        .nx-hero h1 {
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 0.4rem;
        }
        .nx-hero .lead { opacity: 0.92; font-weight: 400; }

        /* ============= BUTTONS ============= */
        .btn {
            font-family: var(--font-base);
            font-weight: 600;
            border-radius: var(--radius-md);
            transition: var(--transition);
        }
        .btn-primary {
            background: var(--clr-primary);
            border-color: var(--clr-primary);
        }
        .btn-primary:hover {
            background: var(--clr-primary-dark);
            border-color: var(--clr-primary-dark);
        }
        .btn-success {
            background: var(--clr-success);
            border-color: var(--clr-success);
        }
        .btn-outline-secondary {
            color: var(--clr-muted);
            border-color: var(--clr-border);
        }
        .btn-outline-secondary:hover {
            background: var(--clr-canvas);
            color: var(--clr-text);
            border-color: var(--clr-border);
        }

        /* ============= ALERTS ============= */
        .nx-alert {
            border: 1px solid;
            border-radius: var(--radius-md);
            padding: 0.85rem 1rem;
            font-size: 0.92rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .nx-alert-success {
            background: var(--clr-success-light);
            border-color: #86efac;
            color: #166534;
        }
        .nx-alert-danger {
            background: var(--clr-danger-light);
            border-color: #fca5a5;
            color: #991b1b;
        }
        .nx-alert-warning {
            background: var(--clr-warning-light);
            border-color: #fdba74;
            color: #9a3412;
        }
        .nx-alert-info {
            background: #e0f2fe;
            border-color: #7dd3fc;
            color: #075985;
        }

        /* ============= STATUS BADGES ============= */
        .badge-pending {
            background: var(--clr-warning-light);
            color: #9a3412;
            padding: 0.25rem 0.65rem;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        /* ============= FOOTER ============= */
        .nx-footer {
            background: var(--clr-surface);
            border-top: 1px solid var(--clr-border);
            padding: 1.25rem 0;
            color: var(--clr-muted);
            font-size: 0.85rem;
            margin-top: 3rem;
        }
        .nx-footer a {
            color: var(--clr-primary);
            text-decoration: none;
            font-weight: 600;
        }

        /* ============= FORMS ============= */
        .form-control, .form-select {
            font-family: var(--font-base);
            border-color: var(--clr-border);
            border-radius: var(--radius-md);
            padding: 0.55rem 0.85rem;
            font-size: 0.93rem;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--clr-primary-mid);
            box-shadow: var(--shadow-glow);
        }
        .form-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--clr-text);
            margin-bottom: 0.4rem;
        }

        /* ============= ROLE-SELECT CARDS ============= */
        .role-card {
            border: 1px solid var(--clr-border);
            border-radius: var(--radius-lg);
            background: var(--clr-surface);
            text-decoration: none;
            color: inherit;
            display: block;
            transition: var(--transition);
            cursor: pointer;
        }
        .role-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
            border-color: var(--clr-primary-mid);
            color: inherit;
            text-decoration: none;
        }
        .role-card .icon-wrap {
            width: 78px;
            height: 78px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
        }
        .icon-admin {
            background: var(--clr-primary-light);
            color: var(--clr-primary);
        }
        .icon-user {
            background: var(--clr-success-light);
            color: var(--clr-success);
        }

        /* ============= AUTH CARD (login/register pages) ============= */
        .auth-card {
            max-width: 460px;
            margin: 2rem auto;
            background: var(--clr-surface);
            border: 1px solid var(--clr-border);
            border-radius: var(--radius-xl);
            padding: 2.5rem;
            box-shadow: var(--shadow-lg);
        }

        /* Bootstrap nav-link override for our gradient nav */
        .navbar-toggler { border-color: var(--clr-border); }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md nx-navbar">
            <div class="container">
                <a class="nx-brand" asp-controller="Home" asp-action="Index">
                    <div class="nx-brand-icon"><i class="bi bi-house-heart-fill"></i></div>
                    <span class="nx-brand-name">Bachelor's Point</span>
                </a>
                @if (isAuthed)
                {
                    string currentMode = Context.Request.Cookies["UserMode"] ?? "owner";
                    bool ownerMode = currentMode == "owner";

                    <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navMain">
                        <ul class="navbar-nav mx-auto align-items-center gap-1">
                            <li class="nav-item">
                                <a class="nx-nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-grid-1x2-fill"></i> Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nx-nav-link" asp-controller="Room" asp-action="Index">
                                    <i class="bi bi-search"></i> Browse Rooms
                                </a>
                            </li>

                            @if (isAdminUser)
                            {
                                <li class="nav-item">
                                    <a class="nx-nav-link" asp-controller="Room" asp-action="Pending"
                                       title="@(pendingRoomCount > 0 ? $"{pendingRoomCount} room(s) waiting for approval" : "No rooms pending")">
                                        <i class="bi bi-clock-history"></i> Pending
                                        @if (pendingRoomCount > 0)
                                        {
                                            <span class="nx-badge nx-badge-warning pulse">@pendingRoomCount</span>
                                        }
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nx-nav-link" asp-controller="User" asp-action="Index">
                                        <i class="bi bi-people-fill"></i> Users
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nx-nav-link" asp-controller="Role" asp-action="Index">
                                        <i class="bi bi-shield-lock-fill"></i> Roles
                                    </a>
                                </li>
                            }
                            else if (ownerMode)
                            {
                                <li class="nav-item">
                                    <a class="nx-nav-link" asp-controller="Room" asp-action="Create">
                                        <i class="bi bi-plus-square-fill"></i> Post a Room
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nx-nav-link" asp-controller="Auth" asp-action="Profile">
                                        <i class="bi bi-bookmark-check-fill"></i> My Bookings
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nx-nav-link" asp-controller="Chat" asp-action="Index">
                                    <i class="bi bi-chat-dots-fill"></i> Messages
                                    @if (unreadCount > 0)
                                    {
                                        <span class="nx-badge">@unreadCount</span>
                                    }
                                </a>
                            </li>
                        </ul>

                        <ul class="navbar-nav align-items-center gap-2">
                            @if (!isAdminUser)
                            {
                                <li class="nav-item dropdown">
                                    <a class="text-decoration-none" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <span class="mode-pill">
                                            <i class="bi @(ownerMode ? "bi-house-add-fill" : "bi-search")"></i>
                                            @(ownerMode ? "Owner Mode" : "Seeker Mode")
                                            <i class="bi bi-caret-down-fill" style="font-size:0.65rem;"></i>
                                        </span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border-color: var(--clr-border); border-radius: var(--radius-md);">
                                        <li class="dropdown-header small">Switch mode</li>
                                        <li>
                                            <form asp-controller="Auth" asp-action="SetMode" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="mode" value="owner" />
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                <button type="submit" class="dropdown-item @(ownerMode ? "active" : "")">
                                                    <i class="bi bi-house-add-fill me-1"></i> Owner Mode
                                                </button>
                                            </form>
                                        </li>
                                        <li>
                                            <form asp-controller="Auth" asp-action="SetMode" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="mode" value="seeker" />
                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                <button type="submit" class="dropdown-item @(!ownerMode ? "active" : "")">
                                                    <i class="bi bi-search me-1"></i> Seeker Mode
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nx-nav-link d-flex align-items-center gap-2" asp-controller="Auth" asp-action="Profile" title="View profile">
                                    @if (!string.IsNullOrEmpty(currentUserPic))
                                    {
                                        <img src="@currentUserPic" alt="Profile" class="nav-avatar" />
                                    }
                                    else
                                    {
                                        <span class="nav-avatar-default"><i class="bi bi-person-fill"></i></span>
                                    }
                                    <span>@User.Identity.Name</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Logout">
                                        <i class="bi bi-box-arrow-right"></i>
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </nav>
    </header>

    <main role="main">
        <div class="container mt-3">
            @if (TempData["Success"] != null)
            {
                <div class="nx-alert nx-alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <span class="flex-grow-1">@TempData["Success"]</span>
                    <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="nx-alert nx-alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span class="flex-grow-1">@TempData["Error"]</span>
                    <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (isAdminUser && pendingRoomCount > 0 && Context.Request.Path != "/Room/Pending")
            {
                <div class="nx-alert nx-alert-warning alert-dismissible fade show" role="alert">
                    <i class="bi bi-bell-fill"></i>
                    <div class="flex-grow-1">
                        <strong>@pendingRoomCount new post@(pendingRoomCount == 1 ? "" : "s")</strong> waiting for your approval.
                        <a asp-controller="Room" asp-action="Pending" style="color: var(--clr-primary); font-weight: 600;">Review now &rarr;</a>
                    </div>
                    <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
        @RenderBody()
    </main>

    <footer class="nx-footer">
        <div class="container text-center">
            &copy; 2026 <strong>Bachelor's Point</strong> &middot;
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

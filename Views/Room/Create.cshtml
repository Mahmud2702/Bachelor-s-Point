@using Bachelor_s_Point.Application.Common
@model CreateRoomDto
@{
    ViewData["Title"] = "Post a Room";
}

<style>
    .cost-input-group .input-group-text {
        background: var(--bg);
        border-color: var(--border);
        color: var(--success);
        font-weight: 700;
        font-size: 0.82rem;
        border-radius: var(--radius-md) 0 0 var(--radius-md);
    }
    .cost-input-group .form-control {
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
        height: 44px;
    }
    .compact-form .form-control, .compact-form .form-select { height: 44px; }
    .compact-form textarea.form-control { height: auto; min-height: 64px; }
    .compact-form .form-label { margin-bottom: 0.25rem; font-size: 0.82rem; }
    .compact-form .mb-3 { margin-bottom: 0.7rem !important; }
    .image-drop-zone {
        border: 2px dashed var(--border);
        border-radius: var(--radius-lg);
        padding: 1rem;
        text-align: center;
        background: var(--bg);
        cursor: pointer;
        transition: var(--transition);
    }
    .image-drop-zone:hover, .image-drop-zone.dragover {
        border-color: var(--primary);
        background: var(--primary-light);
    }
    .image-drop-zone i { font-size: 1.6rem; color: var(--muted); }
    #imagePreview { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.6rem; }
    .preview-thumb {
        width: 68px; height: 68px; border-radius: var(--radius-md);
        object-fit: cover; border: 2px solid var(--border);
    }
    .section-label {
        font-size: 0.78rem; font-weight: 700; color: var(--muted);
        text-transform: uppercase; letter-spacing: 0.5px;
        margin: 0.5rem 0 0.5rem;
    }
</style>

<div class="container py-3" style="max-width: 880px;">
    <div class="nx-card p-4 fade-up compact-form">
        <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width: 48px; height: 48px; background: var(--primary-light); color: var(--primary); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                <i class="bi bi-house-add-fill"></i>
            </div>
            <div>
                <h2 style="font-size: 1.3rem; font-weight: 800; margin: 0;">Post a Room</h2>
                <p style="color: var(--muted); font-size: 0.82rem; margin: 0;">Share your room with the community.</p>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row g-2">
                <div class="col-md-7 mb-3">
                    <label asp-for="Title" class="form-label"><i class="bi bi-tag-fill me-1" style="color: var(--primary);"></i>Title</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. Spacious 2-bed room near campus" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-md-5 mb-3">
                    <label class="form-label"><i class="bi bi-geo-alt-fill me-1" style="color: var(--danger);"></i>Location</label>
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Division" class="form-label" style="font-size: 0.85rem;">Division</label>
                            <select asp-for="Division" id="divisionSelect" class="form-select">
                                <option value="">Select Division</option>
                                @foreach (var div in BangladeshLocations.Divisions)
                                {
                                    <option value="@div">@div</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="District" class="form-label" style="font-size: 0.85rem;">District</label>
                            <select asp-for="District" id="districtSelect" class="form-select">
                                <option value="">Select District</option>
                            </select>
                        </div>
                    </div>
                    <label asp-for="Location" class="form-label" style="font-size: 0.85rem;">Location Details</label>
                    <input asp-for="Location" class="form-control" placeholder="e.g. Street, Neighborhood, Area" />
                    <span asp-validation-for="Location" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"><i class="bi bi-card-text me-1" style="color: var(--primary);"></i>Description</label>
                <textarea asp-for="Description" class="form-control" rows="2"
                          placeholder="Describe the room: facilities, rules, what's nearby..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <p class="section-label"><i class="bi bi-cash-stack me-1"></i>Monthly Costs</p>

            <div class="row g-2">
                <div class="col-md-3 mb-3">
                    <label asp-for="Price" class="form-label">Room Cost</label>
                    <div class="input-group cost-input-group">
                        <span class="input-group-text">BDT</span>
                        <input asp-for="Price" type="number" class="form-control" placeholder="5000" min="0" />
                    </div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="WifiCost" class="form-label">Wifi Cost</label>
                    <div class="input-group cost-input-group">
                        <span class="input-group-text">BDT</span>
                        <input asp-for="WifiCost" type="number" class="form-control" placeholder="0" min="0" />
                    </div>
                    <span asp-validation-for="WifiCost" class="text-danger small"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="MealCostPerMonth" class="form-label">Meal / month</label>
                    <div class="input-group cost-input-group">
                        <span class="input-group-text">BDT</span>
                        <input asp-for="MealCostPerMonth" type="number" class="form-control" placeholder="0" min="0" />
                    </div>
                    <span asp-validation-for="MealCostPerMonth" class="text-danger small"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="MaidCostPerMonth" class="form-label">Maid / month</label>
                    <div class="input-group cost-input-group">
                        <span class="input-group-text">BDT</span>
                        <input asp-for="MaidCostPerMonth" type="number" class="form-control" placeholder="0" min="0" />
                    </div>
                    <span asp-validation-for="MaidCostPerMonth" class="text-danger small"></span>
                </div>
            </div>
            <p style="font-size: 0.74rem; color: var(--muted); margin: -0.2rem 0 0.6rem;">
                <i class="bi bi-info-circle"></i> Wifi, meal &amp; maid costs are optional — leave blank or 0 if not applicable.
            </p>

            <div class="mb-3">
                <label class="form-label"><i class="bi bi-images me-1" style="color: var(--primary);"></i>Room Photos
                    <span style="color: var(--muted); font-weight: 400;">(optional, up to 10, max 5 MB each)</span></label>
                <label for="roomImagesInput" class="image-drop-zone d-block" id="dropZone">
                    <i class="bi bi-cloud-arrow-up-fill"></i>
                    <p class="mb-0 mt-1" style="font-size: 0.88rem;"><strong>Click to upload</strong> or drag &amp; drop</p>
                    <p class="small mb-0" style="color: var(--muted); font-size: 0.74rem;">JPG, PNG, GIF, WEBP — first image is the cover photo</p>
                </label>
                <input type="file" name="roomImages" id="roomImagesInput"
                       accept="image/jpeg,image/png,image/gif,image/webp" multiple style="display:none;" />
                <div id="imagePreview"></div>
            </div>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn-nx success" style="flex: 1; height: 44px;">
                    <i class="bi bi-check-circle"></i> Post Room
                </button>
                <a asp-controller="Auth" asp-action="Profile" class="btn-nx outline" style="flex: 1; height: 44px;">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        // Cascading Division -> District dropdown
        const divisionDistricts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Bachelor_s_Point.Application.Common.BangladeshLocations.DivisionDistricts));

        const divisionSelect = document.getElementById('divisionSelect');
        const districtSelect = document.getElementById('districtSelect');

        function refreshDistricts() {
            const div = divisionSelect.value;
            districtSelect.innerHTML = '<option value="">Select District</option>';
            if (div && divisionDistricts[div]) {
                divisionDistricts[div].forEach(function (d) {
                    const opt = document.createElement('option');
                    opt.value = d;
                    opt.textContent = d;
                    districtSelect.appendChild(opt);
                });
            }
        }

        divisionSelect.addEventListener('change', refreshDistricts);

        // Image preview
        (function() {
            const input = document.getElementById('roomImagesInput');
            const preview = document.getElementById('imagePreview');
            const dropZone = document.getElementById('dropZone');

            function renderPreview(files) {
                preview.innerHTML = '';
                Array.from(files).slice(0, 10).forEach(file => {
                    if (!file.type.startsWith('image/')) return;
                    const reader = new FileReader();
                    reader.onload = e => {
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = 'preview-thumb';
                        preview.appendChild(img);
                    };
                    reader.readAsDataURL(file);
                });
            }
            input.addEventListener('change', () => renderPreview(input.files));
            ['dragenter', 'dragover'].forEach(evt => {
                dropZone.addEventListener(evt, e => {
                    e.preventDefault(); e.stopPropagation();
                    dropZone.classList.add('dragover');
                });
            });
            ['dragleave', 'drop'].forEach(evt => {
                dropZone.addEventListener(evt, e => {
                    e.preventDefault(); e.stopPropagation();
                    dropZone.classList.remove('dragover');
                });
            });
            dropZone.addEventListener('drop', e => {
                if (e.dataTransfer && e.dataTransfer.files.length > 0) {
                    input.files = e.dataTransfer.files;
                    renderPreview(input.files);
                }
            });
        })();
    </script>
}

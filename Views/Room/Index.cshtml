@model Bachelor_s_Point.Application.DTOs.PagedResult<Room>
@{
    ViewData["Title"] = "Browse Rooms";
    var searchText = ViewBag.SearchText as string;
    bool isAdmin = User.IsInRole("Admin");
}

<div class="container">
    <h2 class="mb-3"><i class="bi bi-search me-2 text-secondary"></i>Browse Available Rooms</h2>

    <form asp-action="Index" method="get" class="row g-2 mb-4">
        <div class="col-md-7">
            <input type="text" name="searchText" value="@searchText" class="form-control"
                   placeholder="Search by title, description, or location" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-1"></i> Search
            </button>
            @if (!string.IsNullOrEmpty(searchText))
            {
                <a asp-action="Index" class="btn btn-link">Clear</a>
            }
        </div>
    </form>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i> No rooms found.
        </div>
    }
    else
    {
        <p class="text-muted small">
            Showing @((Model.Page - 1) * Model.PageSize + 1)
            – @((Model.Page - 1) * Model.PageSize + Model.Items.Count)
            of @Model.TotalCount rooms
        </p>

        <div class="row g-3">
            @foreach (var room in Model.Items)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="card-title">@room.Title</h5>
                            <h6 class="card-subtitle text-muted mb-2">
                                <i class="bi bi-geo-alt"></i> @room.Location
                            </h6>
                            <p class="card-text">
                                @(room.Description?.Length > 120 ? room.Description.Substring(0, 120) + "..." : room.Description)
                            </p>
                            <p class="mb-1"><strong class="text-success">BDT @room.Price</strong></p>
                            <p class="text-muted small mb-0">Posted by @(room.Owner?.UserName ?? "Unknown")</p>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <a asp-action="Details" asp-route-id="@room.Id" class="btn btn-sm btn-outline-primary">
                                Details
                            </a>
                            @if (User.Identity != null && User.Identity.IsAuthenticated && !isAdmin)
                            {
                                <a asp-action="Select" asp-route-id="@room.Id" class="btn btn-sm btn-success">
                                    Select
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-searchText="@searchText"
                               asp-route-page="@(Model.Page - 1)">
                            <i class="bi bi-chevron-left"></i> Previous
                        </a>
                    </li>

                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-searchText="@searchText"
                               asp-route-page="@p">@p</a>
                        </li>
                    }

                    <li class="page-item @(Model.HasNext ? "" : "disabled")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-searchText="@searchText"
                               asp-route-page="@(Model.Page + 1)">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

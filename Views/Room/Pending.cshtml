@using Bachelor_s_Point.Models
@model IEnumerable<Room>
@{
    ViewData["Title"] = "Pending Approval";

    var rooms = Model?.ToList() ?? new List<Room>();
    var paymentMap = ViewBag.PaymentMap as Dictionary<int, Payment?> ?? new Dictionary<int, Payment?>();

    int totalPendingRooms = rooms.Count;
    int pendingPaymentCount = rooms.Count(r => paymentMap.TryGetValue(r.Id, out var payment) && payment?.Status == PaymentStatus.Pending);
    int verifiedPaymentCount = rooms.Count(r => paymentMap.TryGetValue(r.Id, out var payment) && payment?.Status == PaymentStatus.Verified);
    int unpaidRoomCount = rooms.Count(r => !paymentMap.TryGetValue(r.Id, out var payment) || payment == null);
    int rejectedPaymentCount = rooms.Count(r => paymentMap.TryGetValue(r.Id, out var payment) && payment?.Status == PaymentStatus.Rejected);

    DateTime? latestSubmission = rooms.Any() ? rooms.Max(r => r.CreatedAt) : null;

    string GetCoverImage(Room room)
    {
        if (room.Images == null || !room.Images.Any()) return "";

        var primary = room.Images.FirstOrDefault(i => i.IsPrimary);
        return (primary?.ImagePath ?? room.Images.OrderBy(i => i.DisplayOrder).First().ImagePath) ?? "";
    }

    string GetShortText(string? text, int maxLength = 120)
    {
        if (string.IsNullOrWhiteSpace(text)) return "No description was provided for this room.";
        return text.Length <= maxLength ? text : text.Substring(0, maxLength) + "...";
    }

    string GetRoomAge(DateTime createdAt)
    {
        var days = (DateTime.Now.Date - createdAt.Date).Days;

        if (days <= 0) return "Today";
        if (days == 1) return "1 day ago";
        if (days < 30) return $"{days} days ago";

        var months = days / 30;
        return months == 1 ? "1 month ago" : $"{months} months ago";
    }
}


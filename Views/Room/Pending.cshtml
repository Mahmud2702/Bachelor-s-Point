@model IEnumerable<Room>
@{
    ViewData["Title"] = "Pending Approval";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
        <h2 class="mb-0">
            <i class="bi bi-clock-history me-2 text-warning"></i>Pending Approval
            @if (Model.Any())
            {
                <span class="badge bg-warning text-dark ms-2">@Model.Count()</span>
            }
        </h2>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-success">
            <i class="bi bi-check2-all me-1"></i> All caught up — no rooms pending approval.
        </div>
    }
    else
    {
        <div class="card stat-card">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Location</th>
                            <th>Price</th>
                            <th>Posted By</th>
                            <th>Posted On</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var room in Model)
                        {
                            <tr>
                                <td><strong>@room.Title</strong></td>
                                <td>@room.Location</td>
                                <td>BDT @room.Price</td>
                                <td>@(room.Owner?.UserName ?? "Unknown")</td>
                                <td class="small text-muted">@room.CreatedAt.ToString("dd-MMM-yyyy hh:mm tt")</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@room.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <form asp-action="Approve" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@room.Id" />
                                        <button type="submit" class="btn btn-sm btn-success">
                                            <i class="bi bi-check2-circle"></i> Approve
                                        </button>
                                    </form>
                                    <a asp-action="Delete" asp-route-id="@room.Id" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Remove
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

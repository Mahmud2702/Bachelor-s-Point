        box-shadow: 0 12px 24px rgba(20, 184, 129, .18);
    }

        .pa-action-success:hover {
            color: #ffffff;
            filter: brightness(1.04);
            transform: translateY(-2px);
            box-shadow: 0 16px 32px rgba(20, 184, 129, .25), 0 0 0 5px rgba(20, 184, 129, .12);
        }

    .pa-action-danger {
        color: #ef4444;
        background: rgba(255, 255, 255, .74);
        border-color: rgba(239, 68, 68, .16);
    }

        .pa-action-danger:hover {
            color: #ffffff;
            background: #ef4444;
            transform: translateY(-2px);
            box-shadow: 0 16px 32px rgba(239, 68, 68, .20), 0 0 0 5px rgba(239, 68, 68, .10);
        }

    [data-theme="dark"] .pa-action-view {
        color: #f8fafc;
        background: rgba(255, 255, 255, .055);
        border-color: rgba(234, 224, 207, .10);
    }

        [data-theme="dark"] .pa-action-view:hover {
            color: #EAE0CF;
            background: rgba(234, 224, 207, .10);
        }

    [data-theme="dark"] .pa-action-danger {
        background: rgba(239, 68, 68, .08);
        color: #fca5a5;
        border-color: rgba(248, 113, 113, .18);
    }

        [data-theme="dark"] .pa-action-danger:hover {
            background: rgba(239, 68, 68, .88);
            color: #ffffff;
        }

    @@media (max-width: 1199.98px) {
        .pa-hero-grid {
            grid-template-columns: 1fr;
        }

        .pa-queue-panel {
            max-width: 520px;
        }

        .pa-room-card {
            grid-template-columns: 220px minmax(0, 1fr);
        }

        .pa-room-body {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 991.98px) {
        .pa-stat-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .pa-room-card {
            grid-template-columns: 1fr;
        }

        .pa-room-media {
            min-height: 220px;
        }
    }

    @@media (max-width: 767.98px) {
        .pending-approval-page {
            padding: .85rem .75rem 1.4rem;
        }

        .pa-hero {
            border-radius: 24px;
        }

        .pa-hero-actions {
            flex-direction: column;
        }

        .pa-btn {
            width: 100%;
        }

        .pa-empty-state {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .pa-empty-icon {
            margin: 0 auto;
        }

        .pa-room-meta-grid {
            grid-template-columns: 1fr;
        }

        .pa-card-actions {
            justify-content: stretch;
        }

            .pa-card-actions > *,
            .pa-card-actions form,
            .pa-card-actions .pa-action-btn {
                width: 100%;
            }
    }

    @@media (max-width: 575.98px) {
        .pa-stat-grid {
            grid-template-columns: 1fr;
        }

        .pa-queue-mini {
            grid-template-columns: 1fr;
        }
    }
</style>

<section class="pending-approval-page">
    <div class="pa-shell">

        <div class="pa-hero">
            <div class="pa-hero-grid">
                <div>
                    <div class="pa-kicker">
                        <i class="bi bi-clock-history"></i>
                        <span>Room Approval Queue</span>
                    </div>

                    <h1>Pending Approval</h1>

                    <p>
                        Review submitted room listings, check payment status, inspect room details, and approve only clean listings for users.
                    </p>

                    <div class="pa-hero-actions">
                        <a asp-controller="Room" asp-action="Index" class="pa-btn pa-btn-primary">
                            <i class="bi bi-house-check-fill"></i>
                            Browse Approved Rooms
                        </a>

                        <a asp-controller="Payment" asp-action="AdminPayments" class="pa-btn pa-btn-soft">
                            <i class="bi bi-cash-coin"></i>
                            Payment Verification
                        </a>
                    </div>
                </div>

                <div class="pa-queue-panel">
                    <div class="pa-queue-number">@totalPendingRooms</div>
                    <span>room listing(s) waiting for admin decision</span>

                    <div class="pa-queue-mini">
                        <div>
                            <strong>@pendingPaymentCount</strong>
                            <small>Payment Pending</small>
                        </div>
                        <div>
                            <strong>@verifiedPaymentCount</strong>
                            <small>Paid</small>
                        </div>
                        <div>
                            <strong>@unpaidRoomCount</strong>
                            <small>No Payment</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="pa-section">
            <div class="pa-section-head">
                <div>
                    <h2 class="pa-section-title">
                        <i class="bi bi-bar-chart-fill"></i>
                        Approval Overview
                    </h2>
                    <p class="pa-section-subtitle">A quick breakdown of rooms waiting in the approval queue.</p>
                </div>
            </div>

            <div class="pa-stat-grid">
                <div class="pa-stat-card">
                    <div class="pa-stat-icon">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <h3 class="pa-stat-value">@totalPendingRooms</h3>
                    <p class="pa-stat-label">Pending Rooms</p>
                    <p class="pa-stat-hint">Listings waiting for admin review.</p>
                </div>

                <div class="pa-stat-card">
                    <div class="pa-stat-icon">
                        <i class="bi bi-receipt"></i>
                    </div>
                    <h3 class="pa-stat-value">@pendingPaymentCount</h3>
                    <p class="pa-stat-label">Payment Pending</p>
                    <p class="pa-stat-hint">TrxIDs awaiting verification.</p>
                </div>

                <div class="pa-stat-card">
                    <div class="pa-stat-icon">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <h3 class="pa-stat-value">@verifiedPaymentCount</h3>
                    <p class="pa-stat-label">Paid Listings</p>
                    <p class="pa-stat-hint">Payment already verified.</p>
                </div>

                <div class="pa-stat-card">
                    <div class="pa-stat-icon">
                        <i class="bi bi-calendar-day-fill"></i>
                    </div>
                    <h3 class="pa-stat-value">@(latestSubmission?.ToString("dd MMM") ?? "—")</h3>
                    <p class="pa-stat-label">Latest Submission</p>
                    <p class="pa-stat-hint">Most recent room in queue.</p>
                </div>
            </div>
        </div>

        <div class="pa-section">
            @if (!rooms.Any())
            {
                <div class="pa-empty-state">
                    <div class="pa-empty-icon">
                        <i class="bi bi-shield-fill-check"></i>
                    </div>

                    <div>
                        <h2>All caught up</h2>
                        <p>No rooms are currently waiting for approval. The queue is clean and ready for the next submission.</p>
                    </div>

                    <a asp-controller="Room" asp-action="Index" class="pa-btn pa-btn-primary">
                        <i class="bi bi-box-arrow-up-right"></i>
                        View Approved Rooms
                    </a>
                </div>
            }
            else
            {
                <div class="pa-section-head">
                    <div>
                        <h2 class="pa-section-title">
                            <i class="bi bi-list-check"></i>
                            Review Queue
                        </h2>
                        <p class="pa-section-subtitle">Inspect each listing and approve only after checking its details and payment state.</p>
                    </div>
                </div>

                <div class="pa-review-grid">
                    @foreach (var room in rooms)
                    {
                        paymentMap.TryGetValue(room.Id, out var pay);
                        string cover = GetCoverImage(room);

                        string statusClass = pay == null
                            ? "pa-status-unpaid"
                            : pay.Status == PaymentStatus.Pending
                                ? "pa-status-review"
                                : pay.Status == PaymentStatus.Verified
                                    ? "pa-status-paid"
                                    : pay.Status == PaymentStatus.Rejected
                                        ? "pa-status-rejected"
                                        : "pa-status-unpaid";

                        string statusText = pay == null
                            ? "No payment found"
                            : pay.Status == PaymentStatus.Pending
                                ? "Payment needs verification"
                                : pay.Status == PaymentStatus.Verified
                                    ? "Payment verified"
                                    : pay.Status == PaymentStatus.Rejected
                                        ? "Payment rejected"
                                        : pay.Status.ToString();

                        string statusIcon = pay == null
                            ? "bi-question-circle-fill"
                            : pay.Status == PaymentStatus.Pending
                                ? "bi-hourglass-split"
                                : pay.Status == PaymentStatus.Verified
                                    ? "bi-check-circle-fill"
                                    : pay.Status == PaymentStatus.Rejected
                                        ? "bi-x-circle-fill"
                                        : "bi-info-circle-fill";

                        <article class="pa-room-card">
                            <div class="pa-room-media">
                                @if (!string.IsNullOrWhiteSpace(cover))
                                {
                                    <img src="@cover" alt="@room.Title" />
                                }
                                else
                                {
                                    <i class="bi bi-image"></i>
                                }
                            </div>

                            <div class="pa-room-body">
                                <div class="pa-room-main">
                                    <div class="pa-room-topline">
                                        <span class="pa-status-badge @statusClass">
                                            <i class="bi @statusIcon"></i>
                                            @statusText
                                        </span>

                                        <span class="pa-info-pill">
                                            <i class="bi bi-clock-fill"></i>
                                            @GetRoomAge(room.CreatedAt)
                                        </span>
                                    </div>

                                    <h2 class="pa-room-title">@room.Title</h2>

                                    <p class="pa-room-desc">
                                        @GetShortText(room.Description)
                                    </p>

                                    <div class="pa-room-meta-grid">
                                        <div class="pa-meta-box">
                                            <span><i class="bi bi-geo-alt-fill"></i> Location</span>
                                            <strong>@(!string.IsNullOrWhiteSpace(room.District) ? room.District : room.Location)</strong>
                                        </div>

                                        <div class="pa-meta-box">
                                            <span><i class="bi bi-cash-stack"></i> Rent</span>
                                            <strong>BDT @room.Price.ToString("N0")</strong>
                                        </div>

                                        <div class="pa-meta-box">
                                            <span><i class="bi bi-person-fill"></i> Posted By</span>
                                            <strong>@(room.Owner?.UserName ?? "Unknown")</strong>
                                        </div>
                                    </div>
                                </div>

                                <aside class="pa-payment-panel">
                                    <div>
                                        <h3 class="pa-payment-label">
                                            <i class="bi bi-cash-coin"></i>
                                            Payment Review
                                        </h3>

                                        @if (pay == null)
                                        {
                                            <p class="pa-payment-empty">
                                                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                                No payment record is attached to this room yet.
                                            </p>
                                        }
                                        else if (pay.Status == PaymentStatus.Pending)
                                        {
                                            <button type="button"
                                                    class="pa-trx-code"
                                                    title="Click to copy transaction ID"
                                                    onclick="navigator.clipboard.writeText('@pay.TransactionId'); this.style.background='rgba(20,184,129,.12)';">
                                                <i class="bi bi-clipboard"></i>
                                                @pay.TransactionId
                                            </button>

                                            <p class="pa-payment-sub">
                                                BDT @pay.Amount.ToString("0") · submitted @pay.SubmittedAt.ToString("dd MMM yyyy, hh:mm tt")
                                            </p>
                                        }
                                        else if (pay.Status == PaymentStatus.Verified)
                                        {
                                            <p class="pa-payment-empty">
                                                <i class="bi bi-check-circle-fill me-1"></i>
                                                Payment has already been verified. Approve the room if the listing is clean.
                                            </p>
                                        }
                                        else if (pay.Status == PaymentStatus.Rejected)
                                        {
                                            <p class="pa-payment-empty">
                                                <i class="bi bi-x-circle-fill me-1"></i>
                                                Payment was rejected. Manual approval is still available if needed.
                                            </p>
                                        }
                                    </div>

                                    <div class="pa-card-actions">
                                        <a asp-action="Details" asp-route-id="@room.Id" class="pa-action-btn pa-action-view">
                                            <i class="bi bi-eye-fill"></i>
                                            View
                                        </a>

                                        @if (pay?.Status == PaymentStatus.Pending)
                                        {
                                            <form asp-controller="Payment" asp-action="Verify" asp-route-id="@pay.Id" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="pa-action-btn pa-action-success"
                                                        onclick="return confirm('Verify TrxID: @pay.TransactionId and approve room?')">
                                                    <i class="bi bi-patch-check-fill"></i>
                                                    Verify &amp; Approve
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Approve" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@room.Id" />
                                                <button type="submit"
                                                        class="pa-action-btn pa-action-success"
                                                        onclick="return confirm('Approve this room without payment?')">
                                                    <i class="bi bi-check-circle-fill"></i>
                                                    Approve
                                                </button>
                                            </form>
                                        }

                                        <a asp-action="Delete" asp-route-id="@room.Id" class="pa-action-btn pa-action-danger">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </aside>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>

    </div>
</section>

@model Room
@{
    ViewData["Title"] = "Room Details";
}

<h2>@Model.Title</h2>
<hr />

<dl class="row">
    <dt class="col-sm-3">Location</dt>
    <dd class="col-sm-9">@Model.Location</dd>

    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">BDT @Model.Price</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>

    <dt class="col-sm-3">Posted By</dt>
    <dd class="col-sm-9">@(Model.Owner?.UserName ?? "Unknown")</dd>

    <dt class="col-sm-3">Posted On</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd-MMM-yyyy hh:mm tt")</dd>

    <dt class="col-sm-3">Available</dt>
    <dd class="col-sm-9">@(Model.IsAvailable ? "Yes" : "No")</dd>
</dl>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>

    @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("RoomSeeker") || User.IsInRole("Admin")))
    {
        @if (Model.IsAvailable)
        {
            <a asp-action="Select" asp-route-id="@Model.Id" class="btn btn-success">Select this Room</a>
        }
    }
</div>

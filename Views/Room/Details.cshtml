@model Room
@{
    ViewData["Title"] = "Room Details";
    bool isAdmin = User.IsInRole("Admin");
    bool isOwner = false;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(idClaim, out int currentUserId) && currentUserId == Model.UserId)
        {
            isOwner = true;
        }
    }
    var roomSelections = ViewBag.RoomSelections as List<RoomSelection>;

    // Order images: primary first, then by DisplayOrder
    var images = (Model.Images ?? new List<RoomImage>())
        .OrderByDescending(i => i.IsPrimary)
        .ThenBy(i => i.DisplayOrder)
        .ToList();
}

<style>
    .room-carousel .carousel-inner {
        border-radius: 14px;
        background: #2c3e50;
    }

    .room-carousel .carousel-item img {
        width: 100%;
        max-height: 480px;
        object-fit: contain;
        background: #2c3e50;
    }

    .room-carousel .carousel-control-prev,
    .room-carousel .carousel-control-next {
        width: 50px;
    }

    .room-carousel .carousel-control-prev-icon,
    .room-carousel .carousel-control-next-icon {
        background-color: rgba(0,0,0,0.45);
        border-radius: 50%;
        padding: 1.2rem;
        background-size: 50% 50%;
    }

    .room-carousel .carousel-indicators [data-bs-target] {
        background-color: rgba(255,255,255,0.7);
        border-radius: 50%;
        width: 10px;
        height: 10px;
        margin: 0 4px;
    }

    .no-image-placeholder {
        height: 320px;
        background: linear-gradient(135deg, #e3e8ef 0%, #c9d3e0 100%);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6b7280;
        font-size: 4rem;
    }
</style>

<div class="container">

    @if (images.Any())
    {
        <div id="roomCarousel" class="carousel slide room-carousel mb-3" data-bs-ride="carousel">
            @if (images.Count > 1)
            {
                <div class="carousel-indicators">
                    @for (int i = 0; i < images.Count; i++)
                    {
                        <button type="button" data-bs-target="#roomCarousel" data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")"
                                aria-current="@(i == 0 ? "true" : "false")"
                                aria-label="Slide @(i + 1)"></button>
                    }
                </div>
            }
            <div class="carousel-inner">
                @for (int i = 0; i < images.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@images[i].ImagePath" alt="Room image @(i + 1)" />
                    </div>
                }
            </div>
            @if (images.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#roomCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#roomCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            }
        </div>
        <p class="text-muted small text-center mb-3">
            <i class="bi bi-images me-1"></i>@images.Count photo@(images.Count == 1 ? "" : "s")
        </p>
    }
    else
    {
        <div class="no-image-placeholder mb-3">
            <i class="bi bi-image"></i>
        </div>
    }

    <div class="card stat-card mb-3">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap">
                <div>
                    <h2 class="mb-1">@Model.Title</h2>
                    <p class="text-muted mb-0"><i class="bi bi-geo-alt"></i> @Model.Location</p>
                </div>
                <div class="text-end">
                    @if (!Model.IsApproved)
                    {
                        <span class="badge-pending"><i class="bi bi-clock"></i> Pending Approval</span>
                    }
                    else if (Model.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Closed</span>
                    }
                </div>
            </div>

            <hr />

            <dl class="row mb-0">
                <dt class="col-sm-3">Price</dt>
                <dd class="col-sm-9"><strong class="text-success">BDT @Model.Price</strong></dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Description</dd>

                <dt class="col-sm-3">Posted By</dt>
                <dd class="col-sm-9">@(Model.Owner?.UserName ?? "Unknown")</dd>

                <dt class="col-sm-3">Posted On</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("dd-MMM-yyyy hh:mm tt")</dd>
            </dl>
        </div>
    </div>

    <div class="mb-3">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>

        @if (isAdmin)
        {
            @if (!Model.IsApproved)
            {
                <form asp-action="Approve" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check2-circle me-1"></i> Approve
                    </button>
                </form>
            }
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i> Remove
            </a>
        }
        else
        {
            @if (isOwner)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i> Edit
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i> Delete
                </a>
            }
            else if (User.Identity != null && User.Identity.IsAuthenticated && Model.IsAvailable && Model.IsApproved)
            {
                <a asp-action="Select" asp-route-id="@Model.Id" class="btn btn-success">
                    <i class="bi bi-bookmark-plus me-1"></i> Select this Room
                </a>
            }
        }
    </div>

    @if (isOwner && roomSelections != null)
    {
        <div class="mt-4">
            <h4 class="mb-3">
                <i class="bi bi-people-fill me-2 text-primary"></i>
                Interested Users
                @if (roomSelections.Any())
                {
                    <span class="badge bg-primary ms-2">@roomSelections.Count</span>
                }
            </h4>

            @if (!roomSelections.Any())
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-1"></i> Nobody has selected this room yet.
                </div>
            }
            else
            {
                <div class="card stat-card">
                    <div class="card-body p-0">
                        @foreach (var s in roomSelections)
                        {
                            <div class="p-3 border-bottom">
                                <div class="d-flex justify-content-between align-items-start flex-wrap">
                                    <div>
                                        <h6 class="mb-1">
                                            <i class="bi bi-person-circle me-1 text-secondary"></i>
                                            <strong>@s.Seeker?.UserName</strong>
                                        </h6>
                                        <p class="mb-0 small text-muted">
                                            <i class="bi bi-envelope me-1"></i>@s.Seeker?.Email
                                            @if (!string.IsNullOrWhiteSpace(s.Seeker?.Address))
                                            {
                                                <span class="ms-2"><i class="bi bi-geo-alt me-1"></i>@s.Seeker?.Address</span>
                                            }
                                        </p>
                                    </div>
                                    <small class="text-muted">
                                        <i class="bi bi-clock me-1"></i>
                                        @s.SelectedAt.ToString("dd-MMM-yyyy hh:mm tt")
                                    </small>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(s.Message))
                                {
                                    <div class="mt-2 p-2 rounded" style="background:#f6f8fb; border-left:4px solid #2563eb;">
                                        <i class="bi bi-chat-left-quote me-1 text-primary"></i>
                                        <span>@s.Message</span>
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted small mb-0 mt-2 fst-italic">No message provided.</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

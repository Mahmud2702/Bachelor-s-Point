@model Room
@{
    ViewData["Title"] = "Room Details";
    bool isAdmin = User.IsInRole("Admin");
    bool isOwner = false;
    if (User.Identity?.IsAuthenticated == true)
    {
        var idClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(idClaim, out int currentUserId) && currentUserId == Model.UserId)
            isOwner = true;
    }

    // Owner can always see their own room details.
    // Everyone else needs PaymentVerified=True (or Admin).
    bool isVerified = isAdmin || isOwner ||
                      (User.Identity?.IsAuthenticated == true &&
                       User.FindFirst("PaymentVerified")?.Value == "True");

    var roomSelections = ViewBag.RoomSelections as List<RoomSelection>;
    var roomPayment    = ViewBag.RoomPayment as Bachelor_s_Point.Models.Payment;
    var images = (Model.Images ?? new List<RoomImage>())
        .OrderByDescending(i => i.IsPrimary)
        .ThenBy(i => i.DisplayOrder)
        .ToList();
    string mapQuery = System.Net.WebUtility.UrlEncode((Model.Location ?? "") + ", Bangladesh");
    string mapUrl   = $"https://www.google.com/maps/search/?api=1&query={mapQuery}";
}

<style>
    .room-carousel .carousel-inner { border-radius: var(--radius-xl); background: var(--bg); }
    .room-carousel .carousel-item img {
        width: 100%; max-height: 480px; object-fit: contain; background: var(--bg);
    }
    .room-carousel .carousel-control-prev, .room-carousel .carousel-control-next { width: 50px; }
    .room-carousel .carousel-control-prev-icon, .room-carousel .carousel-control-next-icon {
        background-color: rgba(0,0,0,0.5); border-radius: 50%; padding: 1.2rem; background-size: 50% 50%;
    }
    .room-carousel .carousel-indicators [data-bs-target] {
        background-color: rgba(255,255,255,0.8); border-radius: 50%;
        width: 10px; height: 10px; margin: 0 4px;
    }
    .no-image-placeholder {
        height: 320px; background: var(--bg); border: 1px solid var(--border);
        border-radius: var(--radius-xl); display: flex; align-items: center;
        justify-content: center; color: var(--muted); font-size: 4rem;
    }
    .detail-row { display: flex; padding: 0.6rem 0; border-bottom: 1px solid var(--border); }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { width: 130px; color: var(--muted); font-size: 0.88rem; flex-shrink: 0; }
    .detail-value { font-size: 0.92rem; }

    /* paywall for details page */
    .detail-paywall-wrap { position: relative; }
    .detail-blurred { filter: blur(8px); pointer-events: none; user-select: none; }
    .detail-paywall-overlay {
        position: absolute;
        inset: 0;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.85rem;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(2px);
        border-radius: var(--radius-xl);
        text-align: center;
        padding: 2rem;
    }
    .detail-paywall-overlay .lock-big {
        width: 64px; height: 64px;
        background: rgba(255,255,255,0.15);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 2rem; color: #fff;
    }
    .detail-paywall-overlay h5 { color: #fff; font-weight: 800; margin: 0; }
    .detail-paywall-overlay p  { color: rgba(255,255,255,0.85); font-size: 0.88rem; margin: 0; }
    .unlock-big-btn {
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: var(--radius-lg);
        padding: 0.65rem 1.8rem;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background 0.2s;
        box-shadow: 0 4px 15px rgba(75,86,148,0.4);
    }
    .unlock-big-btn:hover { background: var(--primary-dark); color: #fff; transform: translateY(-2px); }
</style>

<div class="container py-3" style="max-width: 920px;">

    @* Images are always visible — title/location too. Details are locked. *@

    @if (images.Any())
    {
        <div id="roomCarousel" class="carousel slide room-carousel mb-2 fade-up" data-bs-ride="carousel">
            @if (images.Count > 1)
            {
                <div class="carousel-indicators">
                    @for (int i = 0; i < images.Count; i++)
                    {
                        <button type="button" data-bs-target="#roomCarousel" data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")" aria-label="Slide @(i + 1)"></button>
                    }
                </div>
            }
            <div class="carousel-inner">
                @for (int i = 0; i < images.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@images[i].ImagePath" alt="Room image @(i + 1)" />
                    </div>
                }
            </div>
            @if (images.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#roomCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#roomCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            }
        </div>
        <p class="text-center mb-3" style="color:var(--muted);font-size:0.82rem;">
            <i class="bi bi-images me-1"></i>@images.Count photo@(images.Count == 1 ? "" : "s")
        </p>
    }
    else
    {
        <div class="no-image-placeholder mb-3 fade-up"><i class="bi bi-image"></i></div>
    }

    @if (isVerified)
    {
        <!-- ── Full details for verified users ── -->
        <div class="nx-card p-4 mb-3 fade-up">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                <div>
                    <h2 style="font-weight:800;margin-bottom:0.25rem;">@Model.Title</h2>
                    <p style="color:var(--muted);margin:0;">
                        <i class="bi bi-geo-alt"></i> @Model.Location
                        <a href="@mapUrl" target="_blank" rel="noopener" class="auth-link" style="margin-left:0.5rem;font-size:0.85rem;">
                            <i class="bi bi-map"></i> View on Map
                        </a>
                    </p>
                </div>
                <div>
                    @if (!Model.IsApproved) { <span class="badge-pending"><i class="bi bi-clock"></i> Due Payment</span> }
                    else if (Model.IsAvailable) { <span class="badge-approved"><i class="bi bi-check-circle-fill"></i> Available</span> }
                    else { <span style="background:var(--bg);color:var(--muted);border:1px solid var(--border);padding:0.25rem 0.75rem;border-radius:999px;font-size:0.75rem;font-weight:600;">Closed</span> }
                </div>
            </div>

            <hr style="border-color:var(--border);" />

            <div class="detail-row">
                <span class="detail-label">Room Cost</span>
                <span class="detail-value"><strong style="color:var(--success);font-size:1.1rem;">BDT @Model.Price</strong> <span style="color:var(--muted);font-size:0.82rem;">/ month</span></span>
            </div>
            @if (Model.WifiCost is > 0)
            {
                <div class="detail-row">
                    <span class="detail-label">Wifi Cost</span>
                    <span class="detail-value">BDT @Model.WifiCost <span style="color:var(--muted);font-size:0.82rem;">/ month</span></span>
                </div>
            }
            @if (Model.MealCostPerMonth is > 0)
            {
                <div class="detail-row">
                    <span class="detail-label">Meal Cost</span>
                    <span class="detail-value">BDT @Model.MealCostPerMonth <span style="color:var(--muted);font-size:0.82rem;">/ month</span></span>
                </div>
            }
            @if (Model.MaidCostPerMonth is > 0)
            {
                <div class="detail-row">
                    <span class="detail-label">Maid Cost</span>
                    <span class="detail-value">BDT @Model.MaidCostPerMonth <span style="color:var(--muted);font-size:0.82rem;">/ month</span></span>
                </div>
            }
            @{
                int total = Model.Price + (Model.WifiCost ?? 0) + (Model.MealCostPerMonth ?? 0) + (Model.MaidCostPerMonth ?? 0);
            }
            @if (total > Model.Price)
            {
                <div class="detail-row" style="background:var(--success-light);margin:0 -0.5rem;padding-left:0.5rem;padding-right:0.5rem;border-radius:var(--radius-sm);">
                    <span class="detail-label" style="font-weight:700;color:var(--text);">Est. Total</span>
                    <span class="detail-value"><strong style="color:var(--success);font-size:1.15rem;">BDT @total</strong> <span style="color:var(--muted);font-size:0.82rem;">/ month (all-in)</span></span>
                </div>
            }
            <div class="detail-row">
                <span class="detail-label">Description</span>
                <span class="detail-value">@Model.Description</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Posted By</span>
                <span class="detail-value">@(Model.Owner?.UserName ?? "Unknown")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Posted On</span>
                <span class="detail-value">@Model.CreatedAt.ToString("dd-MMM-yyyy hh:mm tt")</span>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3">
            <a asp-action="Index" class="btn-nx outline">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
            <a href="@mapUrl" target="_blank" rel="noopener" class="btn-nx">
                <i class="bi bi-geo-alt-fill"></i> View on Map
            </a>

            @if (isAdmin)
            {
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-nx danger">
                    <i class="bi bi-trash"></i> Remove
                </a>
            }
            else if (isOwner)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-nx warning">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-nx outline-danger">
                    <i class="bi bi-trash"></i> Delete
                </a>

                @* ── Payment status for unpublished rooms: pay directly, no manual review ── *@
                @if (!Model.IsApproved)
                {
                    @if (roomPayment?.Status == Bachelor_s_Point.Models.PaymentStatus.Verified)
                    {
                        <button class="btn-nx success" style="cursor:default;" disabled>
                            <i class="bi bi-check-circle-fill"></i> Payment Done
                        </button>
                    }
                    else
                    {
                        <form asp-controller="Payment" asp-action="PayRoomFee" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="roomId" value="@Model.Id" />
                            <button type="submit" class="btn-nx warning">
                                <i class="bi bi-cash-coin"></i> Due Payment — Pay Now
                            </button>
                        </form>
                    }
                }
            }
            else if (User.Identity?.IsAuthenticated == true && Model.IsAvailable && Model.IsApproved)
            {
                <a asp-action="Select" asp-route-id="@Model.Id" class="btn-nx success">
                    <i class="bi bi-bookmark-plus"></i> Select this Room
                </a>
                <a asp-controller="Chat" asp-action="Conversation" asp-route-id="@Model.UserId" class="btn-nx outline">
                    <i class="bi bi-chat-dots"></i> Chat with Owner
                </a>
            }
        </div>
    }
    else
    {
        <!-- ── Blurred details + paywall for unverified users ── -->

        <!-- Show just the title + location header (no blurring) -->
        <div class="nx-card p-4 mb-3 fade-up">
            <h2 style="font-weight:800;margin-bottom:0.25rem;">@Model.Title</h2>
            <p style="color:var(--muted);margin:0 0 1rem;">
                <i class="bi bi-geo-alt"></i>
                @if (!string.IsNullOrWhiteSpace(Model.District)) { <span>@Model.District@(string.IsNullOrWhiteSpace(Model.Division) ? "" : ", " + Model.Division)</span> }
                else { <span>@Model.Location</span> }
            </p>

            <!-- Blurred detail block -->
            <div class="detail-paywall-wrap" style="min-height: 240px;">
                <div class="detail-blurred">
                    <div class="detail-row">
                        <span class="detail-label">Room Cost</span>
                        <span class="detail-value" style="color:var(--success);font-size:1.1rem;font-weight:800;">BDT ████</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Description</span>
                        <span class="detail-value">████████████ ██████████ ████████ ████</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Posted By</span>
                        <span class="detail-value">█████████</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Wifi / Meal</span>
                        <span class="detail-value">████ / ████</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Posted On</span>
                        <span class="detail-value">██-███-████</span>
                    </div>
                </div>

                <div class="detail-paywall-overlay">
                    <div class="lock-big"><i class="bi bi-lock-fill"></i></div>
                    <h5>Details Locked</h5>
                    <p>Pay a one-time BDT 20 fee to unlock<br />all room listings on Bachelor's Point.</p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Payment" asp-action="RegistrationFee" class="unlock-big-btn">
                            <i class="bi bi-cash-coin"></i> Pay BDT 20 to Unlock
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Register" class="unlock-big-btn">
                            <i class="bi bi-person-plus"></i> Register &amp; Pay
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mb-3">
            <a asp-action="Index" class="btn-nx outline">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    }

    @* Owner: show interested users panel *@
    @if (isOwner && roomSelections != null)
    {
        <div class="mt-4">
            <h4 style="font-weight:800;margin-bottom:1rem;">
                <i class="bi bi-people-fill me-2" style="color:var(--primary);"></i>
                Interested Users
                @if (roomSelections.Any())
                {
                    <span class="nx-badge" style="background:var(--primary);">@roomSelections.Count</span>
                }
            </h4>

            @if (!roomSelections.Any())
            {
                <div class="nx-alert nx-alert-info">
                    <i class="bi bi-info-circle-fill"></i>
                    <span>Nobody has selected this room yet.</span>
                </div>
            }
            else
            {
                <div class="nx-card">
                    @foreach (var s in roomSelections)
                    {
                        <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--border);">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                <div>
                                    <h6 style="margin-bottom:0.25rem;font-weight:700;">
                                        <i class="bi bi-person-circle me-1" style="color:var(--muted);"></i>
                                        @s.Seeker?.UserName
                                    </h6>
                                    <p style="margin:0;font-size:0.85rem;color:var(--muted);">
                                        <i class="bi bi-envelope me-1"></i>@s.Seeker?.Email
                                        @if (!string.IsNullOrWhiteSpace(s.Seeker?.Address))
                                        { <span class="ms-2"><i class="bi bi-geo-alt me-1"></i>@s.Seeker?.Address</span> }
                                    </p>
                                </div>
                                <div class="text-end">
                                    <small style="color:var(--muted);display:block;">
                                        <i class="bi bi-clock me-1"></i>@s.SelectedAt.ToString("dd-MMM-yyyy hh:mm tt")
                                    </small>
                                    @if (s.Seeker != null)
                                    {
                                        <a asp-controller="Chat" asp-action="Conversation" asp-route-id="@s.SeekerUserId"
                                           class="btn-nx success sm mt-1">
                                            <i class="bi bi-chat-dots"></i> Chat
                                        </a>
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(s.Message))
                            {
                                <div class="mt-2" style="background:var(--bg);border-left:3px solid var(--primary);padding:0.5rem 0.75rem;border-radius:var(--radius-sm);">
                                    <i class="bi bi-chat-left-quote me-1" style="color:var(--primary);"></i>
                                    <span style="font-size:0.9rem;">@s.Message</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

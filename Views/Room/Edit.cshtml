@model Room
@{
    ViewData["Title"] = "Edit Room";
}

<div class="container py-4" style="max-width: 640px;">

    <h2 style="font-weight:800;margin-bottom:1.5rem;">
        <i class="bi bi-pencil-square me-2" style="color:var(--primary);"></i>Edit Room
    </h2>

    <div class="nx-card p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="nx-alert nx-alert-danger mb-3"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger" style="font-size:.82rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger" style="font-size:.82rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" type="number" class="form-control" />
                <span asp-validation-for="Price" class="text-danger" style="font-size:.82rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Location" class="form-label"></label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger" style="font-size:.82rem;"></span>
            </div>

            <div class="mb-4" style="display:flex;align-items:center;gap:.6rem;">
                <input asp-for="IsAvailable" class="form-check-input" style="width:20px;height:20px;cursor:pointer;" />
                <label asp-for="IsAvailable" class="form-label mb-0" style="cursor:pointer;">Available</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-nx success">
                    <i class="bi bi-check-lg"></i> Save Changes
                </button>
                <a asp-action="MyListings" class="btn-nx outline">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
